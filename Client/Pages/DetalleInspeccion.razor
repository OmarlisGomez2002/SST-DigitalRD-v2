    private List<(string Label, string Valor)> CamposGenerales => new()
    {
        ("Área",                  Inspeccion.Area),
        ("Obra",                  Inspeccion.Obra),
        ("Tipo",                  Inspeccion.Tipo),
        ("Inspector",             Inspeccion.Inspector),
        ("Fecha y hora",          $"{Inspeccion.Fecha:dd/MM/yyyy} · {Inspeccion.Hora}"),
        ("Trabajadores presentes",$"{Inspeccion.Trabajadores} personas"),
    };

    private static string GetEstadoPill(string e) => e switch
    {
        "Conforme" => "pill-ok",
        "Observación" => "pill-warn",
        "No conforme" => "pill-danger",
        _ => "pill-info"
    };

    private static string GetItemPill(string r) => r switch
    {
        "ok" => "pill-ok",
        "warn" => "pill-warn",
        "no" => "pill-danger",
        _ => "pill-gray"
    };

    private static string GetItemLabel(string r) => r switch
    {
        "ok" => "Cumple",
        "warn" => "Observación",
        "no" => "No cumple",
        _ => "N/A"
    };

    public class InspeccionDetalle
    {
        public int Id { get; set; }
        public string Area { get; set; } = "";
        public string Obra { get; set; } = "";
        public string Tipo { get; set; } = "";
        public string Inspector { get; set; } = "";
        public DateTime Fecha { get; set; }
        public string Hora { get; set; } = "";
        public string HoraFirma { get; set; } = "";
        public int Trabajadores { get; set; }
        public string Estado { get; set; } = "";
        public bool Firmado { get; set; }
        public bool GpsCapturado { get; set; }
        public double Latitud { get; set; }
        public double Longitud { get; set; }
        public double PrecisionGps { get; set; }
        public int Fotos { get; set; }
        public string HashSha256 { get; set; } = "";
        public string PlanAccion { get; set; } = "";
        public List<ChecklistItemDetalle> Items { get; set; } = new();
    }

    public class ChecklistItemDetalle
    {
        public string Categoria { get; set; }
        public string Descripcion { get; set; }
        public string Resultado { get; set; }
        public string Observacion { get; set; }
        public ChecklistItemDetalle(string c, string d, string r, string o)
        { Categoria = c; Descripcion = d; Resultado = r; Observacion = o; }
    }
}