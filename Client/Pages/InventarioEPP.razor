<!-- ===== MODAL DETALLE ===== -->
@if (TrabajadorDetalle is not null)
{
    <div class="modal-backdrop" @onclick="CerrarDetalle">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="inspector-cell">
                    <div class="mini-avatar"
                         style="background:@TrabajadorDetalle.AvatarBg;
                                    color:@TrabajadorDetalle.AvatarColor;
                                    width:36px;height:36px;font-size:13px">
                        @TrabajadorDetalle.Iniciales
                    </div>
                    <div>
                        <div style="font-weight:600;font-size:14px">
                            @TrabajadorDetalle.Nombre
                        </div>
                        <div class="text-hint">
                            @TrabajadorDetalle.Cargo · @TrabajadorDetalle.Cuadrilla
                        </div>
                    </div>
                </div>
                <button class="icon-action" @onclick="CerrarDetalle">
                    <i class="ti ti-x" aria-hidden="true"></i>
                </button>
            </div>

            <div class="modal-body">
                <div class="detalle-section-title">Inventario de EPP asignado</div>
                <div class="epp-detalle-grid">
                    @foreach (var item in GetEppItems(TrabajadorDetalle))
                    {
                        <div class="epp-detalle-item @GetEppClass(item.Estado)">
                            <div class="epp-detalle-icon">
                                <i class="ti @item.Icono" aria-hidden="true"></i>
                            </div>
                            <div class="epp-detalle-info">
                                <div class="epp-detalle-nombre">@item.Nombre</div>
                                <div class="epp-detalle-fecha">
                                    @if (item.Estado == "na")
                                    {
                                        <span>No aplica</span>
                                    }
                                    else if (item.DiasRestantes < 0)
                                    {
                                        <span style="color:#A32D2D">
                                            Vencido hace @Math.Abs(item.DiasRestantes) días
                                        </span>
                                    }
                                    else
                                    {
                                        <span>Vence en @item.DiasRestantes días</span>
                                    }
                                </div>
                            </div>
                            <div>@GetEppPill(item.Estado)</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── Estado UI ──────────────────────────────────────────────
    private string SearchTerm = "";
    private string TabActivo = "trabajador";
    private int PaginaActual = 1;
    private const int PerPage = 8;
    private TrabajadorEPP? TrabajadorDetalle;

    private bool MostrarPanelFiltros = false;
    private string FiltroCuadrilla = "";
    private string FiltroEstadoGeneral = "";
    private string FiltroTipoEPP = "";
    private bool _puedeCrear = false;
    private bool _puedeEditar = false;

    // ── Tabs ───────────────────────────────────────────────────
    private List<TabItem> Tabs => new()
    {
        new("trabajador", "Por trabajador",  ListaTrabajadores.Count),
        new("tipo",       "Por tipo de EPP", 0),
        new("alertas",    "Alertas",         TrabajadoresVencidos.Count + VencenProximo),
        new("historial",  "Historial",       0),
    };

    // ── Métricas ───────────────────────────────────────────────
    private int TotalStock => 248;
    private int VencenProximo => ListaTrabajadores.Count(t => TieneVencimientoProximo(t));
    private int TrabajadoresCubiertos => ListaTrabajadores.Count;
    private int ArticulosPorReponer => StockPorTipo.Count(e => e.Disponibles < 5);

    private List<TrabajadorEPP> TrabajadoresVencidos =>
        ListaTrabajadores.Where(t => t.Casco == "vencido" ||
                                     t.Chaleco == "vencido" ||
                                     t.Botas == "vencido").ToList();
    

    protected override async Task OnInitializedAsync()
    {
        _puedeCrear = await Permisos.PuedeCrear("EPP");
        _puedeEditar = await Permisos.PuedeEditar("EPP");

        try
        {
            var resultado = await Http
                .GetFromJsonAsync<List<EntregaEPPListDto>>(
                    "api/epp");

            if (resultado is not null)
            {
                ListaTrabajadores = resultado.Select(x => new TrabajadorEPP
                {
                    Id = x.Id,
                    Nombre = x.NombreTrabajador,
                    Iniciales = string.Concat(
                    x.NombreTrabajador.Split(' ')
                     .Take(2).Select(p => p[0].ToString()))
                     .ToUpper(),
                    Cargo = x.Cargo,
                    Cuadrilla = x.Cuadrilla,
                    Casco = MapearEstado(x.Articulos
                    .FirstOrDefault(a =>
                        a.TipoEPP == "Casco de seguridad")),
                    Chaleco = MapearEstado(x.Articulos
                    .FirstOrDefault(a =>
                        a.TipoEPP == "Chaleco reflectivo")),
                    Botas = MapearEstado(x.Articulos
                    .FirstOrDefault(a =>
                        a.TipoEPP == "Botas de seguridad")),
                    Guantes = MapearEstado(x.Articulos
                    .FirstOrDefault(a =>
                        a.TipoEPP == "Guantes")),
                    Arnes = MapearEstado(x.Articulos
                    .FirstOrDefault(a =>
                        a.TipoEPP == "Arnés de seguridad")),
                }).ToList();

                // Alertas
                AlertasEPP = await Http
                    .GetFromJsonAsync<List<AlertaEPPDto>>(
                        "api/epp/alertas") ?? new();

                // Historial
                HistorialEPP = await Http
                    .GetFromJsonAsync<List<HistorialEPPDto>>(
                        "api/epp/historial") ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando EPP: {ex.Message}");
        }
    }

    private static string MapearEstado(ArticuloEPPDto? art)
    {
        if (art is null) return "na";
        return art.Estado switch
        {
            "Vigente" => "ok",
            "Vencido" => "Vencido",
            _ => art.Estado
        };
    }

    private async Task DescargarPDFEPP(TrabajadorEPP t)
    {
        var response = await Http.GetAsync($"api/epp/{t.Id}/pdf");

        if (response.IsSuccessStatusCode)
        {
            var bytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"EPP_{t.Nombre.Replace(" ", "_")}.pdf";

            await JS.InvokeVoidAsync("SSTUtil.descargarArchivo",
                fileName, base64, "application/pdf");
        }
    }

    private async Task ExportarCSV()
    {
        var response = await Http.GetAsync("api/epp/export");

        if (response.IsSuccessStatusCode)
        {
            var bytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"EPP_{DateTime.Now:yyyyMMdd}.csv";

            await JS.InvokeVoidAsync("SSTUtil.descargarArchivo",
                fileName, base64, "text/csv");
        }
    }

    private void VerDetalleEPP(TrabajadorEPP t) =>
    Nav.NavigateTo($"/epp/{t.Id}");

    // ── Filtrado y paginación ──────────────────────────────────
    private IEnumerable<TrabajadorEPP> TrabajadoresFiltrados =>
    ListaTrabajadores.Where(t =>
        (string.IsNullOrWhiteSpace(SearchTerm) ||
         t.Nombre.Contains(SearchTerm,
             StringComparison.OrdinalIgnoreCase) ||
         t.Cargo.Contains(SearchTerm,
             StringComparison.OrdinalIgnoreCase) ||
         t.Cuadrilla.Contains(SearchTerm,
             StringComparison.OrdinalIgnoreCase))
        &&
        (string.IsNullOrEmpty(FiltroCuadrilla) ||
         t.Cuadrilla == FiltroCuadrilla)
        &&
        (string.IsNullOrEmpty(FiltroEstadoGeneral) ||
         GetEstadoGeneralTexto(t) == FiltroEstadoGeneral));

    private IEnumerable<TrabajadorEPP> TrabajadoresPaginados =>
        TrabajadoresFiltrados.Skip((PaginaActual - 1) * PerPage).Take(PerPage);

    private int TotalPaginas => Math.Max(1,
        (int)Math.Ceiling(TrabajadoresFiltrados.Count() / (double)PerPage));
    private int PaginaDesde => TrabajadoresFiltrados.Any()
        ? (PaginaActual - 1) * PerPage + 1 : 0;
    private int PaginaHasta => Math.Min(
        PaginaActual * PerPage, TrabajadoresFiltrados.Count());

    private void TogglePanelFiltros() =>
MostrarPanelFiltros = !MostrarPanelFiltros;

    private void LimpiarFiltros()
    {
        FiltroCuadrilla = "";
        FiltroEstadoGeneral = "";
        FiltroTipoEPP = "";
        PaginaActual = 1;
    }

    private void AplicarFiltros()
    {
        PaginaActual = 1;
        MostrarPanelFiltros = false;
    }

    private int FiltrosActivos =>
        (string.IsNullOrEmpty(FiltroCuadrilla) ? 0 : 1) +
        (string.IsNullOrEmpty(FiltroEstadoGeneral) ? 0 : 1) +
        (string.IsNullOrEmpty(FiltroTipoEPP) ? 0 : 1);

    private static string GetEstadoGeneralTexto(TrabajadorEPP t)
    {
        var items = new[] { t.Casco, t.Chaleco, t.Botas, t.Guantes, t.Arnes }
            .Where(x => x != "na").ToList();
        if (items.Any(x => x == "Vencido")) return "Requiere acción";
        if (items.Any(x => x == "Por vencer")) return "Por vencer";
        return "Al día";
    }

    private List<string> CuadrillasUnicas =>
        ListaTrabajadores.Select(t => t.Cuadrilla)
            .Distinct().OrderBy(x => x).ToList();

