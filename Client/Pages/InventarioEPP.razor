    // ── Helpers de pills ───────────────────────────────────────
    private RenderFragment GetEppPill(string estado) => estado switch
    {
        "ok" => @<span class="pill pill-ok"><i class="ti ti-check"></i> Vigente</span>,
        "vencido" => @<span class="pill pill-danger"><i class="ti ti-alert-triangle"></i> Vencido</span>,
        "na" => @<span class="pill pill-gray">N/A</span>,
        _ => @<span class="pill pill-warn">@estado días</span>,
    };

    private RenderFragment GetEstadoGeneralPill(TrabajadorEPP t)
    {
        var items = new[] { t.Casco, t.Chaleco, t.Botas, t.Guantes, t.Arnes }
            .Where(x => x != "na").ToList();

        if (items.Any(x => x == "vencido"))
            return @<span class="pill pill-danger"><i class="ti ti-x"></i> Requiere acción</span>;

        if (items.Any(x => int.TryParse(x, out int d) && d <= 15))
            return @<span class="pill pill-warn"><i class="ti ti-clock"></i> Por vencer</span>;

        return @<span class="pill pill-ok"><i class="ti ti-check"></i> Al día</span>;
    }

    private static string GetEppClass(string estado) => estado switch
    {
        "ok" => "epp-ok",
        "vencido" => "epp-vencido",
        "na" => "epp-na",
        _ => "epp-warn",
    };

    private static bool TieneVencimientoProximo(TrabajadorEPP t)
    {
        var items = new[] { t.Casco, t.Chaleco, t.Botas, t.Guantes, t.Arnes };
        return items.Any(x => x == "vencido" ||
                              (int.TryParse(x, out int d) && d <= 30));
    }

