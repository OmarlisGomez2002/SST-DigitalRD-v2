@page "/epp"
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS
@inject SSTDigitalRD.Client.Services.PermisosService Permisos

<PageTitle>Inventario EPP · SST-Digital RD</PageTitle>

<!-- ===== TOOLBAR ===== -->
<div class="page-toolbar">
    <div class="search-box">
        <i class="ti ti-search" aria-hidden="true"></i>
        <input type="text"
               placeholder="Buscar trabajador, tipo de EPP..."
               @bind="SearchTerm"
               @bind:event="oninput" />
    </div>
    <div class="toolbar-filters">        
        <div class="filtros-panel-wrapper">
            <button class="filter-btn" @onclick="TogglePanelFiltros">
                <i class="ti ti-filter" aria-hidden="true"></i>
                Filtrar
                @if (FiltrosActivos > 0)
                {
                    <span class="filter-badge">@FiltrosActivos</span>
                }
            </button>

            @if (MostrarPanelFiltros)
            {
                <div class="filtros-panel">
                    <div class="filtros-panel-header">
                        <span>Filtros avanzados</span>
                        <button class="icon-action" @onclick="TogglePanelFiltros">
                            <i class="ti ti-x" aria-hidden="true"></i>
                        </button>
                    </div>
                    <div class="filtros-panel-body">
                        <div class="form-field">
                            <label>Cuadrilla</label>
                            <select @bind="FiltroCuadrilla">
                                <option value="">Todas</option>
                                @foreach (var c in CuadrillasUnicas)
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                        </div>
                        <div class="form-field">
                            <label>Estado general</label>
                            <select @bind="FiltroEstadoGeneral">
                                <option value="">Todos</option>
                                <option value="Al día">Al día</option>
                                <option value="Por vencer">Por vencer</option>
                                <option value="Requiere acción">Requiere acción</option>
                            </select>
                        </div>
                    </div>
                    <div class="filtros-panel-footer">
                        <button class="btn-secondary btn-sm"
                                @onclick="LimpiarFiltros">
                            Limpiar
                        </button>
                        <button class="btn-primary btn-sm"
                                @onclick="AplicarFiltros">
                            Aplicar filtros
                        </button>
                    </div>
                </div>
            }
        </div>
        <button class="filter-btn" @onclick="ExportarCSV">
            <i class="ti ti-download" aria-hidden="true"></i>
            Exportar
        </button>        
    </div>
    @if (_puedeCrear)
    {
        <button class="btn-primary" @onclick="AsignarEPP">
            <i class="ti ti-plus" aria-hidden="true"></i>
            Asignar EPP
        </button>
    }
</div>

<!-- ===== MÉTRICAS ===== -->
<div class="insp-stats-row">
    <div class="insp-stat">
        <span class="insp-stat-label">Total artículos en stock</span>
        <span class="insp-stat-val">@TotalStock <small>unidades</small></span>
    </div>
    <div class="insp-stat">
        <span class="insp-stat-label">Vencen en ≤ 30 días</span>
        <span class="insp-stat-val" style="color:#A32D2D">
            @VencenProximo <small>artículos</small>
        </span>
    </div>
    <div class="insp-stat">
        <span class="insp-stat-label">Trabajadores cubiertos</span>
        <span class="insp-stat-val">@TrabajadoresCubiertos <small>activos</small></span>
    </div>
    <div class="insp-stat">
        <span class="insp-stat-label">Artículos por reponer</span>
        <span class="insp-stat-val" style="color:#854F0B">
            @ArticulosPorReponer <small>tipos</small>
        </span>
    </div>
</div>

<!-- ===== ALERTA DE VENCIDOS ===== -->
@if (TrabajadoresVencidos.Any())
{
    <div class="epp-alert-strip">
        <i class="ti ti-alert-triangle" aria-hidden="true"></i>
        <div class="epp-alert-text">
            <div class="epp-alert-title">
                @TrabajadoresVencidos.Count trabajador(es) con EPP vencido hoy
            </div>
            <div class="epp-alert-sub">
                @string.Join(" · ", TrabajadoresVencidos.Select(t => t.Nombre)) — Casco de seguridad vencido
            </div>
        </div>
        <span class="pill pill-danger" style="cursor:pointer">Ver todos →</span>
    </div>
}

<!-- ===== TABS ===== -->
<div class="tabs-bar">
    @foreach (var tab in Tabs)
    {
        <button class="tab @(TabActivo == tab.Key ? "active" : "")"
                @onclick="() => CambiarTab(tab.Key)">
            @tab.Label
            @if (tab.Count > 0)
            {
                <span>(@tab.Count)</span>
            }
        </button>
    }
</div>

<!-- ===== TABLA POR TRABAJADOR ===== -->
@if (TabActivo == "trabajador")
{
    <div class="table-card">
        <table class="insp-table">
            <thead>
                <tr>
                    <th>Trabajador</th>
                    <th>Casco</th>
                    <th>Chaleco</th>
                    <th>Botas</th>
                    <th>Guantes</th>
                    <th>Arnés</th>
                    <th>Estado general</th>
                    <th style="width:80px"></th>
                </tr>
            </thead>
            <tbody>
                @if (!TrabajadoresFiltrados.Any())
                {
                    <tr>
                        <td colspan="8" class="empty-state">
                            <i class="ti ti-hardhat" aria-hidden="true"></i>
                            <span>No se encontraron trabajadores</span>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var t in TrabajadoresPaginados)
                    {
                        <tr>
                            <td>
                                <div class="inspector-cell">
                                    <div class="mini-avatar"
                                         style="background:@t.AvatarBg;color:@t.AvatarColor">
                                        @t.Iniciales
                                    </div>
                                    <div>
                                        <div style="font-weight:500">@t.Nombre</div>
                                        <div class="text-hint">@t.Cargo · @t.Cuadrilla</div>
                                    </div>
                                </div>
                            </td>
                            <td>@GetEppPill(t.Casco)</td>
                            <td>@GetEppPill(t.Chaleco)</td>
                            <td>@GetEppPill(t.Botas)</td>
                            <td>@GetEppPill(t.Guantes)</td>
                            <td>@GetEppPill(t.Arnes)</td>
                            <td>@GetEstadoGeneralPill(t)</td>
                            <td>
                                <div class="row-actions">
                                    <button class="icon-action"
                                            title="Ver detalle"
                                            @onclick="() => VerDetalleEPP(t)">
                                        <i class="ti ti-eye" aria-hidden="true"></i>
                                    </button>
                                    @if (_puedeEditar)
                                    {
                                        <button class="icon-action"
                                                title="Editar EPP"
                                                @onclick="() => EditarEPP(t)">
                                            <i class="ti ti-edit" aria-hidden="true"></i>
                                        </button>
                                    }
                                    
                                    <button class="icon-action" title="Descargar PDF"
                                            @onclick="() => DescargarPDFEPP(t)">
                                        <i class="ti ti-download" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="pagination-bar">
            <span class="page-info">
                Mostrando @PaginaDesde–@PaginaHasta
                de @TrabajadoresFiltrados.Count() trabajadores
            </span>
            <div class="page-btns">
                <button class="page-btn"
                        @onclick="PaginaAnterior"
                        disabled="@(PaginaActual == 1)">
                    <i class="ti ti-chevron-left" aria-hidden="true"></i>
                </button>
                @for (int i = 1; i <= TotalPaginas; i++)
                {
                    var p = i;
                    <button class="page-btn @(PaginaActual == p ? "active" : "")"
                            @onclick="() => IrAPagina(p)">
                        @p
                    </button>
                }
                <button class="page-btn"
                        @onclick="PaginaSiguiente"
                        disabled="@(PaginaActual == TotalPaginas)">
                    <i class="ti ti-chevron-right" aria-hidden="true"></i>
                </button>
            </div>
        </div>
    </div>
}

<!-- ===== TABLA POR TIPO DE EPP ===== -->
@if (TabActivo == "tipo")
{
    <div class="table-card">
        <table class="insp-table">
            <thead>
                <tr>
                    <th>Tipo de EPP</th>
                    <th>Stock total</th>
                    <th>En uso</th>
                    <th>Disponibles</th>
                    <th>Vencen pronto</th>
                    <th>Estado stock</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var epp in StockPorTipo)
                {
                    <tr>
                        <td>
                            <div class="epp-tipo-cell">
                                <div class="epp-tipo-icon"
                                     style="background:@epp.IconoBg">
                                    <i class="ti @epp.Icono"
                                       style="color:@epp.IconoColor"
                                       aria-hidden="true"></i>
                                </div>
                                <div>
                                    <div style="font-weight:500">@epp.Nombre</div>
                                    <div class="text-hint">@epp.Categoria</div>
                                </div>
                            </div>
                        </td>
                        <td>@epp.StockTotal</td>
                        <td>@epp.EnUso</td>
                        <td>@epp.Disponibles</td>
                        <td>
                            @if (epp.VencenProximo > 0)
                            {
                                <span class="pill pill-warn">
                                    <i class="ti ti-clock" aria-hidden="true"></i>
                                    @epp.VencenProximo
                                </span>
                            }
                            else
                            {
                                <span class="pill pill-ok">Ninguno</span>
                            }
                        </td>
                        <td>
                            @{
                                var pct = epp.StockTotal == 0 ? 0 :
                                (double)epp.Disponibles / epp.StockTotal * 100;
                            }
                            <div class="stock-bar-wrap">
                                <div class="stock-bar-track">
                                    <div class="stock-bar-fill"
                                         style="width:@pct%;
                                                        background:@(pct > 30 ? "#3B6D11" :
                                                                                                      pct > 10 ? "#854F0B" : "#A32D2D")">
                            </div>
                        </div>
                        <span class="stock-pct">@pct.ToString("F0")%</span>
                    </div>
                </td>
            </tr>
                        }
            </tbody>
        </table>
    </div>
}

@if (TabActivo == "alertas")
{
    <div class="table-card">
        <table class="insp-table">
            <thead>
                <tr>
                    <th>Trabajador</th>
                    <th>EPP afectado</th>
                    <th>Estado</th>
                    <th>Días restantes</th>
                    <th style="width:80px"></th>
                </tr>
            </thead>
            <tbody>
                @if (!AlertasEPP.Any())
                {
                    <tr>
                        <td colspan="5" class="empty-state">
                            <i class="ti ti-shield-check"
                               style="color:#3B6D11"
                               aria-hidden="true"></i>
                            <span style="color:#3B6D11">
                                Sin alertas de EPP activas
                            </span>
                        </td>
                    </tr>
                }
                @foreach (var alerta in AlertasEPP)
                {
                    var iniciales = string.Concat(
                    alerta.NombreTrabajador.Split(' ')
                    .Take(2).Select(p => p[0].ToString()))
                    .ToUpper();
                    <tr>
                        <td>
                            <div class="inspector-cell">
                                <div class="mini-avatar"
                                     style="background:#E6F1FB;
                                                    color:#185FA5">
                                    @iniciales
                                </div>
                                <div>
                                    <div style="font-weight:500">
                                        @alerta.NombreTrabajador
                                    </div>
                                    <div class="text-hint">
                                        @alerta.Cargo · @alerta.Cuadrilla
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td>@alerta.TipoEPP</td>
                        <td>
                            <span class="pill @(alerta.DiasRestantes < 0
                                                                  ? "pill-danger" : "pill-warn")">
                                @(alerta.DiasRestantes < 0
                                                        ? "Vencido" : "Por vencer")
                    </span>
                </td>
                <td>
                    @if (alerta.DiasRestantes < 0)
                            {
                                <span style="color:#A32D2D;font-weight:500">
                                    Hace @Math.Abs(alerta.DiasRestantes) días
                                </span>
                            }
                            else
                            {
                                <span style="color:#854F0B;font-weight:500">
                                    @alerta.DiasRestantes días
                                </span>
                            }
                        </td>
                        <td>
                            <div class="row-actions">
                                <button class="icon-action"
                                        title="Asignar EPP"
                                        @onclick="AsignarEPP">
                                    <i class="ti ti-plus" aria-hidden="true"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (TabActivo == "historial")
{
    <div class="table-card">
        <table class="insp-table">
            <thead>
                <tr>
                    <th>Trabajador</th>
                    <th>EPP entregado</th>
                    <th>Marca</th>
                    <th>Fecha entrega</th>
                    <th>Fecha vencimiento</th>
                    <th>Entregado por</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @if (!HistorialEPP.Any())
                {
                    <tr>
                        <td colspan="7" class="empty-state">
                            <i class="ti ti-history" aria-hidden="true"></i>
                            <span>Sin historial de entregas</span>
                        </td>
                    </tr>
                }
                @foreach (var hist in HistorialEPP)
                {
                    var iniciales = string.Concat(
                    hist.NombreTrabajador.Split(' ')
                    .Take(2).Select(p => p[0].ToString()))
                    .ToUpper();
                    <tr>
                        <td>
                            <div class="inspector-cell">
                                <div class="mini-avatar"
                                     style="background:#E6F1FB;
                                                    color:#185FA5">
                                    @iniciales
                                </div>
                                @hist.NombreTrabajador
                            </div>
                        </td>
                        <td>@hist.TipoEPP</td>
                        <td>@hist.Marca</td>
                        <td>@hist.FechaEntrega.ToString("dd/MM/yyyy")</td>
                        <td>@hist.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                        <td>@hist.EntregadoPor</td>
                        <td>
                            <span class="pill @(hist.Estado == "Vigente"
                                                                  ? "pill-ok" : "pill-danger")">
                        @hist.Estado
                    </span>
                </td>
            </tr>
                        }
            </tbody>
        </table>
    </div>
}
