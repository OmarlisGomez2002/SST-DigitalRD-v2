    // ── Modelos ────────────────────────────────────────────────
    public class CharlaViewModel
    {
        public int    Id                   { get; set; }
        public string Tema                 { get; set; } = "";
        public string Instructor           { get; set; } = "";
        public string InstructorIni { get; set; } = "";
        public string Obra { get; set; } = "";        
        public string Cuadrilla            { get; set; } = "";
        public DateTime Fecha              { get; set; }
        public string Hora                 { get; set; } = "";
        public string HoraFirma            { get; set; } = "";
        public int      DuracionMinutos { get; set; }
        public int      TotalAsistentes { get; set; }
        public bool     GpsCapturado    { get; set; }
        public bool     FotoCapturada   { get; set; }
        //public int    DuracionMin          { get; set; }
        public int    AsistentesPresentes  { get; set; }
        //public int    AsistentesTotal      { get; set; }
        public bool   Firmado              { get; set; }
        public string Icono                { get; set; } = "ti-speakerphone";
        public string AvatarBg { get; set; } = "#E6F1FB"; //public string IconoBg { get; set; } = "#E6F1FB";
        public string AvatarColor { get; set; } = "#185FA5";  //public string IconoColor { get; set; } = "#185FA5";
        public string HashSha256           { get; set; } = "";
        public List<AsistenteItem> Asistentes { get; set; } = new();
    }

    public class AsistenteItem
    {
        public string Iniciales   { get; set; }
        public string Nombre      { get; set; }
        public bool   Presente    { get; set; }
        public string AvatarBg    { get; set; }
        public string AvatarColor { get; set; }

        public AsistenteItem(string ini, string nom, bool pres, string bg, string color)
        {
            Iniciales = ini; Nombre = nom; Presente = pres;
            AvatarBg = bg;   AvatarColor = color;
        }
    }
