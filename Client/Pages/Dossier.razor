    //     // Abrir el PDF en una nueva pestaña para imprimir
    //     await JS.InvokeVoidAsync("SSTUtil.abrirPdfParaImprimir", base64);
    // }

    private async Task CargarDossier()
    {
        try
        {
            var url = $"api/dossier?periodo={Uri.EscapeDataString(PeriodoActual)}";
            var resumen = await Http.GetFromJsonAsync<DossierResumenDto>(url);

            if (resumen is not null)
            {
                //DiasProximaEntrega = resumen.DiasProximaEntrega;
                _reportesGenerados = resumen.ReportesGenerados;
                _pctCompletitud = resumen.PorcentajeCompletitud;
                _ultimaGeneracion = resumen.UltimaGeneracion;
                _diasProximaEntrega = resumen.DiasProximaEntrega;

                Reportes = resumen.Reportes.Select(r => new ReporteItem
            {
                Letra              = r.Letra,
                Titulo             = r.Titulo,
                BaseLocal          = r.BaseLegal,
                Frecuencia         = r.Frecuencia,
                Detalle            = r.Detalle,
                Periodo            = r.Periodo,
                RegistrosIncluidos = r.RegistrosIncluidos,
                Estado             = r.Estado,
                Completitud        = r.Completitud,
                HashSha256         = r.HashSha256,
                MensajePendiente   = r.MensajePendiente,
                FechaGeneracion    = r.FechaGeneracion,
                Icono              = GetIconoPorLetra(r.Letra),
                IconoBg            = GetIconoBgPorLetra(r.Letra),
                IconoColor         = GetIconoColorPorLetra(r.Letra)
            }).ToList();

                ReporteSeleccionado = Reportes.FirstOrDefault();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando dossier: {ex.Message}");
        }
    }

    // ── Carga desde API ────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _tieneAcceso = await Permisos.TieneAcceso("Dossier");
        if (!_tieneAcceso) return;

        GenerarPeriodos();

        try
        {
            /*var obra = await Http
        .GetFromJsonAsync<ObraActivaDto>(
