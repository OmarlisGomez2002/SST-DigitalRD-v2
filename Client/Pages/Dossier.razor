@page "/dossier"
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS
@inject SSTDigitalRD.Client.Services.PermisosService Permisos

<PageTitle>Dossier MTRAB · SST-Digital RD</PageTitle>

@if (!_tieneAcceso)
{
    <AccesoRestringido />
    return;
}

<!-- ===== TOOLBAR ===== -->
<div class="page-toolbar">
    <div class="toolbar-filters">

        <!-- Filtro empresa/obra -->
        @* <button class="filter-btn">
            <i class="ti ti-building-factory-2" aria-hidden="true"></i>
            @(ObraActual ?? "Cargando...")
        </button> *@

        <!-- Filtro período -->
        <div class="filtros-panel-wrapper">
            <button class="filter-btn"
                    @onclick="() => MostrarSelectorPeriodo =
                    !MostrarSelectorPeriodo">
                <i class="ti ti-calendar" aria-hidden="true"></i>
                @PeriodoActual
            </button>

            @if (MostrarSelectorPeriodo)
            {
                <div class="filtros-panel" style="width:200px">
                    <div class="filtros-panel-header">
                        <span>Período</span>
                        <button class="icon-action"
                                @onclick="() => MostrarSelectorPeriodo = false">
                            <i class="ti ti-x" aria-hidden="true"></i>
                        </button>
                    </div>
                    <div class="filtros-panel-body" style="padding:6px 8px">
                        @foreach (var p in PeriodosDisponibles)
                        {
                            var periodo = p;
                            <div style="padding:7px 8px;cursor:pointer;
                                            border-radius:var(--radius-md);
                                            font-size:13px;
                                            background:@(PeriodoActual == periodo
                                                                         ? "var(--color-background-info)"
                                                                         : "transparent");
                                    color:@(PeriodoActual == periodo
                                                                 ? "var(--color-text-info)"
                                                                 : "var(--color-text-primary)")"
                         @onclick="() => CambiarPeriodo(periodo)">
                        @periodo
                    </div>
                                        }
                    </div>
                </div>
            }
        </div>
    </div>
    @* <button class="btn-primary" style="margin-left:auto"
            @onclick="GenerarDossierCompleto">
        <i class="ti ti-file-certificate" aria-hidden="true"></i>
        Generar dossier completo
    </button> *@
    @* <button class="btn-primary" style="margin-left:auto"
            @onclick="GenerarDossierCompleto"
            disabled="@GenerandoCompleto">
        @if (GenerandoCompleto)
        {
            <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
            <span>Generando...</span>
        }
        else
        {
            <i class="ti ti-file-certificate" aria-hidden="true"></i>
            <span>Generar dossier completo</span>
        }
    </button> *@
</div>

<!-- ===== MÉTRICAS ===== -->
<div class="insp-stats-row">
    <div class="insp-stat">
        <span class="insp-stat-label">Reportes generados</span>
        <span class="insp-stat-val">
            @_reportesGenerados <small>de @Reportes.Count</small>
        </span>
    </div>
    <div class="insp-stat">
        <span class="insp-stat-label">Completitud dossier</span>
        <span class="insp-stat-val" style="color:#3B6D11">
            @_pctCompletitud<small>%</small>
        </span>
    </div>
    <div class="insp-stat">
        <span class="insp-stat-label">Última generación</span>
        <span class="insp-stat-val" style="font-size:16px">
            @_ultimaGeneracion            
            @* <small>@UltimaGeneracion.Year</small> *@
        </span>
    </div>
    <div class="insp-stat">
        <span class="insp-stat-label">Próxima entrega MTRAB</span>
        <span class="insp-stat-val" style="color:#854F0B">
            @_diasProximaEntrega <small>días</small>
        </span>
    </div>
</div>

<!-- ===== CUERPO PRINCIPAL ===== -->
<div class="dossier-layout">

    <!-- ══ COLUMNA IZQUIERDA — Lista de reportes ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-files" aria-hidden="true"></i>
                Reportes reglamentarios — Reg. 522-06
            </span>
            @if (Reportes.Any(r => r.Estado == "urgente"))
            {
                <span class="pill pill-danger" style="margin-left:auto">
                    @Reportes.Count(r => r.Estado == "urgente") urgente(s)
                </span>
            }
            else if (Reportes.Any(r => r.Estado == "pendiente"))
            {
                <span class="pill pill-warn" style="margin-left:auto">
                    @Reportes.Count(r => r.Estado == "pendiente") pendiente(s)
                </span>
            }
            else
            {
                <span class="pill pill-ok" style="margin-left:auto">
                    <i class="ti ti-check" aria-hidden="true"></i> Completo
                </span>
            }
        </div>

        <div class="dossier-rep-list">
            @foreach (var rep in Reportes)
            {
                var r = rep;
                <div class="dossier-rep-item @(ReporteSeleccionado?.Letra == r.Letra ? "active" : "")"
                     @onclick="() => SeleccionarReporte(r)">

                    <div class="dossier-rep-icon" style="background:@r.IconoBg">
                        <i class="ti @r.Icono" style="color:@r.IconoColor;font-size:18px"
                           aria-hidden="true"></i>
                    </div>

                    <div class="dossier-rep-meta">
                        <div class="dossier-rep-titulo">@r.Letra — @r.Titulo</div>
                        <div class="dossier-rep-sub">
                            @r.BaseLegal · @r.Frecuencia · @r.Detalle
                        </div>
                        <div style="display:flex;gap:5px;margin-top:5px;flex-wrap:wrap">
                            <span class="pill @GetEstadoPill(r.Estado)">
                                @GetEstadoLabel(r.Estado)
                            </span>
                            @if (r.Completitud < 100)
                            {
                                <span class="pill pill-gray">
                                    @r.Completitud% completo
                                </span>
                            }
                        </div>
                    </div>

                    <div style="display:flex;gap:6px;flex-shrink:0">
                        @if (r.Estado == "generado")
                        {
                            <button class="icon-action" title="Ver reporte"
                                    @onclick:stopPropagation="true"
                                    @onclick='() => Nav.NavigateTo($"/dossier/{r.Letra}?periodo=" + Uri.EscapeDataString(PeriodoActual))'>
                                <i class="ti ti-eye" aria-hidden="true"></i>
                            </button>
                            <button class="icon-action"
                                    style="background:#185FA5;border-color:#185FA5"
                                    title="Descargar PDF"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => DescargarPDF(r)" >
                                <i class="ti ti-download"
                                   style="color:#fff" aria-hidden="true"></i>
                            </button>
                        }
                        else
                        {
                            @* <button class="icon-action" title="Generar reporte"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => GenerarReporte(r)">
                                <i class="ti ti-refresh" aria-hidden="true"></i>
                            </button>
                            <button class="icon-action" title="Ver datos"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => SeleccionarReporte(r)">
                                <i class="ti ti-eye" aria-hidden="true"></i>
                            </button> *@
                            <button class="icon-action"
                                    title="@(r.Estado == "urgente"
                                                        ? "Notificar al MTRAB"
                                                        : "Generar reporte")"
                            @onclick:stopPropagation="true"
                            @onclick="() => GenerarReporte(r)">
                        <i class="ti @(r.Estado == "urgente"
                                           ? "ti-bell-ringing"
                                           : "ti-refresh")"
                           aria-hidden="true"></i>
                    </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ══ COLUMNA DERECHA ══ -->
    <div style="display:flex;flex-direction:column;gap:12px">

        <!-- Completitud -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-chart-pie" aria-hidden="true"></i>
                    Completitud del dossier
                </span>
            </div>

            <div style="display:flex;flex-direction:column;gap:10px">
                @foreach (var rep in Reportes)
                {
                    <div style="display:flex;align-items:center;gap:10px">
                        <span style="font-size:12px;font-weight:500;
                                         color:var(--text-primary);width:16px;
                                         flex-shrink:0">
                            @rep.Letra
                        </span>
                        <div style="flex:1;height:6px;border-radius:999px;
                                        background:#F0EFEC;overflow:hidden">
                            <div style="height:100%;border-radius:999px;
                                            width:@(rep.Completitud)%;
                                            background:@GetCompletitudColor(rep.Completitud);
                                            transition:width 0.5s ease">
                            </div>
                        </div>
                        <span style="font-size:11px;font-weight:500;min-width:34px;
                                         text-align:right;
                                         color:@GetCompletitudColor(rep.Completitud)">
                            @rep.Completitud%
                        </span>
                    </div>
                }
            </div>
        </div>

        <!-- Detalle del reporte seleccionado -->
        @if (ReporteSeleccionado is not null)
        {
            <div class="dashboard-card">
                <div class="card-header">
                    <span class="card-title">
                        <i class="ti ti-file-certificate" aria-hidden="true"></i>
                        @ReporteSeleccionado.Letra — @ReporteSeleccionado.Titulo
                    </span>
                </div>

                <div class="detalle-section">
                    <div class="detalle-section-title">Identificación</div>
                    <div class="detalle-field">
                        <span class="detalle-label">Empresa</span>
                        <span class="detalle-val">@(EmpresaNombre ?? "—")</span>
                    </div>
                    <div class="detalle-field">
                        <span class="detalle-label">Período</span>
                        <span class="detalle-val">@ReporteSeleccionado.Periodo</span>
                    </div>
                    <div class="detalle-field">
                        <span class="detalle-label">Base legal</span>
                        <span class="detalle-val">@ReporteSeleccionado.BaseLegal</span>
                    </div>
                    <div class="detalle-field">
                        <span class="detalle-label">Registros incluidos</span>
                        <span class="detalle-val">
                            @ReporteSeleccionado.RegistrosIncluidos
                        </span>
                    </div>
                </div>

                @if (ReporteSeleccionado.Estado == "generado")
                {
                    <div class="hash-box" style="margin-bottom:12px">
                        <i class="ti ti-shield-lock" aria-hidden="true"></i>
                        <span class="hash-text">
                            SHA-256: @ReporteSeleccionado.HashSha256
                        </span>
                    </div>

                    <!-- Botones de acción -->
                    <div style="display:flex;flex-direction:column;gap:8px">

                        <button class="dossier-dl-btn"
                                @onclick="() => DescargarPDF(ReporteSeleccionado)">
                            <i class="ti ti-file-download" aria-hidden="true"></i>
                            <div>
                                <div class="dossier-dl-title">Descargar PDF oficial</div>
                                <div class="dossier-dl-sub">
                                    Listo para entregar al MTRAB
                                </div>
                            </div>
                        </button>

                        <button class="dossier-dl-btn"
                                @onclick="() => EnviarPorCorreo(ReporteSeleccionado)"
                                style="background:var(--color-background-secondary)">
                            <i class="ti ti-mail" aria-hidden="true"></i>
                            <div>
                                <div class="dossier-dl-title">Enviar por correo</div>
                                <div class="dossier-dl-sub">
                                    Al correo del Responsable SST
                                </div>
                            </div>
                        </button>

                       
                    </div>
                }
                else
                {
                    <div class="alert-banner @(ReporteSeleccionado.Estado == "urgente"
                                 ? "danger" : "warn")" style="margin-bottom:12px">
                        <i class="ti ti-alert-circle" aria-hidden="true"></i>
                        @ReporteSeleccionado.MensajePendiente
                    </div>
                    <button class="btn-primary"
                            style="width:100%;margin-top:10px;justify-content:center"
                            @onclick="() => GenerarReporte(ReporteSeleccionado)">
                        <i class="ti ti-refresh" aria-hidden="true"></i>
                        Generar ahora
                    </button>
                }

                @* @if (ReporteSeleccionado.Estado == "generado")
                {
                    <div class="hash-box" style="margin-bottom:12px">
                        <i class="ti ti-shield-lock" aria-hidden="true"></i>
                        <span class="hash-text">
                            SHA-256: @ReporteSeleccionado.HashSha256
                        </span>
                    </div>

                    <button class="dossier-dl-btn"
                            @onclick="() => DescargarPDF(ReporteSeleccionado)">
                        <i class="ti ti-file-download" aria-hidden="true"></i>
                        <div>
                            <div class="dossier-dl-title">Descargar PDF oficial</div>
                            <div class="dossier-dl-sub">
                                Listo para entregar al MTRAB
                            </div>
                        </div>
                    </button>
                }
                else
                {
                    <div class="alert-banner @(ReporteSeleccionado.Estado == "urgente" ? "danger" : "warn")">
                        <i class="ti ti-alert-circle" aria-hidden="true"></i>
                        @ReporteSeleccionado.MensajePendiente
                    </div>
                    <button class="btn-primary"
                            style="width:100%;margin-top:10px;
                                           justify-content:center"
                            @onclick="() => GenerarReporte(ReporteSeleccionado)">
                        <i class="ti ti-refresh" aria-hidden="true"></i>
                        Generar ahora
                    </button>
                } *@
            </div>
        }
        else
        {
            <div class="dashboard-card"
                 style="display:flex;flex-direction:column;
                            align-items:center;justify-content:center;
                            min-height:160px;gap:8px;
                            color:var(--text-hint);font-size:13px">
                <i class="ti ti-file-certificate"
                   style="font-size:28px;color:#E2E1DC"
                   aria-hidden="true"></i>
                <span>Selecciona un reporte para ver el detalle</span>
            </div>
        }
    </div>
</div>

@code {
    // ── Estado UI ──────────────────────────────────────────
    private string PeriodoActual = DateTime.Now.ToString("MMMM yyyy");
    //private int DiasProximaEntrega = 18;
