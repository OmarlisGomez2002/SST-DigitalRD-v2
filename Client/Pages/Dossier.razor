            ObraActual = obra?.Nombre;*/

            var empresa = await Http
        .GetFromJsonAsync<ConfiguracionEmpresaDto>(
            "api/configuracion/empresa");
            EmpresaNombre = empresa?.RazonSocial;

            await CargarDossier();
            Cargando = false;

            // var resumen = await Http
            //     .GetFromJsonAsync<DossierResumenDto>("api/dossier");

            // if (resumen is not null)
            // {
            //     DiasProximaEntrega = resumen.DiasProximaEntrega;

            //     Reportes = resumen.Reportes.Select(r => new ReporteItem
            //     {
            //         Letra = r.Letra,
            //         Titulo = r.Titulo,
            //         BaseLocal = r.BaseLegal,
            //         Frecuencia = r.Frecuencia,
            //         Detalle = r.Detalle,
            //         Periodo = r.Periodo,
            //         RegistrosIncluidos = r.RegistrosIncluidos,
            //         Estado = r.Estado,
            //         Completitud = r.Completitud,
            //         HashSha256 = r.HashSha256,
            //         MensajePendiente = r.MensajePendiente,
            //         Icono = GetIconoPorLetra(r.Letra),
            //         IconoBg = GetIconoBgPorLetra(r.Letra),
            //         IconoColor = GetIconoColorPorLetra(r.Letra)
            //     }).ToList();

            //     ReporteSeleccionado = Reportes.FirstOrDefault();
            // }

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando dossier: {ex.Message}");
        }
        finally { Cargando = false; }
    }

    // ── Acciones ───────────────────────────────────────────
    private void SeleccionarReporte(ReporteItem r) =>
        ReporteSeleccionado = r;

    private async Task GenerarReporte(ReporteItem r)
    {
        var response = await Http.PostAsJsonAsync(
            "api/dossier/generar",
            new GenerarReporteDto { Letra = r.Letra,
            Periodo = PeriodoActual });

        if (response.IsSuccessStatusCode)
        {
            /*r.Estado = "generado";
            r.Completitud = 100;
            r.HashSha256 = GenerarHash();*/
            var actualizado = await response.Content
            .ReadFromJsonAsync<ReporteStatusDto>();

            if (actualizado is not null)
            {
                r.Estado = actualizado.Estado;
                r.Completitud = actualizado.Completitud;
                r.HashSha256 = actualizado.HashSha256;
                r.MensajePendiente = actualizado.MensajePendiente;
                r.RegistrosIncluidos = actualizado.RegistrosIncluidos;
                r.Detalle = actualizado.Detalle;
            }

            // Si era el seleccionado, refrescar la vista
            if (ReporteSeleccionado?.Letra == r.Letra)
                ReporteSeleccionado = r;

            StateHasChanged();
        }
    }
