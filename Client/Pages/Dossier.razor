    private bool Cargando = true;

    // ── Lista de reportes ──────────────────────────────────
    private List<ReporteItem> Reportes = new();

    // ── Métricas ───────────────────────────────────────────
    private int _reportesGenerados = 0;
    private int _pctCompletitud = 0;
    private string _ultimaGeneracion = "—";
    private int _diasProximaEntrega = 0;
    // private int PorcentajeCompletitud =>
    //     Reportes.Count == 0 ? 0 :
    //     (int)Math.Round(Reportes.Average(r => r.Completitud));

    // private DateTime UltimaGeneracion = DateTime.Now;
    //private string? ObraActual;
    private string? EmpresaNombre;

    private bool MostrarSelectorPeriodo = false;
    private List<string> PeriodosDisponibles = new();
    private bool _tieneAcceso = true;

    private void GenerarPeriodos()
    {
        var periodos = new List<string>();
        var fecha = DateTime.Now;
        for (int i = 0; i < 12; i++)
        {
            periodos.Add(fecha.AddMonths(-i).ToString("MMMM yyyy"));
        }
        PeriodosDisponibles = periodos;
    }

    private async Task CambiarPeriodo(string periodo)
    {
        PeriodoActual = periodo;
        MostrarSelectorPeriodo = false;
        // Recargar el dossier con el período seleccionado
        await CargarDossier();
    }

    private async Task EnviarPorCorreo(ReporteItem r)
    {
        // Primero descargar el PDF
        var response = await Http.GetAsync($"api/dossier/{r.Letra}/pdf");
        if (!response.IsSuccessStatusCode) return;

        var bytes = await response.Content.ReadAsByteArrayAsync();
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"Dossier_{r.Letra}_{r.Titulo.Replace(" ", "_")}.pdf";

        // Descargar el PDF y abrir el cliente de correo
        await JS.InvokeVoidAsync("SSTUtil.descargarArchivo",
            fileName, base64, "application/pdf");

        // Abrir cliente de correo con asunto precompletado
        var asunto = Uri.EscapeDataString(
            $"Reporte {r.Letra} — {r.Titulo} · SST-Digital RD");
        var cuerpo = Uri.EscapeDataString(
            $"Adjunto el {r.Titulo} del período {r.Periodo} " +
            $"generado por SST-Digital RD.\n\n" +
            $"SHA-256: {r.HashSha256}");

        await JS.InvokeVoidAsync("open",
            $"mailto:?subject={asunto}&body={cuerpo}");
    }

    // private async Task ImprimirReporte(ReporteItem r)
    // {
    //     // Descargar el PDF y luego disparar window.print()
    //     var response = await Http.GetAsync($"api/dossier/{r.Letra}/pdf");
    //     if (!response.IsSuccessStatusCode) return;

    //     var bytes = await response.Content.ReadAsByteArrayAsync();
