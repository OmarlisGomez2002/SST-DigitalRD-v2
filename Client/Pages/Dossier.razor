    private void VerReporte(ReporteItem r) =>
        Nav.NavigateTo($"/dossier/{r.Letra}?periodo=" + Uri.EscapeDataString(PeriodoActual));

    private async Task DescargarPDF(ReporteItem r)
    {
        var response = await Http.GetAsync($"api/dossier/{r.Letra}/pdf");

        if (response.IsSuccessStatusCode)
        {
            var bytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"Dossier_{r.Letra}_{r.Titulo.Replace(" ", "_")}.pdf";

            await JS.InvokeVoidAsync("SSTUtil.descargarArchivo",fileName, base64, "application/pdf");
        }
    }
    

    // ── Helpers de estado ──────────────────────────────────
    private static string GetEstadoPill(string estado) => estado switch
    {
        "generado" => "pill-ok",
        "pendiente" => "pill-warn",
        "urgente" => "pill-danger",
        _ => "pill-gray"
    };

    private static string GetEstadoLabel(string estado) => estado switch
