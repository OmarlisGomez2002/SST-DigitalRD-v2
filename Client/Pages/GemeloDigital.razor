@page "/gemelo-digital"
@inject IJSRuntime JS
@inject HttpClient Http

<PageTitle>Gemelo Digital · SST-Digital RD</PageTitle>

<!-- ===== TOOLBAR ===== -->
<div class="page-toolbar">
    <div class="toolbar-filters">

        @* <button class="filter-btn">
            <i class="ti ti-building-factory-2" aria-hidden="true"></i>
            @(ObraActual ?? "Cargando...")
        </button>

        <button class="filter-btn">
            <i class="ti ti-layers" aria-hidden="true"></i>
            Vista: Planta
        </button> *@

        <div class="filtros-panel-wrapper">
            <button class="filter-btn"
                    @onclick="() => MostrarSelectorObra =
                    !MostrarSelectorObra">
                <i class="ti ti-building-factory-2" aria-hidden="true"></i>
                @(ObraActual ?? "Cargando...")
            </button>

            @if (MostrarSelectorObra)
            {
                <div class="filtros-panel" style="width:220px">
                    <div class="filtros-panel-header">
                        <span>Proyecto / Obra</span>
                        <button class="icon-action"
                                @onclick="() => MostrarSelectorObra = false">
                            <i class="ti ti-x" aria-hidden="true"></i>
                        </button>
                    </div>
                    <div class="filtros-panel-body" style="padding:6px 8px">
                        @foreach (var obra in ObrasDisponibles)
                        {
                            var o = obra;
                            <div style="padding:7px 8px;cursor:pointer;
                                        border-radius:var(--radius-md);
                                        font-size:13px;
                                        background:@(ObraActual == o.Nombre
                                                                     ? "var(--color-background-info)"
                                                                     : "transparent");
                                color:@(ObraActual == o.Nombre
                                                             ? "var(--color-text-info)"
                                                             : "var(--color-text-primary)")"
                         @onclick="() => CambiarObra(o)">
                        @o.Nombre
                    </div>
                                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <button class="btn-primary" style="margin-left:auto"
            @onclick="Actualizar">
        <i class="ti ti-refresh" aria-hidden="true"></i>
        Actualizar
    </button>
</div>

<!-- ===== MÉTRICAS ===== -->
<div class="insp-stats-row">
    <div class="insp-stat">
        <span class="insp-stat-label">Zonas monitoreadas</span>
        <span class="insp-stat-val">@Zonas.Count <small>activas</small></span>
    </div>
    <div class="insp-stat">
        <span class="insp-stat-label">Zonas críticas</span>
        <span class="insp-stat-val" style="color:#A32D2D">
            @Zonas.Count(z => z.PorcentajeRiesgo >= 70) <small>zonas</small>
        </span>
    </div>
    <div class="insp-stat">
        <span class="insp-stat-label">Incidentes acumulados</span>
        <span class="insp-stat-val">
            @Zonas.Sum(z => z.IncidentesAcumulados) <small>este mes</small>
        </span>
    </div>
    <div class="insp-stat">
        <span class="insp-stat-label">Índice de seguridad</span>
        <span class="insp-stat-val" style="color:#3B6D11">
            @IndiceSeguridad<small>/100</small>
        </span>
    </div>
</div>

<!-- ===== CUERPO PRINCIPAL ===== -->
<div class="gemelo-layout">

    <!-- ══ MAPA DE CALOR ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-building-factory-2" aria-hidden="true"></i>
                Mapa de calor — @(ObraActual ?? "Torre Piantini IV")
            </span>
            <span class="pill pill-info" style="margin-left:auto">
                @PisoActual · Planta
            </span>
        </div>

        <!-- Selector de pisos -->
        <div class="gemelo-pisos">
            @foreach (var piso in Pisos)
            {
                var p = piso;
                <button class="gemelo-piso-btn @(PisoActual == p ? "active" : "")"
                        @onclick="() => CambiarPiso(p)">
                    @p
                </button>
            }
        </div>

        <!-- Canvas del plano -->
        <div class="gemelo-plano-wrap">
            <canvas id="gemeloCanvas"
                    class="gemelo-canvas"
                    @onclick="OnCanvasClick">
            </canvas>
        </div>

        <!-- Leyenda -->
        <div class="gemelo-legend">
            <div class="gemelo-leg-item">
                <div class="gemelo-leg-dot" style="background:rgba(226,75,74,0.5)"></div>
                Crítico (≥70%)
            </div>
            <div class="gemelo-leg-item">
                <div class="gemelo-leg-dot" style="background:rgba(239,159,39,0.5)"></div>
                Alto (50-69%)
            </div>
            <div class="gemelo-leg-item">
                <div class="gemelo-leg-dot" style="background:rgba(99,153,34,0.4)"></div>
                Bajo (&lt;50%)
            </div>
            <span class="gemelo-leg-hint">
                El tamaño del círculo indica densidad de incidentes
            </span>
        </div>
    </div>

    <!-- ══ PANEL DERECHO ══ -->
    <div style="display:flex;flex-direction:column;gap:12px">

        <!-- Detalle de zona seleccionada -->
        @if (ZonaSeleccionada is not null)
        {
            <div class="dashboard-card">
                <div class="card-header">
                    <span class="card-title">
                        <i class="ti ti-map-pin" aria-hidden="true"></i>
                        @ZonaSeleccionada.Nombre
                    </span>
                    <span class="pill @GetRiesgoPill(ZonaSeleccionada.PorcentajeRiesgo)"
                          style="margin-left:auto">
                        @GetRiesgoLabel(ZonaSeleccionada.PorcentajeRiesgo)
                    </span>
                </div>

                <div class="detalle-section">
                    <div class="detalle-section-title">Resumen</div>
                    <div class="detalle-field">
                        <span class="detalle-label">Nivel de riesgo</span>
                        <span class="detalle-val"
                              style="color:@GetRiesgoColor(ZonaSeleccionada.PorcentajeRiesgo)">
                            @ZonaSeleccionada.PorcentajeRiesgo% —
                            @GetRiesgoLabel(ZonaSeleccionada.PorcentajeRiesgo)
                        </span>
                    </div>
                    <div class="detalle-field">
                        <span class="detalle-label">Incidentes acumulados</span>
                        <span class="detalle-val">
                            @ZonaSeleccionada.IncidentesAcumulados este mes
                        </span>
                    </div>
                    <div class="detalle-field">
                        <span class="detalle-label">Trabajadores expuestos</span>
                        <span class="detalle-val">
                            @ZonaSeleccionada.TrabajadoresExpuestos personas
                        </span>
                    </div>
                    <div class="detalle-field">
                        <span class="detalle-label">Última inspección</span>
                        <span class="detalle-val"
                              style="color:@(ZonaSeleccionada.DiasUltimaInspeccion > 7 ? "#A32D2D" : "inherit")">
                            Hace @ZonaSeleccionada.DiasUltimaInspeccion días
                        </span>
                    </div>
                </div>
            </div>

            <!-- Eventos recientes -->
            <div class="dashboard-card">
                <div class="card-header">
                    <span class="card-title">
                        <i class="ti ti-clock" aria-hidden="true"></i>
                        Eventos recientes
                    </span>
                </div>
                <div style="display:flex;flex-direction:column;gap:6px">
                    @foreach (var ev in ZonaSeleccionada.Eventos)
                    {
                        <div style="display:flex;align-items:flex-start;gap:8px;
                                            padding:7px 9px;border-radius:var(--radius-md);
                                            border:0.5px solid var(--border)">
                            <div style="width:7px;height:7px;border-radius:50%;
                                                margin-top:4px;flex-shrink:0;
                                                background:@GetEventoColor(ev.Tipo)">
                            </div>
                            <div style="flex:1">
                                <div style="font-size:12px;font-weight:500;
                                                    color:var(--text-primary)">
                                    @ev.Titulo
                                </div>
                                <div style="font-size:11px;color:var(--text-sec);
                                                    margin-top:1px">
                                    @ev.Descripcion
                                </div>
                                <div style="font-size:10px;color:var(--text-hint);
                                                    margin-top:2px">
                                    @ev.Fecha.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="dashboard-card"
                 style="display:flex;flex-direction:column;
                            align-items:center;justify-content:center;
                            min-height:200px;gap:8px;
                            color:var(--text-hint);font-size:13px">
                <i class="ti ti-map-pin"
                   style="font-size:28px;color:#E2E1DC"
                   aria-hidden="true"></i>
                <span>Haz clic en una zona del mapa</span>
            </div>
        }
    </div>
</div>

