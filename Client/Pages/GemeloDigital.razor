    // ── Modelos ────────────────────────────────────────────────
    public class ZonaGemelo
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = "";
        public int PorcentajeRiesgo { get; set; }
        public int IncidentesAcumulados { get; set; }
        public int TrabajadoresExpuestos { get; set; }
        public int DiasUltimaInspeccion { get; set; }
        public double CanvasX { get; set; }
        public double CanvasY { get; set; }
        public double CanvasW { get; set; }
        public double CanvasH { get; set; }
        public List<EventoZona> Eventos { get; set; } = new();
    }

    public class EventoZona
    {
        public string Tipo { get; set; }
        public string Titulo { get; set; }
        public string Descripcion { get; set; }
        public DateTime Fecha { get; set; }

        public EventoZona(string tipo, string titulo,
            string desc, DateTime fecha)
        {
            Tipo = tipo; Titulo = titulo;
            Descripcion = desc; Fecha = fecha;
        }
    }
}