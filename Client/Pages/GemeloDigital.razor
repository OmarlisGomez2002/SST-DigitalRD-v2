    private List<string> Pisos => new List<string> { "Todo" }
    .Concat(Zonas.Select(z => z.Nombre).Distinct())
    .ToList();

    private void GenerarPeriodos()
    {
        var periodos = new List<string>();
        var fecha = DateTime.Now;
        for (int i = 0; i < 12; i++)
            periodos.Add(fecha.AddMonths(-i).ToString("MMMM yyyy"));
        PeriodosDisponibles = periodos;
    }

    private async Task CambiarPeriodo(string periodo)
    {
        PeriodoActual = periodo;
        MostrarSelectorPeriodo = false;
        await CargarDatosReales();
        ZonaSeleccionada = ZonasFiltradas
            .OrderByDescending(z => z.PorcentajeRiesgo)
            .FirstOrDefault();
        await RenderizarMapa();
        StateHasChanged();
    }

    private int IndiceSeguridad =>
        Zonas.Any()
        ? 100 - (int)Math.Round(Zonas.Average(z => z.PorcentajeRiesgo))
        : 100;

    // private List<ZonaGemelo> ZonasFiltradas =>
    // PisoActual == "Todo"
    //     ? Zonas
    //     : Zonas.Where(z =>
    //         z.Nombre.Contains(PisoActual,
    //             StringComparison.OrdinalIgnoreCase))
    //           .ToList();
    private List<ZonaGemelo> ZonasFiltradas =>
    PisoActual == "Todo"
        ? Zonas
        : Zonas.Where(z => z.Nombre == PisoActual).ToList();

    // ── Acciones ───────────────────────────────────────────────
    private void CambiarPiso(string piso)
    {
        PisoActual = piso;
        ZonaSeleccionada = ZonasFiltradas
            .OrderByDescending(z => z.PorcentajeRiesgo)
            .FirstOrDefault();
        StateHasChanged();
        _ = RenderizarMapa();
    }

    private async Task Actualizar()
    {
        await CargarDatosReales();
        ZonaSeleccionada = Zonas
            .OrderByDescending(z => z.PorcentajeRiesgo)
            .FirstOrDefault();
        await RenderizarMapa();
        StateHasChanged();
    }
    //private void Actualizar() => _ = RenderizarMapa();

    private async Task OnCanvasClick(MouseEventArgs e)
    {
        var nombreZona = await JS.InvokeAsync<string?>(
            "SSTGemelo.getZonaEnPunto",
            "gemeloCanvas", e.ClientX, e.ClientY);

        if (!string.IsNullOrEmpty(nombreZona))
        {
            ZonaSeleccionada = ZonasFiltradas
                .FirstOrDefault(z => z.Nombre == nombreZona)
                ?? ZonasFiltradas.OrderByDescending(z => z.PorcentajeRiesgo)
                        .First();
            StateHasChanged();
        }
    }

    // ── Chart ──────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Esperamos que el DOM termine de pintar el contenedor
            await Task.Delay(150);
            await RenderizarMapa();
        }
    }

    private async Task RenderizarMapa()
    {
        var zonaData = ZonasFiltradas.Select(z => new
        {
            nombre = z.Nombre,
            riesgo = z.PorcentajeRiesgo,
            x = z.CanvasX,
            y = z.CanvasY,
            w = z.CanvasW,
            h = z.CanvasH,
            incidentes = z.IncidentesAcumulados
        }).ToArray();

        await JS.InvokeVoidAsync(
            "SSTGemelo.renderMapa", "gemeloCanvas", zonaData);
    }

    // ── Helpers ────────────────────────────────────────────────
    private static string GetRiesgoColor(int pct) => pct switch
    {
        >= 70 => "#A32D2D",
        >= 50 => "#854F0B",
        _ => "#3B6D11"
    };

    private static string GetRiesgoPill(int pct) => pct switch
    {
        >= 70 => "pill-danger",
        >= 50 => "pill-warn",
        _ => "pill-ok"
    };

    private static string GetRiesgoLabel(int pct) => pct switch
    {
        >= 70 => "Crítico",
        >= 50 => "Alto",
        _ => "Bajo"
    };

    private static string GetEventoColor(string tipo) => tipo switch
    {
        "incidente" => "#E24B4A",
        "inspeccion" => "#EF9F27",
        "epp" => "#EF9F27",
        "charla" => "#3B6D11",
        _ => "#888780"
    };

    protected override async Task OnInitializedAsync()
    {
        GenerarPeriodos();
        try
        {
            var obras = await Http
        .GetFromJsonAsync<List<ObraActivaDto>>(
            "api/configuracion/obras");
            if (obras is not null)
            {
                ObrasDisponibles = obras;
                var primera = obras.FirstOrDefault();
                ObraActual = primera?.Nombre;
                ObraSeleccionadaId = primera?.Id ?? 0;
            }
        }
        catch { }

        await CargarDatosReales();
        ZonaSeleccionada = ZonasFiltradas
            .OrderByDescending(z => z.PorcentajeRiesgo)
            .FirstOrDefault();
    }

    private async Task CambiarObra(ObraActivaDto obra)
    {
        ObraActual = obra.Nombre;
        ObraSeleccionadaId = obra.Id;
        MostrarSelectorObra = false;
        await CargarDatosReales();
        ZonaSeleccionada = ZonasFiltradas
            .OrderByDescending(z => z.PorcentajeRiesgo)
            .FirstOrDefault();
        await RenderizarMapa();
        StateHasChanged();
    }

