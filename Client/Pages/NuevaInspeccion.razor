    private void FiltrarResponsables()
    {
        if (string.IsNullOrWhiteSpace(BusquedaResponsable))
        {
            ResponsablesFiltrados = new();
            return;
        }
        ResponsablesFiltrados = TodosEmpleados
            .Where(x => x.Nombre.Contains(
                BusquedaResponsable,
                StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void SeleccionarResponsable(EmpleadoSimpleDto emp)
    {
        Modelo.ResponsableArea = emp.Nombre;
        BusquedaResponsable = emp.Nombre;
        ResponsablesFiltrados = new();
        StateHasChanged();
    }

    private void OnResponsableInput(ChangeEventArgs e)
    {
        BusquedaResponsable = e.Value?.ToString() ?? "";
        Modelo.ResponsableArea = "";
        FiltrarResponsables();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var obras = await Http.GetFromJsonAsync<List<ObraActivaDto>>("api/configuracion/obras");

            if (obras is not null)
                ObrasDisponibles = obras;
            
            var tipos = await Http.GetFromJsonAsync<List<TipoInspeccionDto>>("api/configuracion/tipos-inspeccion");
            if (tipos is not null)
                TiposInspeccionDisponibles = tipos;

            // // Forzar render para que el select tenga las opciones
            // // antes de asignar el valor seleccionado
            // StateHasChanged();
            // await Task.Delay(50);

            // En OnInitializedAsync, después de cargar tipos:
            var itemsChecklist = await Http
                .GetFromJsonAsync<List<ItemChecklistDto>>(
                    "api/configuracion/checklist?soloActivos=true");

            if (itemsChecklist is not null && itemsChecklist.Any())
            {
                ListaVerificacion = itemsChecklist
                    .Select((x, i) => new ChecklistItem(
                        x.Id, x.Categoria, x.Descripcion))
                    .ToList();
            }
            else
            {
                // Fallback con items por defecto si la BD está vacía
                ListaVerificacion = new List<ChecklistItem>
                {
                    new(1, "EPP", "Todo el personal usa casco de seguridad"),
                    new(2, "EPP", "Todo el personal usa chaleco reflectivo"),
                    // ... resto de defaults
                };
            }

            var empleados = await Http
        .GetFromJsonAsync<List<EmpleadoListDto>>(
            "api/empleados");
            if (empleados is not null)
                TodosEmpleados = empleados
                    .Select(x => new EmpleadoSimpleDto
                    {
                        Id = x.Id,
                        Nombre = x.Nombre,
                        Cargo = x.Cargo,
                        Cuadrilla = x.Cuadrilla
                    }).ToList();

            // Si es edición y ya hay obra seleccionada, cargar sus zonas
            if (Modelo.ObraId > 0)
                await CargarZonas(Modelo.ObraId);

            // Si es edición, cargar los datos existentes
            if (EsEdicion && Id.HasValue)
            {
                var dto = await Http
                    .GetFromJsonAsync<InspeccionDetalleDto>(
                        $"api/inspecciones/{Id.Value}");

                if (dto is not null)
                {
                    Modelo.ObraId = dto.ObraId;
                    Modelo.Area = dto.Area;
                    Modelo.TipoInspeccion = dto.TipoInspeccion;
                    Modelo.Inspector = dto.Inspector;
                    Modelo.ResponsableArea = dto.ResponsableArea;
                    Modelo.FechaInspeccion = dto.FechaInspeccion;
                    Modelo.CantidadTrabajadores = dto.CantidadTrabajadores;
                    Modelo.Descripcion = dto.Descripcion;
                    Modelo.Latitud = dto.Latitud;
                    Modelo.Longitud = dto.Longitud;
                    Modelo.PrecisionGps = dto.PrecisionGps;
                    Modelo.PlanAccion = dto.PlanAccion;

                    // GPS ya capturado
                    if (dto.GpsCapturado)
                        GpsCargado = true;

                    // Firma ya capturada
                    if (dto.Firmado)
                        FirmaCapturada = true;

                    // Cargar items del checklist
                    if (dto.Items.Any())
                    {
                        foreach (var itemDto in dto.Items)
                        {
                            var item = ListaVerificacion
                                .FirstOrDefault(x =>
                                    x.Descripcion == itemDto.Descripcion);
                            if (item is not null)
                            {
                                item.Resultado = itemDto.Resultado;
                                item.Observacion = itemDto.Observacion;
                            }
                        }
                    }
                }
            }

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando configuración: {ex.Message}");
        }
    }
