@page "/inspecciones/nueva"
@page "/inspecciones/{Id:int}/editar"
@using SSTDigitalRD.Shared.DTOs
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http

<PageTitle>@(EsEdicion ? "Editar inspección" : "Nueva inspección") · SST-Digital RD</PageTitle>

<!-- ===== ENCABEZADO ===== -->
<div class="form-page-header">
    <button class="btn-back" @onclick="Cancelar">
        <i class="ti ti-arrow-left" aria-hidden="true"></i>
        Volver a inspecciones
    </button>
    <div class="form-page-title">
        <h1>@(EsEdicion ? "Editar inspección" : "Nueva inspección")</h1>
        <span class="form-page-sub">Complete todos los campos requeridos antes de firmar</span>
    </div>
    <div class="form-page-actions">        
        <button class="btn-primary" @onclick="EnviarFormulario" disabled="@(!FormularioValido || Guardando)">
            @if (Guardando)
            {
                <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                <span>Guardando...</span>
            }
            else
            {
                <i class="ti ti-send" aria-hidden="true"></i>
                <span>Enviar inspección</span>
            }
        </button>
    </div>
</div>

<!-- ===== PROGRESO ===== -->
<div class="form-progress">
    @foreach (var (paso, idx) in Pasos.Select((p, i) => (p, i + 1)))
    {
        <div class="progress-step @(PasoActual == idx ? "active" : "") @(PasoActual > idx ? "done" : "")">
            <div class="step-circle">
                @if (PasoActual > idx)
                {
                    <i class="ti ti-check" aria-hidden="true"></i>
                }
                else
                {
                    @idx
                }
            </div>
            <span class="step-label">@paso</span>
        </div>
        @if (idx < Pasos.Count)
        {
            <div class="step-line @(PasoActual > idx ? "done" : "")"></div>
        }
    }
</div>

<!-- ===== CONTENIDO POR PASO ===== -->
<div class="form-body">

    <!-- PASO 1: Datos generales -->
    @if (PasoActual == 1)
    {
        <div class="form-card">
            <div class="form-card-header">
                <i class="ti ti-clipboard-list" aria-hidden="true"></i>
                <span>Datos generales</span>
            </div>

            <div class="form-grid-2">
                <div class="form-field">
                    <label>Obra / Proyecto <span class="required">*</span></label>
                    @* <select @bind="Modelo.ObraId"
                            class="@(MostrarErrores && Modelo.ObraId == 0 ? "input-error" : "")">
                        <option value="0">Seleccionar obra...</option>
                        @foreach (var obra in ObrasDisponibles)
                        {
                            <option value="@obra.Id">@obra.Nombre</option>
                        }
                    </select> *@
                    <select value="@Modelo.ObraId"
                            @onchange="OnObraInspeccionChange">
                        <option value="0">Seleccionar obra...</option>
                        @foreach (var obra in ObrasDisponibles)
                        {
                            <option value="@obra.Id">@obra.Nombre</option>
                        }
                    </select>
                    
                    @if (MostrarErrores && Modelo.ObraId == 0)
                    {
                        <span class="field-error">Seleccione una obra</span>
                    }
                </div>

                <div class="form-field">
                    <label>Área / Zona inspeccionada <span class="required">*</span></label>
                    <select @bind="Modelo.Area"
                            class="@(MostrarErrores &&
                                            string.IsNullOrWhiteSpace(Modelo.Area)
                                            ? "input-error" : "")">
                    <option value="">Seleccionar zona...</option>
                    @foreach (var zona in ZonasDisponibles)
                        {
                            <option value="@zona.Nombre">@zona.Nombre</option>
                        }
                    </select>
                    @* <input type="text"
                           @bind="Modelo.Area"
                           placeholder="Ej. Piso 8 — Estructura metálica"
                           class="@(MostrarErrores && string.IsNullOrWhiteSpace(Modelo.Area) ? "input-error" : "")" /> *@
                    @if (MostrarErrores && string.IsNullOrWhiteSpace(Modelo.Area))
                    {
                        <span class="field-error">El área es requerida</span>
                    }
                </div>

                <div class="form-field">
                    <label>Tipo de inspección <span class="required">*</span></label>
                    <select @bind="Modelo.TipoInspeccion">
                        <option value="">Seleccionar tipo...</option>
                        @foreach (var tipo in TiposInspeccionDisponibles)
                        {
                            <option value="@tipo.Nombre">@tipo.Nombre</option>
                        }
                    </select>
                </div>

                @* <div class="form-field">
                    <label>Responsable del área</label>
                    <input type="text" @bind="Modelo.ResponsableArea" placeholder="Nombre del encargado" />
                </div> *@
                @* <div class="form-field">
                    <label>Responsable del área</label>
                    <input type="text"
                           @bind="BusquedaResponsable"
                           @bind:event="oninput"
                           @oninput="FiltrarResponsables"
                           placeholder="Buscar empleado..."
                           autocomplete="off" />
                    @if (ResponsablesFiltrados.Any() &&
                         !string.IsNullOrWhiteSpace(BusquedaResponsable) &&
                         BusquedaResponsable != Modelo.ResponsableArea)
                    {
                        <div style="position:absolute;z-index:50;width:100%;
                                    background:var(--bg-surface);
                                    border:0.5px solid var(--border-mid);
                                    border-radius:var(--radius-md);
                                    box-shadow:var(--shadow-sm);
                                    max-height:180px;overflow-y:auto">
                            @foreach (var emp in ResponsablesFiltrados.Take(6))
                            {
                                var e = emp;
                                <div style="padding:8px 12px;cursor:pointer;font-size:13px;
                                            border-bottom:0.5px solid var(--border)"
                                     @onclick="() => SeleccionarResponsable(e)">
                                    <div style="font-weight:500">@e.Nombre</div>
                                    <div style="font-size:11px;color:var(--text-hint)">
                                        @e.Cargo · @e.Cuadrilla
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Modelo.ResponsableArea))
                    {
                        <span style="font-size:11px;color:var(--green-600)">
                            <i class="ti ti-check"></i> @Modelo.ResponsableArea
                        </span>
                    }
                </div> *@

                <div class="form-field" style="position:relative">
                    <label>Responsable del área</label>
                    <input type="text"
                           value="@BusquedaResponsable"
                           @oninput="OnResponsableInput"
                           placeholder="Buscar empleado..."
                           autocomplete="off" />
                    @if (ResponsablesFiltrados.Any() &&
                                    !string.IsNullOrWhiteSpace(BusquedaResponsable) &&
                                    BusquedaResponsable != Modelo.ResponsableArea)
                    {
                        <div style="position:absolute;z-index:50;width:100%;
                            background:var(--bg-surface);
                            border:0.5px solid var(--border-mid);
                            border-radius:var(--radius-md);
                            box-shadow:var(--shadow-sm);
                            max-height:180px;overflow-y:auto">
                            @foreach (var emp in ResponsablesFiltrados.Take(6))
                            {
                                var e = emp;
                                <div style="padding:8px 12px;cursor:pointer;font-size:13px;
                                        border-bottom:0.5px solid var(--border)"
                                     @onclick="() => SeleccionarResponsable(e)">
                                    <div style="font-weight:500">@e.Nombre</div>
                                    <div style="font-size:11px;color:var(--text-hint)">
                                        @e.Cargo · @e.Cuadrilla
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Modelo.ResponsableArea))
                    {
                        <span style="font-size:11px;color:var(--green-600)">
                            <i class="ti ti-check" aria-hidden="true"></i>
                            @Modelo.ResponsableArea
                        </span>
                    }
                </div>

                <div class="form-field">
                    <label>Fecha de inspección <span class="required">*</span></label>
                    <input type="date" @bind="Modelo.FechaInspeccion" />
                </div>

                <div class="form-field">
                    <label>Cantidad de trabajadores presentes</label>
                    <input type="number" @bind="Modelo.CantidadTrabajadores" min="0" placeholder="0" />
                </div>
            </div>

            <div class="form-field">
                <label>Descripción general del área</label>
                <textarea @bind="Modelo.Descripcion"
                          rows="3"
                          placeholder="Describa las condiciones generales del área al momento de la inspección...">
                </textarea>
            </div>
        </div>

        <div class="form-nav">
            <div></div>
            <button class="btn-primary" @onclick="Siguiente">
                Siguiente <i class="ti ti-arrow-right" aria-hidden="true"></i>
            </button>
        </div>
    }

    <!-- PASO 2: Lista de verificación -->
    @if (PasoActual == 2)
    {
        <div class="form-card">
            <div class="form-card-header">
                <i class="ti ti-checklist" aria-hidden="true"></i>
                <span>Lista de verificación SST</span>
                <span class="card-badge">@ItemsCompletados / @ListaVerificacion.Count completados</span>
            </div>

            @foreach (var categoria in ListaVerificacion.GroupBy(x => x.Categoria))
            {
                <div class="checklist-group">
                    <div class="checklist-group-title">@categoria.Key</div>
                    @foreach (var item in categoria)
                    {
                        <div class="checklist-item">
                            <div class="checklist-desc">
                                <span class="checklist-label">@item.Descripcion</span>
                                @if (!string.IsNullOrEmpty(item.Observacion))
                                {
                                    <span class="checklist-obs">Obs: @item.Observacion</span>
                                }
                            </div>
                            <div class="checklist-options">
                                <label class="radio-option ok @(item.Resultado == "ok" ? "selected" : "")">
                                    <input type="radio"
                                           name="@($"item_{item.Id}")"
                                           value="ok"
                                           checked="@(item.Resultado == "ok")"
                                           @onchange='() => SetResultado(item, "ok")' />
                                    <i class="ti ti-check" aria-hidden="true"></i>
                                    Cumple
                                </label>
                                <label class="radio-option warn @(item.Resultado == "warn" ? "selected" : "")">
                                    <input type="radio"
                                           name="@($"item_{item.Id}")"
                                           value="warn"
                                           checked="@(item.Resultado == "warn")"
                                           @onchange='() => SetResultado(item, "warn")' />
                                    <i class="ti ti-alert-triangle" aria-hidden="true"></i>
                                    Observ.
                                </label>
                                <label class="radio-option danger @(item.Resultado == "no" ? "selected" : "")">
                                    <input type="radio"
                                           name="@($"item_{item.Id}")"
                                           value="no"
                                           checked="@(item.Resultado == "no")"
                                           @onchange='() => SetResultado(item, "no")' />
                                    <i class="ti ti-x" aria-hidden="true"></i>
                                    No cumple
                                </label>
                                <label class="radio-option @(item.Resultado == "na" ? "selected" : "")">
                                    <input type="radio"
                                           name="@($"item_{item.Id}")"
                                           value="na"
                                           checked="@(item.Resultado == "na")"
                                           @onchange='() => SetResultado(item, " na")' />
                                    N/A
                                </label>
                            </div>
                        </div>
                        @if (item.Resultado == "warn" || item.Resultado == "no")
                        {
                            <div class="obs-input-wrap">
                                <i class="ti ti-message" aria-hidden="true"></i>
                                <input type="text"
                                       placeholder="Describa la observación o no conformidad..."
                                       @bind="item.Observacion" />
                            </div>
                        }
                    }
                </div>
            }
        </div>

        <div class="form-nav">
            <button class="btn-secondary" @onclick="Anterior">
                <i class="ti ti-arrow-left" aria-hidden="true"></i> Anterior
            </button>
            <button class="btn-primary" @onclick="Siguiente">
                Siguiente <i class="ti ti-arrow-right" aria-hidden="true"></i>
            </button>
        </div>
    }

    <!-- PASO 3: GPS -->
    @if (PasoActual == 3)
    {
        <div class="form-card">
            <div class="form-card-header">
                <i class="ti ti-map-pin" aria-hidden="true"></i>
                <span>Geolocalización</span>
                @if (GpsCargado)
                {
                    <span class="card-badge ok">GPS capturado</span>
                }
            </div>

            @if (!GpsCargado && !GpsCargando)
            {
                <div class="gps-empty">
                    <i class="ti ti-current-location" aria-hidden="true"></i>
                    <p>Capture la ubicación GPS actual de la inspección.</p>
                    <p class="gps-sub">Esto vincula el registro al lugar exacto de la obra y es requerido para la validez legal del documento.</p>
                    <button class="btn-primary" @onclick="CapturarGPS">
                        <i class="ti ti-map-pin" aria-hidden="true"></i>
                        Capturar ubicación
                    </button>
                </div>
            }

            @if (GpsCargando)
            {
                <div class="gps-loading">
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                    <span>Obteniendo coordenadas...</span>
                </div>
            }

            @if (GpsCargado)
            {
                <div class="gps-result">
                    <div class="gps-coords-grid">
                        <div class="gps-coord">
                            <span class="gps-coord-label">Latitud</span>
                            <span class="gps-coord-val">@Modelo.Latitud.ToString("F6")</span>
                        </div>
                        <div class="gps-coord">
                            <span class="gps-coord-label">Longitud</span>
                            <span class="gps-coord-val">@Modelo.Longitud.ToString("F6")</span>
                        </div>
                        <div class="gps-coord">
                            <span class="gps-coord-label">Precisión</span>
                            <span class="gps-coord-val">±@Modelo.PrecisionGps.ToString("F0") m</span>
                        </div>
                        <div class="gps-coord">
                            <span class="gps-coord-label">Capturado</span>
                            <span class="gps-coord-val">@DateTime.Now.ToString("hh:mm tt")</span>
                        </div>
                    </div>
                    <div class="gps-map-placeholder">
                        <i class="ti ti-map" aria-hidden="true"></i>
                        <span>Mapa · @Modelo.Latitud.ToString("F4"), @Modelo.Longitud.ToString("F4")</span>
                    </div>
                    <button class="btn-secondary btn-sm" @onclick="RecapturarGPS">
                        <i class="ti ti-refresh" aria-hidden="true"></i>
                        Recapturar
                    </button>
                </div>
            }

            @if (!string.IsNullOrEmpty(GpsError))
            {
                <div class="alert-banner danger">
                    <i class="ti ti-alert-circle" aria-hidden="true"></i>
                    @GpsError
                </div>
            }
        </div>

        <div class="form-nav">
            <button class="btn-secondary" @onclick="Anterior">
                <i class="ti ti-arrow-left" aria-hidden="true"></i> Anterior
            </button>
            <button class="btn-primary" @onclick="Siguiente" disabled="@(!GpsCargado)">
                Siguiente <i class="ti ti-arrow-right" aria-hidden="true"></i>
            </button>
        </div>
    }

    <!-- PASO 4: Firma digital -->
    @if (PasoActual == 4)
    {
        <div class="form-card">
            <div class="form-card-header">
                <i class="ti ti-signature" aria-hidden="true"></i>
                <span>Firma digital</span>
                @if (FirmaCapturada)
                {
                    <span class="card-badge ok">Firma lista</span>
                }
            </div>

            <div class="firma-info">
                <div class="firma-quien">
                    <div class="avatar" style="background:#E6F1FB;color:#185FA5">RG</div>
                    <div>
                        <div class="firma-nombre">Ramón Gómez</div>
                        <div class="firma-rol">Prevencionista SST · SST-Digital RD</div>
                    </div>
                </div>
                <div class="firma-fecha">
                    <i class="ti ti-calendar" aria-hidden="true"></i>
                    @DateTime.Now.ToString("dd/MM/yyyy hh:mm tt")
                </div>
            </div>

            <div class="firma-canvas-wrap">
                <canvas id="firmaIncidenteCanvas"
                        width="600"
                        height="200"
                        class="firma-canvas @(FirmaCapturada ? "signed" : "")">
                </canvas>
                @if (!FirmaCapturada)
                {
                    <div class="firma-placeholder">
                        <i class="ti ti-pencil" aria-hidden="true"></i>
                        Firme aquí con el mouse o con el dedo
                    </div>
                }
            </div>

            <div class="firma-actions">
                <button class="btn-secondary btn-sm" @onclick="LimpiarFirma">
                    <i class="ti ti-eraser" aria-hidden="true"></i>
                    Limpiar
                </button>
                <button class="btn-primary btn-sm" @onclick="CapturarFirma" disabled="@FirmaCapturada">
                    <i class="ti ti-check" aria-hidden="true"></i>
                    @(FirmaCapturada ? "Firma guardada" : "Confirmar firma")
                </button>
            </div>

            @if (FirmaCapturada)
            {
                <div class="alert-banner ok">
                    <i class="ti ti-shield-check" aria-hidden="true"></i>
                    Firma capturada y vinculada con hash SHA-256 al registro de esta inspección.
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(ErrorGeofencing))
        {
            <div class="alert-banner danger"
                 style="margin-bottom:12px">
                <i class="ti ti-map-pin-off" aria-hidden="true"></i>
                <div>
                    <div style="font-weight:500">
                        Registro rechazado por geofencing
                    </div>
                    <div style="font-size:12px;margin-top:2px">
                        @ErrorGeofencing
                    </div>
                </div>
            </div>
        }

        <div class="form-nav">
            <button class="btn-secondary" @onclick="Anterior">
                <i class="ti ti-arrow-left" aria-hidden="true"></i> Anterior
            </button>
            <button class="btn-primary"
                    @onclick="EnviarFormulario"
                    disabled="@(!FirmaCapturada || Guardando)">
                @if (Guardando)
                {
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                    <span>Enviando...</span>
                }
                else
                {
                    <i class="ti ti-send" aria-hidden="true"></i>
                    <span>Enviar inspección</span>
                }
            </button>
        </div>
    }

</div>

@code {

    [Parameter] public int? Id { get; set; }
    private bool EsEdicion => Id.HasValue;

    // ── Pasos ──────────────────────────────────────────────────
    private List<string> Pasos = new() { "Datos generales", "Verificación", "GPS", "Firma" };
    private int PasoActual = 1;
    private bool MostrarErrores = false;

    // ── Estado ─────────────────────────────────────────────────
    private bool Guardando = false;
    private bool GpsCargado = false;
    private bool GpsCargando = false;
    private bool FirmaCapturada = false;
    private string GpsError = "";

    private string ErrorGeofencing = "";

    private string BusquedaResponsable = "";
    private List<EmpleadoSimpleDto> TodosEmpleados = new();
    private List<EmpleadoSimpleDto> ResponsablesFiltrados = new();
    private List<ZonaObraDto> ZonasDisponibles = new();

    // ── Modelo ─────────────────────────────────────────────────
    private InspeccionFormDto Modelo = new()
    {
        FechaInspeccion = DateTime.Today
    };

    // ── Validación ─────────────────────────────────────────────
    private bool FormularioValido =>
        Modelo.ObraId > 0 &&
        !string.IsNullOrWhiteSpace(Modelo.Area) &&
        GpsCargado &&
        FirmaCapturada;

    private int ItemsCompletados =>
        ListaVerificacion.Count(x => !string.IsNullOrEmpty(x.Resultado));

    // ── Navegación de pasos ────────────────────────────────────
    private void Siguiente()
    {
        if (PasoActual == 1)
        {
            MostrarErrores = true;
            if (Modelo.ObraId == 0 || string.IsNullOrWhiteSpace(Modelo.Area)) return;
            MostrarErrores = false;
        }
        if (PasoActual < Pasos.Count) PasoActual++;
    }

    private void Anterior()
    {
        if (PasoActual > 1) PasoActual--;
    }

    // ── GPS ────────────────────────────────────────────────────
    private async Task CapturarGPS()
    {
        GpsCargando = true;
        GpsError = "";
        StateHasChanged();

        try
        {
            var coords = await JS.InvokeAsync<GeoCoords>("SSTGeo.getPosition");
            Modelo.Latitud      = coords.Latitude;
            Modelo.Longitud     = coords.Longitude;
            Modelo.PrecisionGps = coords.Accuracy;
            GpsCargado = true;
        }
        catch (Exception ex)
        {
            GpsError = ex.Message.Contains("denied")
                ? "Permiso de ubicación denegado. Active la geolocalización en su navegador."
                : "No se pudo obtener la ubicación. Verifique su conexión.";
        }
        finally
        {
            GpsCargando = false;
            StateHasChanged();
        }
    }

    private void RecapturarGPS()
    {
        GpsCargado = false;
        Modelo.Latitud = Modelo.Longitud = Modelo.PrecisionGps = 0;
    }

    private async Task OnObraInspeccionChange(ChangeEventArgs e)
    {
        Modelo.ObraId = int.TryParse(
            e.Value?.ToString(), out var id) ? id : 0;
        Modelo.Area = "";
        await CargarZonas(Modelo.ObraId);

        // Forzar render para el select de zonas
        StateHasChanged();
        await Task.Delay(50);
    }

    private async Task CargarZonas(int obraId)
    {
        if (obraId == 0)
        {
            ZonasDisponibles = new();
            return;
        }
        try
        {
            ZonasDisponibles = await Http
                .GetFromJsonAsync<List<ZonaObraDto>>(
                    $"api/configuracion/zonas?obraId={obraId}")
                ?? new();
        }
        catch { ZonasDisponibles = new(); }
        StateHasChanged();
    }

    // ── Firma ──────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (PasoActual == 4) //if (firstRender)
        {
            await JS.InvokeVoidAsync("SSTFirma.init", "firmaIncidenteCanvas");
        }
    }

    private async Task CapturarFirma()
    {
        var dataUrl = await JS.InvokeAsync<string>("SSTFirma.getDataUrl", "firmaIncidenteCanvas");
        if (!string.IsNullOrEmpty(dataUrl) && dataUrl != "data:,")
        {
            Modelo.FirmaBase64 = dataUrl;
            FirmaCapturada = true;
        }
    }

    private async Task LimpiarFirma()
    {
        await JS.InvokeVoidAsync("SSTFirma.clear", "firmaIncidenteCanvas");
        FirmaCapturada = false;
        Modelo.FirmaBase64 = "";
    }

    private class ErrorDto
    {
        public string Error { get; set; } = "";
    }

    // ── Envío ──────────────────────────────────────────────────
    private async Task EnviarFormulario()
    {
        if (!FormularioValido) return;
        Guardando = true;
        ErrorGeofencing = "";
        StateHasChanged();

        // Obtener nombre de obra desde la lista
        var obraNombre = ObrasDisponibles
            .FirstOrDefault(x => x.Id == Modelo.ObraId)
            ?.Nombre ?? "Obra";

        var dto = new CrearInspeccionDto
        {
            ObraId = Modelo.ObraId,
            Area = Modelo.Area,
            Obra = obraNombre, //Modelo.ObraId switch   // ← mapear ID a nombre
            // {
            //     1 => "Torre Piantini IV",
            //     2 => "Residencial Los Alamos",
            //     3 => "Centro Comercial Acropolis",
            //     _ => "Obra"
            // },//.ToString(),
            TipoInspeccion = Modelo.TipoInspeccion,
            Inspector = Modelo.Inspector,
            ResponsableArea = Modelo.ResponsableArea,
            FechaInspeccion = Modelo.FechaInspeccion,
            CantidadTrabajadores = Modelo.CantidadTrabajadores,
            Descripcion = Modelo.Descripcion,
            Latitud = Modelo.Latitud,
            Longitud = Modelo.Longitud,
            PrecisionGps = Modelo.PrecisionGps,
            FirmaBase64 = Modelo.FirmaBase64,
            PlanAccion = Modelo.PlanAccion,
            Items = ListaVerificacion.Select(i =>
                new ChecklistItemDto
                {
                    Categoria = i.Categoria,
                    Descripcion = i.Descripcion,
                    Resultado = i.Resultado,
                    Observacion = i.Observacion
                }).ToList()
        };

        HttpResponseMessage response;

        if (EsEdicion && Id.HasValue)
            response = await Http.PutAsJsonAsync($"api/inspecciones/{Id.Value}", dto);
        else
            response = await Http.PostAsJsonAsync("api/inspecciones", dto);



        if (response.IsSuccessStatusCode)
            Nav.NavigateTo("/inspecciones");
        else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            // Leer el mensaje de error del backend
            var error = await response.Content.ReadFromJsonAsync<ErrorDto>();
            ErrorGeofencing = error?.Error ?? "No se pudo guardar la inspección.";
            Guardando = false;
            StateHasChanged();
        }
        else
        {
            ErrorGeofencing = "Error inesperado. Intente nuevamente.";
            Guardando = false;
            StateHasChanged();
        }
    }

