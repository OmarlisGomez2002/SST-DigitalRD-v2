@page "/epp/asignar"
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http

<PageTitle>Asignar EPP · SST-Digital RD</PageTitle>

<!-- ===== ENCABEZADO ===== -->
<div class="form-page-header">
    <button class="btn-back" @onclick="Cancelar">
        <i class="ti ti-arrow-left" aria-hidden="true"></i>
        Volver a inventario
    </button>
    <div class="form-page-title">
        <h1>Asignar EPP a trabajador</h1>
        <span class="form-page-sub">
            Registre la entrega de equipos y capture la firma del receptor
        </span>
    </div>
    <div class="form-page-actions">        
        <button class="btn-primary"
                @onclick="ConfirmarEntrega"
                disabled="@(!FormularioValido || Guardando)">
            @if (Guardando)
            {
                <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                <span>Guardando...</span>
            }
            else
            {
                <i class="ti ti-send" aria-hidden="true"></i>
                <span>Confirmar entrega</span>
            }
        </button>
    </div>
</div>

<!-- ===== CONTENIDO ===== -->
<div class="asignar-epp-layout">

    <!-- ══ COLUMNA IZQUIERDA ══ -->
    <div class="asignar-epp-left">

        <!-- Selección del trabajador -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-user" aria-hidden="true"></i>
                    Selección del trabajador
                </span>
            </div>

            <div class="form-field">
                <label>Obra / Proyecto <span class="required">*</span></label>
                <select @bind="ObraSeleccionada">
                    <option value="">Seleccionar obra...</option>
                    @foreach (var obra in ObrasDisponibles)
                    {
                        <option value="@obra.Nombre">@obra.Nombre</option>
                    }
                </select>
            </div>

            <div class="form-field">
                <label>Cuadrilla <span class="required">*</span></label>
                <select @bind="CuadrillaSeleccionada"
                        @bind:after="CargarTrabajadores">
                    <option value="">Seleccionar cuadrilla...</option>
                    @foreach (var c in CuadrillasDisponibles)
                    {
                        <option value="@c.Nombre">@c.Nombre</option>
                    }
                </select>
            </div>

            <div class="form-field">
                <label>Trabajador <span class="required">*</span></label>
                <select @bind="TrabajadorSeleccionadoId"
                        @bind:after="CargarEstadoEPP">
                    <option value="0">Seleccionar trabajador...</option>
                    @foreach (var t in TrabajadoresDisponibles)
                    {
                        <option value="@t.Id">@t.Nombre — @t.Cargo</option>
                    }
                </select>
                @if (MostrarErrores && TrabajadorSeleccionadoId == 0)
                {
                    <span class="field-error">Seleccione un trabajador</span>
                }
            </div>

            @if (TrabajadorActivo is not null)
            {
                <div class="worker-selected-card">
                    <div class="mini-avatar"
                         style="background:@TrabajadorActivo.AvatarBg;
                                    color:@TrabajadorActivo.AvatarColor;
                                    width:38px;height:38px;font-size:13px">
                        @TrabajadorActivo.Iniciales
                    </div>
                    <div class="worker-selected-info">
                        <span class="worker-selected-name">@TrabajadorActivo.Nombre</span>
                        <span class="worker-selected-role">
                            @TrabajadorActivo.Cargo · @CuadrillaSeleccionada · Activo
                        </span>
                    </div>
                    <span class="pill @GetEstadoEppPill(TrabajadorActivo)">
                        @GetEstadoEppLabel(TrabajadorActivo)
                    </span>
                </div>
            }
        </div>

        <!-- Lista de artículos EPP -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-hardhat" aria-hidden="true"></i>
                    Artículos a entregar
                </span>
                <span class="card-badge">
                    @ArticulosSeleccionados seleccionado(s)
                </span>
            </div>

            <!-- Cabecera de columnas -->
            <div class="epp-asignar-header">
                <span style="grid-column: 1/3">Equipo</span>
                <span>Marca / Modelo</span>
                <span>Fecha vencimiento</span>
                <span></span>
            </div>

            <div class="epp-asignar-list">
                @foreach (var item in ArticulosEPP)
                {
                    var epp = item;
                    <div class="epp-asignar-row @(epp.Incluido ? "active" : "")">
                        <div class="epp-tipo-icon"
                             style="background:@epp.IconoBg;width:32px;height:32px">
                            <i class="ti @epp.Icono"
                               style="color:@epp.IconoColor"
                               aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="epp-asignar-nombre">@epp.Nombre</div>
                            <div class="text-hint">@epp.Categoria · Stock: @epp.Stock</div>
                        </div>
                        <input type="text"
                               @bind="epp.Marca"
                               placeholder="Marca"
                               disabled="@(!epp.Incluido)"
                               class="@(!epp.Incluido ? "input-disabled" : "")" />
                        <input type="date"
                               @bind="epp.FechaVencimiento"
                               disabled="@(!epp.Incluido)"
                               class="@(!epp.Incluido ? "input-disabled" : "")" />
                        <label class="toggle-asist">
                            <input type="checkbox"
                                   checked="@epp.Incluido"
                                   @onchange="() => epp.Incluido = !epp.Incluido" />
                            <span class="toggle-track">
                                <span class="toggle-thumb"></span>
                            </span>
                        </label>
                    </div>
                }
            </div>

            <div class="epp-asignar-hint">
                <i class="ti ti-info-circle" aria-hidden="true"></i>
                Active el toggle para incluir el artículo en esta entrega.
                Ingrese marca y fecha de vencimiento por cada uno.
            </div>

            @if (MostrarErrores && ArticulosSeleccionados == 0)
            {
                <div class="alert-banner danger" style="margin-top:8px">
                    <i class="ti ti-alert-circle" aria-hidden="true"></i>
                    Seleccione al menos un artículo EPP para continuar.
                </div>
            }
        </div>
    </div>

    <!-- ══ COLUMNA DERECHA ══ -->
    <div class="asignar-epp-right">

        <!-- Registro rechazado por geofencing -->
        @if (!string.IsNullOrEmpty(GpsError) || !string.IsNullOrEmpty(ErrorGeofencing))
        {
            <div class="alert-banner danger" style="margin-top:8px">
                <i class="ti ti-map-pin-off" aria-hidden="true"></i>
                <div>
                    <div style="font-weight:500">
                        @(string.IsNullOrEmpty(ErrorGeofencing) ? "Error de geolocalización" : "Registro rechazado por geofencing")
                    </div>
                    <div style="font-size:12px;margin-top:2px">
                        @(string.IsNullOrEmpty(ErrorGeofencing) ? GpsError : ErrorGeofencing)
                    </div>
                </div>
            </div>
        }

        <!-- Firma del trabajador -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-writing" aria-hidden="true"></i>
                    Firma del trabajador receptor
                </span>
                @if (FirmaCapturada)
                {
                    <span class="card-badge ok">Lista</span>
                }
            </div>

            @if (TrabajadorActivo is not null)
            {
                <div class="firma-info">
                    <div class="firma-quien">
                        <div class="mini-avatar"
                             style="background:@TrabajadorActivo.AvatarBg;
                                        color:@TrabajadorActivo.AvatarColor;
                                        width:28px;height:28px;font-size:11px">
                            @TrabajadorActivo.Iniciales
                        </div>
                        <div>
                            <div class="firma-nombre">@TrabajadorActivo.Nombre</div>
                            <div class="firma-rol">Receptor · @TrabajadorActivo.Cargo</div>
                        </div>
                    </div>
                    <div class="firma-fecha">
                        <i class="ti ti-calendar" aria-hidden="true"></i>
                        @DateTime.Now.ToString("dd/MM/yyyy")
                    </div>
                </div>
            }
            else
            {
                <div class="charla-detalle-empty" style="min-height:60px">
                    <i class="ti ti-user" aria-hidden="true"></i>
                    <span>Seleccione un trabajador primero</span>
                </div>
            }

            <div class="firma-canvas-wrap" style="margin-top:10px">
                <canvas id="firmaEPPCanvas"
                        width="600" height="140"
                        class="firma-canvas @(FirmaCapturada ? "signed" : "")">
                </canvas>
                @if (!FirmaCapturada)
                {
                    <div class="firma-placeholder">
                        <i class="ti ti-pencil" aria-hidden="true"></i>
                        Firme aquí con el mouse o con el dedo
                    </div>
                }
            </div>

            <div class="firma-actions" style="margin-top:8px">
                <button class="btn-secondary btn-sm" @onclick="LimpiarFirma">
                    <i class="ti ti-eraser" aria-hidden="true"></i>
                    Limpiar
                </button>
                <button class="btn-primary btn-sm"
                        @onclick="CapturarFirma"
                        disabled="@(FirmaCapturada || TrabajadorActivo is null)">
                    <i class="ti ti-check" aria-hidden="true"></i>
                    @(FirmaCapturada ? "Firma guardada" : "Confirmar firma")
                </button>
            </div>

            @if (FirmaCapturada)
            {
                <div class="hash-box" style="margin-top:10px">
                    <i class="ti ti-shield-lock" aria-hidden="true"></i>
                    <span class="hash-text">SHA-256: @HashGenerado</span>
                </div>
            }
        </div>

        <!-- GPS -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-map-pin" aria-hidden="true"></i>
                    Geolocalización
                </span>
                @if (GpsCargado)
                {
                    <span class="pill pill-ok" style="margin-left:auto">
                        Capturado
                    </span>
                }
            </div>

            @if (!GpsCargado && !GpsCargando)
            {
                <button class="btn-primary"
                        style="width:100%;justify-content:center"
                        @onclick="CapturarGPS">
                    <i class="ti ti-map-pin" aria-hidden="true"></i>
                    Capturar ubicación GPS
                </button>
            }

            @if (GpsCargando)
            {
                <div style="display:flex;align-items:center;gap:8px;
                        font-size:13px;color:var(--text-sec)">
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                    Obteniendo coordenadas...
                </div>
            }

            @if (GpsCargado)
            {
                <div style="padding:8px 10px;background:#EAF3DE;
                        border-radius:var(--radius-md);
                        font-size:11px;font-family:var(--font-mono);
                        color:#3B6D11">
                    @Latitud.ToString("F6"), @Longitud.ToString("F6")
                    · ±@Precision.ToString("F0")m
                </div>
            }

            @if (!string.IsNullOrEmpty(GpsError))
            {
                <div class="alert-banner danger" style="margin-top:8px">
                    <i class="ti ti-map-pin-off" aria-hidden="true"></i>
                    @GpsError
                </div>
            }
        </div>
        
        

        <!-- Resumen de entrega -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-receipt" aria-hidden="true"></i>
                    Resumen de entrega
                </span>
            </div>

            <div class="epp-resumen-card">
                <div class="epp-resumen-row">
                    <span class="epp-resumen-label">Trabajador</span>
                    <span class="epp-resumen-val">
                        @(TrabajadorActivo?.Nombre ?? "—")
                    </span>
                </div>
                <div class="epp-resumen-row">
                    <span class="epp-resumen-label">Obra</span>
                    <span class="epp-resumen-val">
                        @(string.IsNullOrEmpty(ObraSeleccionada) ? "—" : ObraSeleccionada)
                    </span>
                </div>
                <div class="epp-resumen-row">
                    <span class="epp-resumen-label">Artículos</span>
                    <span class="epp-resumen-val">
                        @ArticulosSeleccionados equipo(s)
                    </span>
                </div>
                <div class="epp-resumen-row">
                    <span class="epp-resumen-label">Próx. vencimiento</span>
                    <span class="epp-resumen-val" style="color:#854F0B">
                        @ProximoVencimiento
                    </span>
                </div>
                <div class="epp-resumen-row total">
                    <span class="epp-resumen-label">Estado</span>
                    @if (FormularioValido)
                    {
                        <span class="pill pill-ok">
                            <i class="ti ti-check" aria-hidden="true"></i>
                            Listo para confirmar
                        </span>
                    }
                    else
                    {
                        <span class="pill pill-warn">Pendiente</span>
                    }
                </div>
            </div>

            <div class="epp-asignar-hint" style="margin-top:10px">
                <i class="ti ti-bell" aria-hidden="true"></i>
                El sistema enviará alerta automática 30 días antes
                del próximo vencimiento.
            </div>
        </div>
    </div>
</div>

@code {
    private string ObraSeleccionada = "";
    private string CuadrillaSeleccionada = "";
    private int TrabajadorSeleccionadoId = 0;
    private bool MostrarErrores = false;
    private bool Guardando = false;
    private bool FirmaCapturada = false;
    private string HashGenerado = "";

    // GPS
    private bool GpsCargado = false;
    private bool GpsCargando = false;
    private string GpsError = "";
    private double Latitud = 0;
    private double Longitud = 0;
    private double Precision = 0;

    // Listas dinámicas
    private List<ObraActivaDto> ObrasDisponibles = new();
    private List<CuadrillaDto> CuadrillasDisponibles = new();
    private List<EmpleadoListDto> TrabajadoresDisponibles = new();

    private TrabajadorItem? TrabajadorActivo =>
        TrabajadoresDisponibles
            .Where(t => t.Id == TrabajadorSeleccionadoId)
            .Select(t => new TrabajadorItem(
                t.Id, t.Nombre,
                string.Concat(t.Nombre.Split(' ')
                    .Take(2).Select(p => p[0].ToString()))
                    .ToUpper(),
                t.Cargo, "#E6F1FB", "#185FA5",
                "ok", "ok", "ok"))
            .FirstOrDefault();

    private int ArticulosSeleccionados =>
        ArticulosEPP.Count(x => x.Incluido);

    private string ProximoVencimiento
    {
        get
        {
            var fechas = ArticulosEPP
                .Where(x => x.Incluido && x.FechaVencimiento != default)
                .Select(x => x.FechaVencimiento)
                .ToList();
            return fechas.Any()
                ? fechas.Min().ToString("dd/MM/yyyy") : "—";
        }
    }

    private bool FormularioValido =>
        !string.IsNullOrEmpty(ObraSeleccionada) &&
        TrabajadorSeleccionadoId > 0 &&
        ArticulosSeleccionados > 0 &&
        ArticulosEPP.Where(x => x.Incluido)
                    .All(x => x.FechaVencimiento != default) &&
        FirmaCapturada &&
        GpsCargado;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ObrasDisponibles = await Http
                .GetFromJsonAsync<List<ObraActivaDto>>(
                    "api/configuracion/obras") ?? new();

            CuadrillasDisponibles = await Http
                .GetFromJsonAsync<List<CuadrillaDto>>(
                    "api/configuracion/cuadrillas") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando datos: {ex.Message}");
        }
    }

    private async Task CargarTrabajadores()
    {
        TrabajadorSeleccionadoId = 0;
        TrabajadoresDisponibles = new();
        if (string.IsNullOrEmpty(CuadrillaSeleccionada)) return;

        try
        {
            var todos = await Http
                .GetFromJsonAsync<List<EmpleadoListDto>>(
                    $"api/empleados?cuadrilla=" +
                    Uri.EscapeDataString(CuadrillaSeleccionada)
                    + "&estado=Activo");

            if (todos is not null)
                TrabajadoresDisponibles = todos;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando trabajadores: {ex.Message}");
        }
    }

    private void CargarEstadoEPP()
    {
        FirmaCapturada = false;
        HashGenerado = "";
        foreach (var item in ArticulosEPP)
        {
            item.Incluido = false;
            item.Marca = "";
            item.FechaVencimiento = default;
        }
    }

    // ── GPS ────────────────────────────────────────────────────
    private async Task CapturarGPS()
    {
        GpsCargando = true;
        GpsError = "";
        StateHasChanged();

        try
        {
            var coords = await JS.InvokeAsync<GeoCoords>("SSTGeo.getPosition");
            Latitud = coords.Latitude;
            Longitud = coords.Longitude;
            Precision = coords.Accuracy;
            GpsCargado = true;
        }
        catch
        {
            GpsError = "No se pudo obtener la ubicación. " +
                       "Active el GPS e intente nuevamente.";
        }
        finally
        {
            GpsCargando = false;
            StateHasChanged();
        }
    }

    public class GeoCoords
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public double Accuracy { get; set; }
    }

    // ── Firma ──────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || !FirmaCapturada)
            await JS.InvokeVoidAsync("SSTFirma.init", "firmaEPPCanvas");
    }

    private async Task CapturarFirma()
    {
        var dataUrl = await JS.InvokeAsync<string>(
            "SSTFirma.getDataUrl", "firmaEPPCanvas");
        if (!string.IsNullOrEmpty(dataUrl) && dataUrl != "data:,")
        {
            FirmaCapturada = true;
            HashGenerado = GenerarHashSimulado();
            StateHasChanged();
        }
    }

    private async Task LimpiarFirma()
    {
        await JS.InvokeVoidAsync("SSTFirma.clear", "firmaEPPCanvas");
        FirmaCapturada = false;
        HashGenerado = "";
    }

    private static string GenerarHashSimulado()
    {
        var chars = "abcdef0123456789";
        var rng = new Random();
        return new string(
            Enumerable.Range(0, 64)
                      .Select(_ => chars[rng.Next(chars.Length)])
                      .ToArray());
    }
    private string ErrorGeofencing = "";

    // ── Confirmación ───────────────────────────────────────────
    private async Task ConfirmarEntrega()
    {
        MostrarErrores = true;
        ErrorGeofencing = "";
        if (!FormularioValido) return;
        Guardando = true;
        StateHasChanged();

        var trabajador = TrabajadorActivo;
        var obraId = ObrasDisponibles.FirstOrDefault(o => o.Nombre == ObraSeleccionada)?.Id ?? 0;

        var dto = new CrearEntregaEPPDto
        {
            NombreTrabajador = trabajador?.Nombre ?? "",
            CedulaTrabajador = "",
            Cargo = trabajador?.Cargo ?? "",
            Cuadrilla = CuadrillaSeleccionada,
            Obra = ObraSeleccionada,
            ObraId = obraId,
            EntregadoPor = "Ramón Gómez",
            FechaEntrega = DateTime.Now,
            FirmaBase64 = FirmaCapturada ? HashGenerado : null,
            Latitud = Latitud,   // ← variables GPS
            Longitud = Longitud,
            Articulos = ArticulosEPP
                .Where(a => a.Incluido)
                .Select(a => new ArticuloEPPDto
                {
                    TipoEPP = a.Nombre,
                    Categoria = a.Categoria,
                    Marca = a.Marca,
                    FechaVencimiento = a.FechaVencimiento,
                    Estado = "Vigente"
                }).ToList()
        };

        var response = await Http.PostAsJsonAsync("api/epp", dto);


        if (response.IsSuccessStatusCode)
            Nav.NavigateTo("/epp");
        else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            // Leer el mensaje de error del backend
            var error = await response.Content.ReadFromJsonAsync<ErrorDto>();
            ErrorGeofencing = error?.Error ?? "No se pudo guardar la entrega.";
            Guardando = false;
            StateHasChanged();
        }
        else
        {
            ErrorGeofencing = "Error inesperado. Intente nuevamente.";
            Guardando = false;
            StateHasChanged();
        }
    }

    private class ErrorDto
    {
        public string Error { get; set; } = "";
    }

    private void Cancelar() => Nav.NavigateTo("/epp");

    // ── Helpers ────────────────────────────────────────────────
    private static string GetEstadoEppPill(TrabajadorItem t)
    {
        var items = new[] { t.Casco, t.Chaleco, t.Botas };
        if (items.Any(x => x == "vencido")) return "pill-danger";
        if (items.Any(x =>
            int.TryParse(x, out int d) && d <= 30)) return "pill-warn";
        return "pill-ok";
    }

    private static string GetEstadoEppLabel(TrabajadorItem t)
    {
        var items = new[] { t.Casco, t.Chaleco, t.Botas };
        if (items.Any(x => x == "vencido")) return "EPP vencido";
        if (items.Any(x =>
            int.TryParse(x, out int d) && d <= 30)) return "Por vencer";
        return "Al día";
    }

    // ── Datos ──────────────────────────────────────────────────
    private List<ArticuloEPP> ArticulosEPP = new()
    {
        new("ti-hardhat",   "#E6F1FB","#185FA5",
            "Casco de seguridad", "Protección craneal",   7),
        new("ti-shirt",     "#EAF3DE","#3B6D11",
            "Chaleco reflectivo",  "Visibilidad",          12),
        new("ti-shoe",      "#FAEEDA","#854F0B",
            "Botas de seguridad",  "Protección de pies",   2),
        new("ti-hand-stop", "#F1EFE8","#5F5E5A",
            "Guantes",             "Protección de manos",  30),
        new("ti-ripple",    "#FCEBEB","#A32D2D",
            "Arnés de seguridad",  "Trabajo en altura",    5),
        new("ti-eyeglass",  "#EAF3DE","#3B6D11",
            "Gafas de seguridad",  "Protección ocular",    13),
    };

    // ── Modelos ────────────────────────────────────────────────
    public class TrabajadorItem
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = "";
        public string Iniciales { get; set; } = "";
        public string Cargo { get; set; } = "";
        public string AvatarBg { get; set; } = "#E6F1FB";
        public string AvatarColor { get; set; } = "#185FA5";
        public string Casco { get; set; } = "ok";
        public string Chaleco { get; set; } = "ok";
        public string Botas { get; set; } = "ok";

        public TrabajadorItem(int id, string nombre, string ini,
            string cargo, string bg, string color,
            string casco, string chaleco, string botas)
        {
            Id = id; Nombre = nombre; Iniciales = ini;
            Cargo = cargo; AvatarBg = bg; AvatarColor = color;
            Casco = casco; Chaleco = chaleco; Botas = botas;
        }
    }

    public class ArticuloEPP
    {
        public string Icono { get; set; }
        public string IconoBg { get; set; }
        public string IconoColor { get; set; }
        public string Nombre { get; set; }
        public string Categoria { get; set; }
        public int Stock { get; set; }
        public bool Incluido { get; set; }
