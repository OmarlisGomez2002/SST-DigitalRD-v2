    }

    private async Task<List<RegistroItem>> CargarRegistrosE()
    {
        var entregas = await Http
            .GetFromJsonAsync<List<EntregaEPPListDto>>(
                "api/epp") ?? new();
        
        var filtradas = entregas
        .Where(x => x.FechaEntrega >= InicioMes &&
