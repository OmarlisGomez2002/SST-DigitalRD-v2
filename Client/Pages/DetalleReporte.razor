        return items;
    }

    private async Task<List<RegistroItem>> CargarRegistrosF()
    {
        var incidentes = await Http
            .GetFromJsonAsync<List<IncidenteListDto>>(
                "api/incidentes") ?? new();

        var graves = incidentes
            .Where(x => x.Tipo == "Accidente grave" &&
                    x.Fecha >= InicioMes &&
                    x.Fecha <= FinMes)
            .OrderByDescending(x => x.Fecha)
            .Take(10)//.Take(5)
            .Select(x => new RegistroItem(
                "ti-first-aid-kit", "#FCEBEB", "#A32D2D",
                $"{x.Tipo} — {x.Area}",
                $"{x.Fecha:dd/MM/yyyy} · {x.Afectado} · {x.Estado}"))
            .ToList();

        if (!graves.Any())
            graves.Add(new("ti-check", "#EAF3DE", "#3B6D11",
                "Sin accidentes graves",
                "No hay accidentes graves " +
            $"{InicioMes:MMMM yyyy}"));

        return graves;
    }

