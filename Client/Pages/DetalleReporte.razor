    // ── Modelos ────────────────────────────────────────────────
    public class ReporteDetalle
    {
        public string Titulo { get; set; } = "";
        public string BaseLegal { get; set; } = "";
        public string Periodo { get; set; } = "";
        public DateTime FechaGeneracion { get; set; } = DateTime.Now;
        public string HashSha256 { get; set; } = "";
        public List<RegistroItem> RegistrosIncluidos { get; set; } = new();
        public List<ArticuloLegal> ArticulosLegales { get; set; } = new();
        public List<VersionReporte> Versiones { get; set; } = new();
    }

    public class RegistroItem
    {
        public string Icono { get; set; }
        public string IconoBg { get; set; }
        public string IconoColor { get; set; }
        public string Titulo { get; set; }
        public string Descripcion { get; set; }
        public RegistroItem(string i, string bg, string c, string t, string d)
        { Icono = i; IconoBg = bg; IconoColor = c; Titulo = t; Descripcion = d; }
    }

    public class ArticuloLegal
    {
        public string Numero { get; set; }
        public string Texto { get; set; }
        public ArticuloLegal(string n, string t) { Numero = n; Texto = t; }
    }

    public class VersionReporte
    {
        public DateTime Fecha { get; set; }
        public string Autor { get; set; }
        public bool Activa { get; set; }
        public VersionReporte(DateTime f, string a, bool act)
        { Fecha = f; Autor = a; Activa = act; }
    }
}