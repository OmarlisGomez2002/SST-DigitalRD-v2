        $"{(x.Firmado ? "Firmada" : "Pendiente")}"))
        .ToList();



        // var items = charlas
        //     .OrderByDescending(x => x.FechaCharla)
        //     .Take(5)
        //     .Select(x => new RegistroItem(
        //         "ti-speakerphone", "#E6F1FB", "#185FA5",
        //         x.Tema,
        //         $"{x.FechaCharla:dd/MM/yyyy} · " +
        //         $"{x.TotalAsistentes} asistentes · {x.Cuadrilla}"))
        //     .ToList();

        if (!items.Any())
            items.Add(new("ti-alert-circle", "#E6F1FB", "#185FA5",
