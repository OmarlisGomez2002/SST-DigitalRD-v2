@page "/dossier/{Letra}"
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Reporte @Letra · SST-Digital RD</PageTitle>

<!-- ===== ENCABEZADO ===== -->
<div class="form-page-header">
    <button class="btn-back" @onclick="VolverAlDossier">
        <i class="ti ti-arrow-left" aria-hidden="true"></i>
        Volver al dossier
    </button>
    <div class="form-page-title">
        <h1>Reporte @Letra — @Reporte.Titulo</h1>
        <span class="form-page-sub">
            @Reporte.BaseLegal · Generado el @Reporte.FechaGeneracion.ToString("dd/MM/yyyy")
            · @Reporte.Periodo
        </span>
    </div>
    <div class="form-page-actions">        
        <button class="btn-primary" @onclick="DescargarPDF">
            <i class="ti ti-download" aria-hidden="true"></i>
            Descargar PDF
        </button>
    </div>
</div>

<!-- ===== CONTENIDO ===== -->
<div class="detalle-reporte-layout">

    <!-- ══ COLUMNA IZQUIERDA ══ -->
    <div style="display:flex;flex-direction:column;gap:12px">

        <!-- Identificación -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-info-circle" aria-hidden="true"></i>
                    Identificación del reporte
                </span>
                <span class="pill pill-ok" style="margin-left:auto">
                    <i class="ti ti-check" aria-hidden="true"></i>
                    Generado y sellado
                </span>
            </div>
            <div style="display:flex;flex-direction:column">
                @foreach (var campo in CamposIdentificacion)
                {
                    <div style="display:flex;flex-direction:column;gap:2px;
                                    padding:7px 0;border-bottom:0.5px solid var(--border)">
                        <span class="text-hint" style="font-size:11px">
                            @campo.Label
                        </span>
                        <span style="font-size:13px;font-weight:500;
                                         color:var(--text-primary)">
                            @campo.Valor
                        </span>
                    </div>
                }
            </div>
        </div>

        <!-- Registros incluidos — varía por tipo -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-list-check" aria-hidden="true"></i>
                    Registros incluidos
                </span>
                <span class="pill pill-info" style="margin-left:auto">
                    @Reporte.RegistrosIncluidos.Count items
                </span>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px">
                @foreach (var reg in Reporte.RegistrosIncluidos)
                {
                    <div style="display:flex;align-items:center;gap:10px;
                                    padding:8px 10px;border:0.5px solid var(--border);
                                    border-radius:var(--radius-md)">
                        <div style="width:32px;height:32px;border-radius:var(--radius-md);
                                        display:flex;align-items:center;justify-content:center;
                                        flex-shrink:0;background:@reg.IconoBg">
                            <i class="ti @reg.Icono"
                               style="font-size:16px;color:@reg.IconoColor"
                               aria-hidden="true"></i>
                        </div>
                        <div style="flex:1">
                            <div style="font-size:12px;font-weight:500;
                                            color:var(--text-primary)">
                                @reg.Titulo
                            </div>
                            <div class="text-hint">@reg.Descripcion</div>
                        </div>
                        <span class="pill pill-ok">Incluido</span>
                    </div>
                }
            </div>
        </div>

        <!-- Artículos legales aplicados -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-book" aria-hidden="true"></i>
                    Marco legal aplicado
                </span>
            </div>
            <div style="display:flex;flex-direction:column">
                @foreach (var art in Reporte.ArticulosLegales)
                {
                    <div style="display:flex;align-items:flex-start;gap:8px;
                                    padding:8px 0;border-bottom:0.5px solid var(--border)">
                        <div style="width:22px;height:22px;border-radius:50%;
                                        background:#E6F1FB;color:#185FA5;
                                        font-size:10px;font-weight:500;
                                        display:flex;align-items:center;
                                        justify-content:center;flex-shrink:0;margin-top:1px">
                            @art.Numero
                        </div>
                        <div style="font-size:12px;color:var(--text-primary);
                                        line-height:1.5">
                            @art.Texto
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ══ COLUMNA DERECHA ══ -->
    <div style="display:flex;flex-direction:column;gap:12px">

        <!-- Integridad -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-shield-lock" aria-hidden="true"></i>
                    Integridad del documento
                </span>
            </div>
            <div style="display:flex;flex-direction:column;gap:8px">
                <div class="text-hint" style="font-size:11px">Hash SHA-256</div>
                <div class="hash-box">
                    <i class="ti ti-shield-lock" aria-hidden="true"></i>
                    <span class="hash-text">@Reporte.HashSha256</span>
                </div>
                <div class="text-hint">
                    Generado: @Reporte.FechaGeneracion.ToString("dd/MM/yyyy hh:mm tt")
                </div>
                <div class="text-hint">
                    Validez legal: Ley 126-02, Art. 7
                </div>
            </div>
        </div>
        
        <!-- Historial de versiones -->
        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-clock" aria-hidden="true"></i>
                    Historial de versiones
                </span>
            </div>
            <div style="display:flex;flex-direction:column">
                @foreach (var ver in Reporte.Versiones)
                {
                    <div style="display:flex;align-items:center;gap:8px;
                                    padding:7px 0;border-bottom:0.5px solid var(--border)">
                        <div style="width:7px;height:7px;border-radius:50%;
                                        flex-shrink:0;
                                        background:@(ver.Activa ? "#3B6D11" : "#888780")">
                        </div>
                        <div style="flex:1">
                            <div style="font-size:12px;font-weight:500;
                                            color:var(--text-primary)">
                                @(ver.Activa ? "Versión actual" : "Versión anterior")
                            </div>
                            <div class="text-hint">
                                @ver.Fecha.ToString("dd/MM/yyyy") · @ver.Autor
                            </div>
                        </div>
                        <span class="pill @(ver.Activa ? "pill-ok" : "pill-gray")">
                            @(ver.Activa ? "Activa" : "Archivada")
                        </span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Letra { get; set; } = "A";
    [Parameter]
    [SupplyParameterFromQuery(Name = "periodo")]
    public string? PeriodoQuery { get; set; }

    // Fechas calculadas del período
    private DateTime InicioMes;
    private DateTime FinMes;
        
    private ReporteDetalle Reporte = new();

    private string EmpresaNombre = "";
    private string EmpresaRNC = "";
    private string ResponsableSST = "";

    private void VolverAlDossier() => Nav.NavigateTo("/dossier");

    private void ParsearPeriodo()
    {
        if (!string.IsNullOrEmpty(PeriodoQuery) &&
            DateTime.TryParseExact(
                PeriodoQuery,
                new[] { "MMMM yyyy", "MMMM\u00a0yyyy" },
                new System.Globalization.CultureInfo("es-DO"),
                System.Globalization.DateTimeStyles.None,
                out var fecha))
        {
            InicioMes = new DateTime(fecha.Year, fecha.Month, 1);
            FinMes = InicioMes.AddMonths(1).AddSeconds(-1);
        }
        else
        {
            // Sin período: usar mes actual
            var ahora = DateTime.Now;
            InicioMes = new DateTime(ahora.Year, ahora.Month, 1);
            FinMes = InicioMes.AddMonths(1).AddSeconds(-1);
        }
    }
    
    private async Task DescargarPDF()
    {
        var response = await Http.GetAsync($"api/dossier/{Letra}/pdf");
        if (response.IsSuccessStatusCode)
        {
            var bytes    = await response.Content.ReadAsByteArrayAsync();
            var base64   = Convert.ToBase64String(bytes);
            var fileName = $"Dossier_{Reporte.Titulo.Replace(" ", "_")}.pdf";
            await JS.InvokeVoidAsync("SSTUtil.descargarArchivo",fileName, base64, "application/pdf");
        }
    }
    

    private List<(string Label, string Valor)> CamposIdentificacion =>
        new()
        {
            ("Empresa",            EmpresaNombre),//"Constructora Piantini S.R.L."),
            ("RNC",               EmpresaRNC), //"1-31-12345-6"),
            ("Responsable SST",   $"{ResponsableSST} · Prevencionista"), //"Ramón Gómez · Prevencionista"),
            ("Base legal",        Reporte.BaseLegal),
            ("Período",           Reporte.Periodo),
            ("Fecha generación",  Reporte.FechaGeneracion.ToString("dd/MM/yyyy · hh:mm tt")),
        };

    // protected override void OnInitialized() =>
    //     Reporte = BuildReporte(Letra);

    // protected override void OnParametersSet() =>
    //     Reporte = BuildReporte(Letra);
    protected override async Task OnParametersSetAsync()
    {
        try
        {
            ParsearPeriodo();

            // Cargar empresa
            var empresa = await Http
                .GetFromJsonAsync<ConfiguracionEmpresaDto>(
                    "api/configuracion/empresa");
            EmpresaNombre = empresa?.RazonSocial ?? "—";
            EmpresaRNC = empresa?.RNC ?? "—";
            ResponsableSST = empresa?.ResponsableSST ?? "—";

            var resumen = await Http
                .GetFromJsonAsync<DossierResumenDto>(
                    "api/dossier");

            if (resumen is not null)
            {
                var dto = resumen.Reportes
                    .FirstOrDefault(r => r.Letra == Letra);

                if (dto is not null)
                {
                    // Cargar registros reales según el tipo
                    var registros = await CargarRegistrosReales(Letra);

                    Reporte = new ReporteDetalle
                    {
                        Titulo = dto.Titulo,
                        BaseLegal = dto.BaseLegal,
                        Periodo = dto.Periodo,
                        FechaGeneracion = DateTime.TryParse(
                            dto.FechaGeneracion, out var f) ? f : DateTime.Now,
                        HashSha256 = dto.HashSha256,
                        RegistrosIncluidos = registros, //BuildRegistros(Letra, dto),
                        ArticulosLegales = BuildArticulos(Letra),
                        Versiones = new()
                    {
                        new(DateTime.Today, ResponsableSST, true), //"R. Gómez"
                        new(DateTime.Today.AddYears(-1), ResponsableSST, false), //"R. Gómez"
                    }
                    };
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando reporte: {ex.Message}");
            Reporte = BuildReporte(Letra);
        }
    }

    private async Task<List<RegistroItem>> CargarRegistrosReales(string letra)
    {
        return letra switch
        {
            "A" => await CargarRegistrosA(),
            "B" => await CargarRegistrosB(),
            "C" => await CargarRegistrosC(),
            "D" => await CargarRegistrosD(),
            "E" => await CargarRegistrosE(),
            "F" => await CargarRegistrosF(),
            _ => new()
        };
    }

    private async Task<List<RegistroItem>> CargarRegistrosA()
    {
        var prog = await Http
            .GetFromJsonAsync<ProgramaSSTDto>(
                "api/configuracion/programa-sst");

        return new()
    {
        new("ti-shield-check", "#EAF3DE", "#3B6D11",
            "Política de Seguridad y Salud",
            string.IsNullOrEmpty(prog?.Politica)
                ? "Pendiente de configurar"
                : prog.Politica.Length > 80
                    ? prog.Politica[..80] + "..."
                    : prog.Politica),
        new("ti-alert-triangle", "#FAEEDA", "#854F0B",
            "Matriz de identificación de riesgos",
            string.IsNullOrEmpty(prog?.MatrizRiesgos)
                ? "Pendiente de configurar"
                : prog.MatrizRiesgos.Length > 80
                    ? prog.MatrizRiesgos[..80] + "..."
                    : prog.MatrizRiesgos),
        new("ti-flame", "#FCEBEB", "#A32D2D",
            "Plan de emergencias",
            string.IsNullOrEmpty(prog?.PlanEmergencia)
                ? "Pendiente de configurar"
                : prog.PlanEmergencia.Length > 80
                    ? prog.PlanEmergencia[..80] + "..."
                    : prog.PlanEmergencia),
        new("ti-calendar", "#E6F1FB", "#185FA5",
            "Vigencia del programa",
            prog?.Vigencia ?? "No configurada"),
    };
    }

    private async Task<List<RegistroItem>> CargarRegistrosB()
    {
        var incidentes = await Http
            .GetFromJsonAsync<List<IncidenteListDto>>(
                "api/incidentes") ?? new();

        var filtrados = incidentes
        .Where(x => x.Fecha >= InicioMes &&
                    x.Fecha <= FinMes)
        .OrderByDescending(x => x.Fecha)
        .Take(10)
        .ToList();

        var items = filtrados.Select(x => new RegistroItem(
        x.Tipo == "Accidente grave"
            ? "ti-first-aid-kit" : "ti-alert-triangle",
        x.Tipo == "Accidente grave"
            ? "#FCEBEB" : "#FAEEDA",
        x.Tipo == "Accidente grave"
            ? "#A32D2D" : "#854F0B",
        $"{x.Tipo} — {x.Area}",
        $"{x.Fecha:dd/MM/yyyy} · {x.Afectado} · {x.Estado}"))
        .ToList();

        // var items = incidentes
        //     .OrderByDescending(x => x.Fecha)
        //     .Take(5)
        //     .Select(x => new RegistroItem(
        //         x.Tipo == "Accidente grave"
        //             ? "ti-first-aid-kit" : "ti-alert-triangle",
        //         x.Tipo == "Accidente grave"
        //             ? "#FCEBEB" : "#FAEEDA",
        //         x.Tipo == "Accidente grave"
        //             ? "#A32D2D" : "#854F0B",
        //         $"{x.Tipo} — {x.Area}",
        //         $"{x.Fecha:dd/MM/yyyy} · {x.Afectado} · {x.Estado}"))
        //     .ToList();

        if (!items.Any())
            items.Add(new("ti-check", "#EAF3DE", "#3B6D11",
                "Sin incidentes registrados",
                $"No hay incidentes en {InicioMes:MMMM yyyy}"));

        return items;
    }

    private async Task<List<RegistroItem>> CargarRegistrosC()
    {
        var charlas = await Http
            .GetFromJsonAsync<List<CharlaListDto>>(
                "api/charlas") ?? new();

        var filtradas = charlas
        .Where(x => x.FechaCharla >= InicioMes &&
                    x.FechaCharla <= FinMes)
        .OrderByDescending(x => x.FechaCharla)
        .Take(10)
        .ToList();

        var items = filtradas.Select(x => new RegistroItem(
        "ti-users", "#FAEEDA", "#854F0B",
        $"Acta — {x.FechaCharla:dd/MM/yyyy}",
        $"{x.AsistentesPresentes}/{x.TotalAsistentes} asistentes · " +
        $"{x.Cuadrilla} · " +
        $"{(x.Firmado ? "Firmada" : "Pendiente")}"))
        .ToList();

        // var items = charlas
        //     .OrderByDescending(x => x.FechaCharla)
        //     .Take(5)
        //     .Select(x => new RegistroItem(
        //         "ti-users", "#FAEEDA", "#854F0B",
        //         $"Acta — {x.FechaCharla:dd/MM/yyyy}",
        //         $"{x.TotalAsistentes} asistentes · {x.Cuadrilla} · " +
        //         $"{(x.Firmado ? "Firmada" : "Pendiente")}"))
        //     .ToList();

        if (!items.Any())
            items.Add(new("ti-alert-circle", "#FAEEDA", "#854F0B",
                "Sin actas registradas",
                "No hay reuniones del comité en " +
            $"{InicioMes:MMMM yyyy}"));

        return items;
    }

    private async Task<List<RegistroItem>> CargarRegistrosD()
    {
        var charlas = await Http
            .GetFromJsonAsync<List<CharlaListDto>>(
                "api/charlas") ?? new();

        var filtradas = charlas
        .Where(x => x.FechaCharla >= InicioMes &&
                    x.FechaCharla <= FinMes)
        .OrderByDescending(x => x.FechaCharla)
