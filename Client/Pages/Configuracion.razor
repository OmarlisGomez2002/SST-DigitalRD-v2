@page "/configuracion"
@inject HttpClient Http
@inject SSTDigitalRD.Client.Services.PermisosService Permisos

<PageTitle>Configuración · SST-Digital RD</PageTitle>

@if (!_tieneAcceso)
{
    <AccesoRestringido />
    return;
}

<div class="cfg-layout">

    <!-- ══ Datos de la empresa ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-building" aria-hidden="true"></i>
                Datos de la empresa
            </span>
        </div>
        <div class="form-grid-2">
            <div class="form-field">
                <label>Razón social</label>
                <input type="text" @bind="Config.RazonSocial" />
            </div>
            <div class="form-field">
                <label>RNC</label>
                <input type="text" @bind="Config.RNC" />
            </div>
            <div class="form-field">
                <label>Sector / Actividad económica</label>
                <input type="text" @bind="Config.Sector" />
            </div>
            <div class="form-field">
                <label>Responsable SST</label>
                <input type="text" @bind="Config.ResponsableSST" />
            </div>
            <div class="form-field">
                <label>Teléfono de contacto</label>
                <input type="text" @bind="Config.Telefono" />
            </div>
            <div class="form-field">
                <label>Correo institucional</label>
                <input type="email" @bind="Config.Correo" />
            </div>
        </div>
        <div style="display:flex;justify-content:flex-end;margin-top:8px">
            <button class="btn-primary btn-sm" @onclick="GuardarEmpresa"
                    disabled="@GuardandoEmpresa">
                @if (GuardandoEmpresa)
                {
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                    <span>Guardando...</span>
                }
                else
                {
                    <i class="ti ti-device-floppy" aria-hidden="true"></i>
                    <span>Guardar cambios</span>
                }
            </button>
        </div>
    </div>

    <!-- ══ Obras registradas ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-map-pin" aria-hidden="true"></i>
                Obra activa
            </span>
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Nombre de la obra</label>
            <input type="text" @bind="Obra.Nombre" />
        </div>
        @* <div class="form-field" style="margin-bottom:12px">
            <label>Coordenadas GPS (lat, lng)</label>
            <input type="text" @bind="O.ObraCoordenadas"
                   placeholder="18.473621, -69.931215" />
        </div> *@         
        <div class="form-field" style="margin-bottom:12px">
            <label>Latitud</label>
            <input type="number" @bind="Obra.Latitud"
                   step="0.000001" placeholder="18.473621" />
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Longitud</label>
            <input type="number" @bind="Obra.Longitud"
                   step="0.000001" placeholder="-69.931215" />
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Radio de geofencing (metros)</label>
            <input type="number" @bind="Obra.RadioGeofencing"
                   min="50" max="500" />
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Dirección</label>
            <input type="text" @bind="Obra.Direccion" />
        </div>
        <div style="display:flex;justify-content:flex-end">
            <button class="btn-primary btn-sm" @onclick="GuardarObra"
                    disabled="@GuardandoObra">
                @if (GuardandoObra)
                {
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                }
                else
                {
                    <i class="ti ti-device-floppy" aria-hidden="true"></i>
                }
                Guardar obra
            </button>
            
        </div>
        <button class="btn-secondary"
                style="width:100%;justify-content:center;margin-top:8px"
                @onclick="AgregarObraActual">
            <i class="ti ti-plus" aria-hidden="true"></i>
            Guardar como nueva obra
        </button>
    </div>

    <!-- ══ Notificaciones ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-bell" aria-hidden="true"></i>
                Notificaciones
            </span>
        </div>
        <div style="display:flex;flex-direction:column">
            @foreach (var noti in Notificaciones)
            {
                var n = noti;
                <div class="cfg-noti-row">
                    <div style="flex:1">
                        <div style="font-size:13px;color:var(--text-primary)">
                            @n.Titulo
                        </div>
                        <div class="text-hint">@n.Descripcion</div>
                    </div>
                    <label class="toggle-asist">
                        <input type="checkbox"
                               checked="@n.Activa"
                               @onchange="() => n.Activa = !n.Activa" />
                        <span class="toggle-track">
                            <span class="toggle-thumb"></span>
                        </span>
                    </label>
                </div>
            }
        </div>
        <div style="display:flex;justify-content:flex-end;margin-top:10px">
            <button class="btn-primary btn-sm" @onclick="GuardarNotificaciones" disabled="@GuardandoNoti">
                @if (GuardandoNoti)
                {
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                }
                else
                {
                    <i class="ti ti-device-floppy" aria-hidden="true"></i>
                }
                Guardar preferencias
            </button>
        </div>
    </div>
        
    <!-- ══ Usuarios del sistema ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-users" aria-hidden="true"></i>
                Usuarios del sistema
            </span>
        </div>

        <div style="display:flex;flex-direction:column;
                gap:8px;margin-bottom:12px">
            @foreach (var user in Usuarios)
            {
                var u = user;
                var iniciales = string.Concat(
                u.Nombre.Split(' ').Take(2)
                .Select(p => p.Length > 0
                ? p[0].ToString() : ""))
                .ToUpper();
                var avatarBg = u.Rol == "Administrador"
                ? "#E6F1FB" : u.Rol == "Prevencionista"
                ? "#EAF3DE" : "#FAEEDA";
                var avatarColor = u.Rol == "Administrador"
                ? "#185FA5" : u.Rol == "Prevencionista"
                ? "#3B6D11" : "#854F0B";

                <div style="display:flex;align-items:center;gap:10px;
                            padding:8px 10px;
                            border:0.5px solid var(--border);
                            border-radius:var(--radius-md)">
                    <div class="mini-avatar"
                         style="background:@avatarBg;color:@avatarColor;
                                width:30px;height:30px;font-size:11px">
                        @iniciales
                    </div>
                    <div style="flex:1">
                        <div style="font-size:13px;font-weight:500;
                                    color:var(--text-primary)">
                            @u.Nombre
                        </div>
                        <div class="text-hint">
                            @u.Rol
                            @if (!string.IsNullOrEmpty(u.Cuadrilla))
                            {
                                <span> · @u.Cuadrilla</span>
                            }
                            · @u.Correo
                        </div>
                    </div>
                    <span class="pill @(u.Rol == "Administrador"
                                              ? "pill-info" : u.Rol == "Prevencionista"
                                              ? "pill-ok" : "pill-gray")">
                    @u.Rol
                </span>
                <button class="icon-action"
                        title="Editar usuario"
                        @onclick="() => AbrirEditarUsuario(u)">
                    <i class="ti ti-edit" aria-hidden="true"></i>
                </button>
                <button class="icon-action"
                        title="Cambiar contraseña"
                        @onclick="() => AbrirCambiarPassword(u)">
                    <i class="ti ti-key" aria-hidden="true"></i>
                </button>
            </div>
                        }
        </div>

        <button class="btn-primary"
                style="width:100%;justify-content:center"
                @onclick="AbrirNuevoUsuario">
            <i class="ti ti-user-plus" aria-hidden="true"></i>
            Agregar usuario
        </button>
    </div>

    <!-- ══ Modal: Crear / Editar usuario ══ -->
    @if (MostrarModalUsuario)
    {
        <div class="modal-backdrop" @onclick="CerrarModalUsuario">
            <div class="modal-card" @onclick:stopPropagation="true"
                 style="max-width:440px">
                <div class="modal-header">
                    <span style="font-weight:600;font-size:14px">
                        @(UsuarioEditando.Id == 0
                                            ? "Nuevo usuario" : "Editar usuario")
                </span>
                <button class="icon-action"
                        @onclick="CerrarModalUsuario">
                    <i class="ti ti-x" aria-hidden="true"></i>
                </button>
            </div>
            <div class="modal-body"
                 style="display:flex;flex-direction:column;gap:12px">

                    <div class="form-field">
                        <label>Nombre completo</label>
                        <input type="text"
                               @bind="UsuarioEditando.Nombre"
                               placeholder="Juan Pérez" />
                    </div>
                    <div class="form-field">
                        <label>Correo electrónico</label>
                        <input type="email"
                               @bind="UsuarioEditando.Correo"
                               placeholder="usuario@empresa.do" />
                    </div>
                    <div class="form-field">
                        <label>Rol</label>
                        <select @bind="UsuarioEditando.Rol">
                            <option value="Administrador">Administrador</option>
                            <option value="Prevencionista">Prevencionista</option>
                            <option value="Supervisor">Supervisor</option>
                        </select>
                    </div>
                    <div class="form-field">
                        <label>Cuadrilla (opcional)</label>
                        <select @bind="UsuarioEditando.Cuadrilla">
                            <option value="">Sin cuadrilla asignada</option>
                        @foreach (var c in Cuadrillas)
                            {
                                <option value="@c.Nombre">@c.Nombre</option>
                            }
                        </select>
                    </div>

                    @if (UsuarioEditando.Id == 0)
                    {
                        <div class="form-field">
                            <label>Contraseña inicial</label>
                            <input type="password"
                                   @bind="PasswordNuevo"
                                   placeholder="Mínimo 8 caracteres" />
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(ErrorModal))
                    {
                        <div class="alert-banner danger">
                            <i class="ti ti-alert-circle"
                               aria-hidden="true"></i>
                            @ErrorModal
                        </div>
                    }

                    <div style="display:flex;gap:8px;
                                justify-content:flex-end">
                        <button class="btn-secondary"
                                @onclick="CerrarModalUsuario">
                            Cancelar
                        </button>
                        <button class="btn-primary"
                                @onclick="GuardarUsuario"
                                disabled="@GuardandoUsuario">
                            @if (GuardandoUsuario)
                            {
                                <i class="ti ti-loader-2 spin"
                                   aria-hidden="true"></i>
                            }
                            else
                            {
                                <i class="ti ti-device-floppy"
                                   aria-hidden="true"></i>
                            }
                        @(UsuarioEditando.Id == 0
                                                ? "Crear usuario" : "Guardar cambios")
                    </button>
                </div>
            </div>
        </div>
    </div>
        }

    <!-- ══ Modal: Cambiar contraseña ══ -->
    @if (MostrarModalPassword)
    {
        <div class="modal-backdrop" @onclick="CerrarModalPassword">
            <div class="modal-card" @onclick:stopPropagation="true"
                 style="max-width:380px">
                <div class="modal-header">
                    <span style="font-weight:600;font-size:14px">
                        Cambiar contraseña
                    </span>
                    <button class="icon-action"
                            @onclick="CerrarModalPassword">
                        <i class="ti ti-x" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="modal-body"
                     style="display:flex;flex-direction:column;gap:12px">

                    <div style="font-size:13px;color:var(--text-sec)">
                        Cambiando contraseña de
                        <strong>@UsuarioPassword?.Nombre</strong>
                    </div>

                    <div class="form-field">
                        <label>Nueva contraseña</label>
                        <input type="password"
                               @bind="PasswordNuevo"
                               placeholder="Mínimo 8 caracteres" />
                    </div>
                    <div class="form-field">
                        <label>Confirmar contraseña</label>
                        <input type="password"
                               @bind="PasswordConfirmar"
                               placeholder="Repetir contraseña" />
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorModal))
                    {
                        <div class="alert-banner danger">
                            <i class="ti ti-alert-circle"
                               aria-hidden="true"></i>
                            @ErrorModal
                        </div>
                    }
                    @if (PasswordCambiado)
                    {
                        <div class="alert-banner ok">
                            <i class="ti ti-check"
                               aria-hidden="true"></i>
                            Contraseña actualizada correctamente.
                        </div>
                    }

                    <div style="display:flex;gap:8px;
                                justify-content:flex-end">
                        <button class="btn-secondary"
                                @onclick="CerrarModalPassword">
                            Cerrar
                        </button>
                        <button class="btn-primary"
                                @onclick="GuardarPassword"
                                disabled="@GuardandoUsuario">
                            @if (GuardandoUsuario)
                            {
                                <i class="ti ti-loader-2 spin"
                                   aria-hidden="true"></i>
                            }
                            else
                            {
                                <i class="ti ti-key"
                                   aria-hidden="true"></i>
                            }
                            Cambiar contraseña
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
