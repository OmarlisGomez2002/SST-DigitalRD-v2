@page "/configuracion"
@inject HttpClient Http
@inject SSTDigitalRD.Client.Services.PermisosService Permisos

<PageTitle>Configuración · SST-Digital RD</PageTitle>

@if (!_tieneAcceso)
{
    <AccesoRestringido />
    return;
}

<div class="cfg-layout">

    <!-- ══ Datos de la empresa ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-building" aria-hidden="true"></i>
                Datos de la empresa
            </span>
        </div>
        <div class="form-grid-2">
            <div class="form-field">
                <label>Razón social</label>
                <input type="text" @bind="Config.RazonSocial" />
            </div>
            <div class="form-field">
                <label>RNC</label>
                <input type="text" @bind="Config.RNC" />
            </div>
            <div class="form-field">
                <label>Sector / Actividad económica</label>
                <input type="text" @bind="Config.Sector" />
            </div>
            <div class="form-field">
                <label>Responsable SST</label>
                <input type="text" @bind="Config.ResponsableSST" />
            </div>
            <div class="form-field">
                <label>Teléfono de contacto</label>
                <input type="text" @bind="Config.Telefono" />
            </div>
            <div class="form-field">
                <label>Correo institucional</label>
                <input type="email" @bind="Config.Correo" />
            </div>
        </div>
        <div style="display:flex;justify-content:flex-end;margin-top:8px">
            <button class="btn-primary btn-sm" @onclick="GuardarEmpresa"
                    disabled="@GuardandoEmpresa">
                @if (GuardandoEmpresa)
                {
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                    <span>Guardando...</span>
                }
                else
                {
                    <i class="ti ti-device-floppy" aria-hidden="true"></i>
                    <span>Guardar cambios</span>
                }
            </button>
        </div>
    </div>

    <!-- ══ Obras registradas ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-map-pin" aria-hidden="true"></i>
                Obra activa
            </span>
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Nombre de la obra</label>
            <input type="text" @bind="Obra.Nombre" />
        </div>
        @* <div class="form-field" style="margin-bottom:12px">
            <label>Coordenadas GPS (lat, lng)</label>
            <input type="text" @bind="O.ObraCoordenadas"
                   placeholder="18.473621, -69.931215" />
        </div> *@         
        <div class="form-field" style="margin-bottom:12px">
            <label>Latitud</label>
            <input type="number" @bind="Obra.Latitud"
                   step="0.000001" placeholder="18.473621" />
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Longitud</label>
            <input type="number" @bind="Obra.Longitud"
                   step="0.000001" placeholder="-69.931215" />
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Radio de geofencing (metros)</label>
            <input type="number" @bind="Obra.RadioGeofencing"
                   min="50" max="500" />
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Dirección</label>
            <input type="text" @bind="Obra.Direccion" />
        </div>
        <div style="display:flex;justify-content:flex-end">
            <button class="btn-primary btn-sm" @onclick="GuardarObra"
                    disabled="@GuardandoObra">
                @if (GuardandoObra)
                {
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                }
                else
                {
                    <i class="ti ti-device-floppy" aria-hidden="true"></i>
                }
                Guardar obra
            </button>
            
        </div>
        <button class="btn-secondary"
                style="width:100%;justify-content:center;margin-top:8px"
                @onclick="AgregarObraActual">
            <i class="ti ti-plus" aria-hidden="true"></i>
            Guardar como nueva obra
        </button>
    </div>

    <!-- ══ Notificaciones ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-bell" aria-hidden="true"></i>
                Notificaciones
            </span>
        </div>
        <div style="display:flex;flex-direction:column">
            @foreach (var noti in Notificaciones)
            {
                var n = noti;
                <div class="cfg-noti-row">
                    <div style="flex:1">
                        <div style="font-size:13px;color:var(--text-primary)">
                            @n.Titulo
                        </div>
                        <div class="text-hint">@n.Descripcion</div>
                    </div>
                    <label class="toggle-asist">
                        <input type="checkbox"
                               checked="@n.Activa"
                               @onchange="() => n.Activa = !n.Activa" />
                        <span class="toggle-track">
                            <span class="toggle-thumb"></span>
                        </span>
                    </label>
                </div>
            }
        </div>
        <div style="display:flex;justify-content:flex-end;margin-top:10px">
            <button class="btn-primary btn-sm" @onclick="GuardarNotificaciones" disabled="@GuardandoNoti">
                @if (GuardandoNoti)
                {
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                }
                else
                {
                    <i class="ti ti-device-floppy" aria-hidden="true"></i>
                }
                Guardar preferencias
            </button>
        </div>
    </div>

    <!-- ══ Usuarios del sistema ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-users" aria-hidden="true"></i>
                Usuarios del sistema
            </span>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:12px">
            @foreach (var user in Usuarios)
            {
                var iniciales = string.Concat(
                user.Nombre.Split(' ')
                .Take(2)
                .Select(p => p.Length > 0
                ? p[0].ToString() : ""))
                .ToUpper();

                var avatarBg = user.Rol == "Admin" ? "#E6F1FB" : "#FAEEDA";
                var avatarColor = user.Rol == "Admin" ? "#185FA5" : "#854F0B";

                <div style="display:flex;align-items:center;gap:10px;
                            padding:8px 10px;border:0.5px solid var(--border);
                            border-radius:var(--radius-md)">
                    <div class="mini-avatar"
                         style="background:@avatarBg;color:@avatarColor;
                                width:30px;height:30px;font-size:11px">
                        @iniciales
                    </div>
                    <div style="flex:1">
                        <div style="font-size:13px;font-weight:500;
                                    color:var(--text-primary)">
                            @user.Nombre
                        </div>
                        <div class="text-hint">
                            @user.Rol · @user.Cuadrilla
                        </div>
                    </div>
                    <span class="pill @(user.Rol == "Admin" ? "pill-info" : "pill-gray")">
                        @user.Rol
                    </span>
                    <button class="icon-action">
                        <i class="ti ti-edit" aria-hidden="true"></i>
                    </button>
                </div>
            }
            @* @foreach (var user in Usuarios)
            {
                <div style="display:flex;align-items:center;gap:10px;
                                padding:8px 10px;border:0.5px solid var(--border);
                                border-radius:var(--radius-md)">
                    <div class="mini-avatar"
                         style="background:@user.AvatarBg;color:@user.AvatarColor;
                                    width:30px;height:30px;font-size:11px">
                        @user.Iniciales
                    </div>
                    <div style="flex:1">
                        <div style="font-size:13px;font-weight:500;
                                        color:var(--text-primary)">
                            @user.Nombre
                        </div>
                        <div class="text-hint">@user.Rol · @user.Cuadrilla</div>
                    </div>
                    <span class="pill @(user.Rol == "Admin" ? "pill-info" : "pill-gray")">
                        @user.Rol
                    </span>
                    <button class="icon-action">
                        <i class="ti ti-edit" aria-hidden="true"></i>
                    </button>
                </div>
            } *@
        </div>
        <button class="btn-primary"
                style="width:100%;justify-content:center">
            <i class="ti ti-user-plus" aria-hidden="true"></i>
            Agregar usuario
        </button>
    </div>

    <!-- ══ Tipos de inspección ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-clipboard-list" aria-hidden="true"></i>
                Tipos de inspección
            </span>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px">
            @foreach (var tipo in TiposInspeccion)
            {
                <div style="display:flex;align-items:center;gap:10px;
                            padding:8px 10px;border:0.5px solid var(--border);
                            border-radius:var(--radius-md)">
                    <span style="flex:1;font-size:13px;color:var(--text-primary)">
                        @tipo.Nombre
                    </span>
                    <button class="icon-action"
                            @onclick="() => EliminarTipoInspeccion(tipo.Id)">
                        <i class="ti ti-trash" aria-hidden="true"></i>
                    </button>
                </div>
            }
        </div>
        <div style="display:flex;gap:8px">
            <input type="text"
                   @bind="NuevoTipoInspeccion"
                   placeholder="Nuevo tipo de inspección..."
                   style="flex:1" />
            <button class="btn-primary btn-sm" @onclick="AgregarTipoInspeccion">
                <i class="ti ti-plus" aria-hidden="true"></i>
                Agregar
            </button>
        </div>
    </div>

    <!-- ══ Cuadrillas ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-users-group" aria-hidden="true"></i>
                Cuadrillas
            </span>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px">
            @foreach (var c in Cuadrillas)
            {
                <div style="display:flex;align-items:center;gap:10px;
                            padding:8px 10px;border:0.5px solid var(--border);
                            border-radius:var(--radius-md)">
                    <span style="flex:1;font-size:13px;color:var(--text-primary)">
                        @c.Nombre
                    </span>
                    <button class="icon-action"
                            @onclick="() => EliminarCuadrilla(c.Id)">
                        <i class="ti ti-trash" aria-hidden="true"></i>
                    </button>
                </div>
            }
        </div>
        <div style="display:flex;gap:8px">
            <input type="text"
                   @bind="NuevaCuadrilla"
                   placeholder="Nueva cuadrilla..."
                   style="flex:1" />
            <button class="btn-primary btn-sm" @onclick="AgregarCuadrilla">
                <i class="ti ti-plus" aria-hidden="true"></i>
                Agregar
            </button>
        </div>
    </div>

    <!-- ══ Tipos de charla ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-speakerphone" aria-hidden="true"></i>
                Tipos de charla
            </span>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px">
            @foreach (var tipo in TiposCharla)
            {
                <div style="display:flex;align-items:center;gap:10px;
                            padding:8px 10px;border:0.5px solid var(--border);
                            border-radius:var(--radius-md)">
                    <span style="flex:1;font-size:13px;color:var(--text-primary)">
                        @tipo.Nombre
                    </span>
                    <button class="icon-action"
                            @onclick="() => EliminarTipoCharla(tipo.Id)">
                        <i class="ti ti-trash" aria-hidden="true"></i>
                    </button>
                </div>
            }
        </div>
        <div style="display:flex;gap:8px">
            <input type="text"
                   @bind="NuevoTipoCharla"
                   placeholder="Nuevo tipo de charla..."
                   style="flex:1" />
            <button class="btn-primary btn-sm" @onclick="AgregarTipoCharla">
                <i class="ti ti-plus" aria-hidden="true"></i>
                Agregar
            </button>
        </div>
    </div>

    <!-- ══ Cargos de empleados ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-briefcase" aria-hidden="true"></i>
                Cargos de empleados
            </span>
        </div>
        <div style="display:flex;flex-direction:column;
                gap:6px;margin-bottom:12px">
            @foreach (var cargo in Cargos)
            {
                <div style="display:flex;align-items:center;gap:10px;
                            padding:8px 10px;border:0.5px solid var(--border);
                            border-radius:var(--radius-md)">
                    <span style="flex:1;font-size:13px;
                                 color:var(--text-primary)">
                        @cargo.Nombre
                    </span>
                    <button class="icon-action"
                            @onclick="() => EliminarCargo(cargo.Id)">
                        <i class="ti ti-trash" aria-hidden="true"></i>
                    </button>
                </div>
            }
        </div>
        <div style="display:flex;gap:8px">
            <input type="text"
                   @bind="NuevoCargo"
                   placeholder="Nuevo cargo..."
                   style="flex:1" />
            <button class="btn-primary btn-sm"
                    @onclick="AgregarCargo">
                <i class="ti ti-plus" aria-hidden="true"></i>
                Agregar
            </button>
        </div>
    </div>


    <!-- ══ Items de checklist ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-checklist" aria-hidden="true"></i>
                Lista de verificación
            </span>
        </div>

        @foreach (var grupo in ItemsChecklist.GroupBy(x => x.Categoria))
        {
            <div style="font-size:10px;font-weight:600;color:var(--text-hint);
                        text-transform:uppercase;letter-spacing:.06em;
                        padding:8px 0 4px;border-bottom:0.5px solid var(--border);
                        margin-bottom:4px">
                @grupo.Key
            </div>
            @foreach (var item in grupo)
            {
                var it = item;
                <div style="display:flex;align-items:center;gap:10px;
                                padding:7px 4px;border-bottom:0.5px solid var(--border)">
                    <span style="flex:1;font-size:12px;
                                     color:@(it.Activo ? "var(--text-primary)" : "var(--text-hint)")">
                        @it.Descripcion
                    </span>
                    <span class="pill @(it.Activo ? "pill-ok" : "pill-gray")"
                          style="cursor:pointer"
                          @onclick="() => ToggleItemChecklist(it)">
                        @(it.Activo ? "Vigente" : "Inactivo")
                    </span>
                    <button class="icon-action"
                            @onclick="() => EliminarItemChecklist(it.Id)">
                        <i class="ti ti-trash" aria-hidden="true"></i>
                    </button>
                </div>
            }
        }

        <div style="display:flex;flex-direction:column;gap:8px;margin-top:12px">
            <div style="display:flex;gap:8px">
                <input type="text" @bind="NuevoItemCategoria" placeholder="Categoría (ej. EPP)" style="flex:0 0 160px" />
                <input type="text" @bind="NuevoItemDescripcion" placeholder="Descripción del item..." style="flex:1" />
                <button class="btn-primary btn-sm" @onclick="AgregarItemChecklist">
                    <i class="ti ti-plus" aria-hidden="true"></i>
                    Agregar
                </button>
            </div>
        </div>
    </div>

    <!-- ══ Tipos de EPP ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-hardhat" aria-hidden="true"></i>
                Tipos de EPP
            </span>
        </div>

        @foreach (var grupo in TiposEPP.GroupBy(x => x.Categoria))
        {
            <div style="font-size:10px;font-weight:600;
                        color:var(--text-hint);
                        text-transform:uppercase;
                        letter-spacing:.06em;
                        padding:8px 0 4px;
                        border-bottom:0.5px solid var(--border);
                        margin-bottom:4px">
                @grupo.Key
            </div>
            @foreach (var tipo in grupo)
            {
                var t = tipo;
                <div style="display:flex;align-items:center;gap:10px;
                                padding:7px 4px;
                                border-bottom:0.5px solid var(--border)">
                    <i class="ti @t.Icono"
                       style="font-size:16px;color:var(--text-sec);
                                  width:20px;text-align:center"
                       aria-hidden="true"></i>
                    <span style="flex:1;font-size:12px;
                                     color:@(t.Activo
                                                           ? "var(--text-primary)"
                                                           : "var(--text-hint)")">
                @t.Nombre
            </span>
            <span class="pill @(t.Activo ? "pill-ok" : "pill-gray")"
                  style="cursor:pointer"
                  @onclick="() => ToggleTipoEPP(t)">
                @(t.Activo ? "Activo" : "Inactivo")
            </span>
            <button class="icon-action"
                    @onclick="() => EliminarTipoEPP(t.Id)">
                <i class="ti ti-trash" aria-hidden="true"></i>
            </button>
        </div>
                }
        }

        <div style="display:flex;flex-direction:column;
                gap:8px;margin-top:12px">
            <div style="display:flex;gap:8px">
                <input type="text"
                       @bind="NuevoEPPCategoria"
                       placeholder="Categoría (ej. Protección craneal)"
                       style="flex:0 0 200px" />
                <input type="text"
                       @bind="NuevoEPPNombre"
                       placeholder="Nombre del EPP..."
                       style="flex:1" />
                <button class="btn-primary btn-sm"
                        @onclick="AgregarTipoEPP">
                    <i class="ti ti-plus" aria-hidden="true"></i>
                    Agregar
                </button>
            </div>
        </div>
    </div>

</div>

@code {
    private bool GuardandoEmpresa = false;
    private bool GuardandoObra = false;
    private bool GuardandoNoti = false;

    private List<ItemChecklistDto> ItemsChecklist = new();
    private string NuevoItemCategoria = "";
    private string NuevoItemDescripcion = "";



    private ConfiguracionEmpresaDto Config = new();
    private ObraActivaDto Obra = new();
    private List<NotificacionConfigDto> Notificaciones = new();
    private List<UsuarioSistemaDto> Usuarios = new();

    private List<TipoInspeccionDto> TiposInspeccion = new();
    private string NuevoTipoInspeccion = "";

    private List<CuadrillaDto> Cuadrillas = new();
    private string NuevaCuadrilla = "";

    private List<TipoCharlaDto> TiposCharla = new();
    private string NuevoTipoCharla = "";

    private List<CargoEmpleadoDto> Cargos = new();
    private string NuevoCargo = "";

    private bool _tieneAcceso = true;

    private List<TipoEPPDto> TiposEPP = new();
    private string NuevoEPPNombre = "";
    private string NuevoEPPCategoria = "";
    private string NuevoEPPIcono = "ti-hardhat";

    protected override async Task OnInitializedAsync()
    {
        _tieneAcceso = await Permisos.TieneAcceso("Configuracion");
        if (!_tieneAcceso) return;

        try
        {
            Config = await Http
                .GetFromJsonAsync<ConfiguracionEmpresaDto>(
                    "api/configuracion/empresa")
                ?? new();

            Obra = await Http
                .GetFromJsonAsync<ObraActivaDto>(
                    "api/configuracion/obra")
                ?? new();

            Notificaciones = await Http
                .GetFromJsonAsync<List<NotificacionConfigDto>>(
                    "api/configuracion/notificaciones")
                ?? new();

            Usuarios = (await Http
                .GetFromJsonAsync<List<UsuarioSistemaDto>>(
                    "api/configuracion/usuarios")
                ?? new())
                .Select(u =>
                {
                    u.Iniciales = string.Concat(
                        u.Nombre.Split(' ')
                         .Take(2)
                         .Select(p => p.Length > 0 ? p[0].ToString() : ""))
                         .ToUpper();
                    u.AvatarBg = u.Rol == "Admin" ? "#E6F1FB" : "#FAEEDA";
                    u.AvatarColor = u.Rol == "Admin" ? "#185FA5" : "#854F0B";
                    return u;
                }).ToList();

            ItemsChecklist = await Http
    .GetFromJsonAsync<List<ItemChecklistDto>>(
        "api/configuracion/checklist") ?? new();

            TiposInspeccion = await Http.GetFromJsonAsync<List<TipoInspeccionDto>>("api/configuracion/tipos-inspeccion") ?? new();

            Cuadrillas = await Http.GetFromJsonAsync<List<CuadrillaDto>>("api/configuracion/cuadrillas") ?? new();

            TiposCharla = await Http.GetFromJsonAsync<List<TipoCharlaDto>>("api/configuracion/tipos-charla") ?? new();

            Cargos = await Http.GetFromJsonAsync<List<CargoEmpleadoDto>>("api/configuracion/cargos") ?? new();

            TiposEPP = await Http
    .GetFromJsonAsync<List<TipoEPPDto>>(
        "api/configuracion/tipos-epp") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando configuración: {ex.Message}");
        }
    }

    private async Task AgregarCargo()
    {
        if (string.IsNullOrWhiteSpace(NuevoCargo)) return;

        var dto = new CargoEmpleadoDto { Nombre = NuevoCargo };
        var response = await Http.PostAsJsonAsync(
            "api/configuracion/cargos", dto);

        if (response.IsSuccessStatusCode)
        {
            var creado = await response.Content
                .ReadFromJsonAsync<CargoEmpleadoDto>();
            if (creado is not null)
                Cargos.Add(creado);
            NuevoCargo = "";
        }
    }

    private async Task EliminarCargo(int id)
    {
        var response = await Http.DeleteAsync(
            $"api/configuracion/cargos/{id}");

        if (response.IsSuccessStatusCode)
            Cargos.RemoveAll(x => x.Id == id);
    }

    private async Task GuardarEmpresa()
    {
        GuardandoEmpresa = true;
        StateHasChanged();
        await Http.PutAsJsonAsync("api/configuracion/empresa", Config);
        GuardandoEmpresa = false;
        StateHasChanged();
    }

    private async Task GuardarObra()
    {
        GuardandoObra = true;
        StateHasChanged();

        // Parsear coordenadas si vienen como string
        var partes = Obra.Direccion.Split(',');
        if (partes.Length == 2)
        {
            if (double.TryParse(partes[0].Trim(),
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture,
                out double lat))
                Obra.Latitud = lat;

            if (double.TryParse(partes[1].Trim(),
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture,
                out double lng))
                Obra.Longitud = lng;
        }

        await Http.PutAsJsonAsync("api/configuracion/obra", Obra);
        GuardandoObra = false;
        StateHasChanged();
    }

    private async Task GuardarNotificaciones()
    {
        GuardandoNoti = true;
        StateHasChanged();
        await Http.PutAsJsonAsync(
            "api/configuracion/notificaciones", Notificaciones);
        GuardandoNoti = false;
        StateHasChanged();
    }

    private async Task AgregarObraActual()
    {
        await Http.PostAsJsonAsync("api/configuracion/obras", Obra);
    }

    private async Task AgregarTipoInspeccion()
    {
        if (string.IsNullOrWhiteSpace(NuevoTipoInspeccion)) return;

        var dto = new TipoInspeccionDto { Nombre = NuevoTipoInspeccion };
        var response = await Http.PostAsJsonAsync(
