            <span class="card-title">
                <i class="ti ti-hardhat" aria-hidden="true"></i>
                Tipos de EPP
            </span>
        </div>

        @foreach (var grupo in TiposEPP.GroupBy(x => x.Categoria))
        {
            <div style="font-size:10px;font-weight:600;
                        color:var(--text-hint);
                        text-transform:uppercase;
                        letter-spacing:.06em;
                        padding:8px 0 4px;
                        border-bottom:0.5px solid var(--border);
                        margin-bottom:4px">
                @grupo.Key
            </div>
            @foreach (var tipo in grupo)
            {
                var t = tipo;
                <div style="display:flex;align-items:center;gap:10px;
                                padding:7px 4px;
                                border-bottom:0.5px solid var(--border)">
                    <i class="ti @t.Icono"
                       style="font-size:16px;color:var(--text-sec);
                                  width:20px;text-align:center"
                       aria-hidden="true"></i>
                    <span style="flex:1;font-size:12px;
                                     color:@(t.Activo
                                                           ? "var(--text-primary)"
                                                           : "var(--text-hint)")">
                @t.Nombre
            </span>
            <span class="pill @(t.Activo ? "pill-ok" : "pill-gray")"
                  style="cursor:pointer"
                  @onclick="() => ToggleTipoEPP(t)">
                @(t.Activo ? "Activo" : "Inactivo")
            </span>
            <button class="icon-action"
                    @onclick="() => EliminarTipoEPP(t.Id)">
                <i class="ti ti-trash" aria-hidden="true"></i>
            </button>
        </div>
                }
        }

        <div style="display:flex;flex-direction:column;
                gap:8px;margin-top:12px">
            <div style="display:flex;gap:8px">
                <input type="text"
                       @bind="NuevoEPPCategoria"
                       placeholder="Categoría (ej. Protección craneal)"
                       style="flex:0 0 200px" />
                <input type="text"
                       @bind="NuevoEPPNombre"
                       placeholder="Nombre del EPP..."
                       style="flex:1" />
                <button class="btn-primary btn-sm"
                        @onclick="AgregarTipoEPP">
                    <i class="ti ti-plus" aria-hidden="true"></i>
                    Agregar
                </button>
            </div>
        </div>
    </div>

    <!-- ══ Programa SST (Reporte A) ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-file-certificate" aria-hidden="true"></i>
                Programa de SST — Reporte A
            </span>
            <span class="pill pill-info" style="margin-left:auto">
                Reg. 522-06 · Art. 8
            </span>
        </div>

        <div class="form-field" style="margin-bottom:12px">
            <label>Vigencia del programa</label>
            <input type="text"
                   @bind="ProgramaSST.Vigencia"
                   placeholder="Ej. 2025 — 2027" />
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Política de SST</label>
            <textarea @bind="ProgramaSST.Politica"
                      rows="3"
                      placeholder="Describa la política de seguridad...">
        </textarea>
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Matriz de riesgos</label>
            <textarea @bind="ProgramaSST.MatrizRiesgos"
                      rows="3"
                      placeholder="Descripción de la matriz de riesgos...">
        </textarea>
        </div>
        <div class="form-field" style="margin-bottom:12px">
            <label>Plan de emergencias</label>
            <textarea @bind="ProgramaSST.PlanEmergencia"
                      rows="3"
                      placeholder="Descripción del plan de evacuación...">
        </textarea>
        </div>

        @if (!string.IsNullOrEmpty(ProgramaSST.FechaAprobacion))
        {
            <div style="font-size:11px;color:var(--text-hint);
                        margin-bottom:8px">
                Última actualización: @ProgramaSST.FechaAprobacion
            </div>
        }

        <div style="display:flex;justify-content:flex-end">
            <button class="btn-primary btn-sm"
                    @onclick="GuardarProgramaSST"
                    disabled="@GuardandoPrograma">
                @if (GuardandoPrograma)
                {
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                }
                else
                {
                    <i class="ti ti-device-floppy" aria-hidden="true"></i>
                }
                Guardar programa
            </button>
        </div>
    </div>

</div>

