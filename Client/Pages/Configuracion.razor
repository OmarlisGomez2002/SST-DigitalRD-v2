    private void AbrirEditarUsuario(UsuarioSistemaDto u)
    {
        UsuarioEditando = new UsuarioSistemaDto
        {
            Id = u.Id,
            Nombre = u.Nombre,
            Correo = u.Correo,
            Rol = u.Rol,
            Cuadrilla = u.Cuadrilla,
            Activo = u.Activo
        };
        ErrorModal = "";
        MostrarModalUsuario = true;
    }

    private void AbrirCambiarPassword(UsuarioSistemaDto u)
    {
        UsuarioPassword = u;
        PasswordNuevo = "";
        PasswordConfirmar = "";
        ErrorModal = "";
        PasswordCambiado = false;
        MostrarModalPassword = true;
    }

    private void CerrarModalUsuario()
    {
        MostrarModalUsuario = false;
        ErrorModal = "";
    }

    private void CerrarModalPassword()
    {
        MostrarModalPassword = false;
        ErrorModal = "";
        PasswordCambiado = false;
    }

    private async Task GuardarUsuario()
    {
        ErrorModal = "";

        if (string.IsNullOrWhiteSpace(UsuarioEditando.Nombre) ||
            string.IsNullOrWhiteSpace(UsuarioEditando.Correo))
        {
            ErrorModal = "Nombre y correo son requeridos.";
            return;
        }

        if (UsuarioEditando.Id == 0 &&
            string.IsNullOrWhiteSpace(PasswordNuevo))
        {
            ErrorModal = "La contraseña inicial es requerida.";
            return;
        }

        GuardandoUsuario = true;
        StateHasChanged();

        try
        {
            if (UsuarioEditando.Id == 0)
            {
                // Crear nuevo usuario
                var dto = new CrearUsuarioConPasswordDto
                {
                    Nombre = UsuarioEditando.Nombre,
                    Correo = UsuarioEditando.Correo,
                    Rol = UsuarioEditando.Rol,
                    Cuadrilla = UsuarioEditando.Cuadrilla,
                    Password = PasswordNuevo
                };

                var response = await Http.PostAsJsonAsync(
                    "api/auth/crear-usuario", dto);

                if (response.IsSuccessStatusCode)
                {
                    var creado = await response.Content
                        .ReadFromJsonAsync<UsuarioSistemaDto>();
                    if (creado is not null)
                        Usuarios.Add(creado);
                    CerrarModalUsuario();
                }
                else
                {
                    var error = await response.Content
                        .ReadFromJsonAsync<ErrorResponseDto>();
                    ErrorModal = error?.Error
                        ?? "Error al crear el usuario.";
                }
            }
            else
            {
                // Editar usuario existente
                var dto = new EditarUsuarioDto
                {
                    Nombre = UsuarioEditando.Nombre,
                    Correo = UsuarioEditando.Correo,
                    Rol = UsuarioEditando.Rol,
                    Cuadrilla = UsuarioEditando.Cuadrilla,
                    Activo = UsuarioEditando.Activo
                };

                var response = await Http.PutAsJsonAsync(
                    $"api/auth/usuarios/{UsuarioEditando.Id}", dto);

                if (response.IsSuccessStatusCode)
                {
                    var idx = Usuarios.FindIndex(
                        x => x.Id == UsuarioEditando.Id);
                    if (idx >= 0)
                    {
                        Usuarios[idx].Nombre = dto.Nombre;
                        Usuarios[idx].Correo = dto.Correo;
                        Usuarios[idx].Rol = dto.Rol;
                        Usuarios[idx].Cuadrilla = dto.Cuadrilla;
                    }
                    CerrarModalUsuario();
                }
                else
                {
                    var error = await response.Content
                        .ReadFromJsonAsync<ErrorResponseDto>();
                    ErrorModal = error?.Error
                        ?? "Error al actualizar el usuario.";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorModal = $"Error: {ex.Message}";
        }
        finally
        {
            GuardandoUsuario = false;
            StateHasChanged();
        }
    }

    private async Task GuardarPassword()
    {
        ErrorModal = "";

        if (string.IsNullOrWhiteSpace(PasswordNuevo))
        {
            ErrorModal = "La contraseña no puede estar vacía.";
            return;
        }

        if (PasswordNuevo.Length < 8)
        {
            ErrorModal = "La contraseña debe tener al menos 8 caracteres.";
            return;
        }

        if (PasswordNuevo != PasswordConfirmar)
        {
            ErrorModal = "Las contraseñas no coinciden.";
            return;
        }

        GuardandoUsuario = true;
        StateHasChanged();

        try
        {
            var dto = new CambiarPasswordAdminDto
            { PasswordNuevo = PasswordNuevo };
            var response = await Http.PutAsJsonAsync(
                $"api/auth/usuarios/{UsuarioPassword!.Id}/reset-password",
                dto);

            if (response.IsSuccessStatusCode)
            {
                PasswordCambiado = true;
                PasswordNuevo = "";
                PasswordConfirmar = "";
            }
            else
            {
                ErrorModal = "Error al cambiar la contraseña.";
            }
        }
        catch (Exception ex)
        {
            ErrorModal = $"Error: {ex.Message}";
        }
        finally
        {
            GuardandoUsuario = false;
            StateHasChanged();
        }
    }

    private class ErrorResponseDto
    {
        public string Error { get; set; } = "";
    }

    private class CrearUsuarioConPasswordDto
    {
        public string Nombre { get; set; } = "";
        public string Correo { get; set; } = "";
        public string Rol { get; set; } = "";
        public string Cuadrilla { get; set; } = "";
        public string Password { get; set; } = "";
    }

    private async Task GuardarProgramaSST()
    {
        GuardandoPrograma = true;
        StateHasChanged();
        await Http.PutAsJsonAsync(
            "api/configuracion/programa-sst", ProgramaSST);
        GuardandoPrograma = false;
        StateHasChanged();
    }
}

