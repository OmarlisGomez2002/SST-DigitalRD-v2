@page "/charlas/nueva"
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http

<PageTitle>Nueva charla · SST-Digital RD</PageTitle>

<!-- ===== ENCABEZADO ===== -->
<div class="form-page-header">
    <button class="btn-back" @onclick="Cancelar">
        <i class="ti ti-arrow-left" aria-hidden="true"></i>
        Volver a charlas
    </button>
    <div class="form-page-title">
        <h1>Nueva charla SST</h1>
        <span class="form-page-sub">Complete los datos, registre la asistencia y firme al finalizar</span>
    </div>
    <div class="form-page-actions">
        <button class="btn-secondary" @onclick="GuardarBorrador" disabled="@Guardando">
            <i class="ti ti-device-floppy" aria-hidden="true"></i>
            Guardar borrador
        </button>
        <button class="btn-primary" @onclick="EnviarFormulario"
                disabled="@(!FormularioValido || Guardando)">
            @if (Guardando)
            {
                <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                <span>Guardando...</span>
            }
            else
            {
                <i class="ti ti-send" aria-hidden="true"></i>
                <span>Registrar charla</span>
            }
        </button>
    </div>
</div>

<!-- ===== PROGRESO ===== -->
<div class="form-progress">
    @foreach (var (paso, idx) in Pasos.Select((p, i) => (p, i + 1)))
    {
        <div class="progress-step @(PasoActual == idx ? "active" : "") @(PasoActual > idx ? "done" : "")">
            <div class="step-circle">
                @if (PasoActual > idx)
                {
                    <i class="ti ti-check" aria-hidden="true"></i>
                }
                else
                {

                    @idx
                }
            </div>
            <span class="step-label">@paso</span>
        </div>
        @if (idx < Pasos.Count)
        {
            <div class="step-line @(PasoActual > idx ? "done" : "")"></div>
        }
    }
</div>

<div class="form-body">

    <!-- ══════════════════════════════
         PASO 1 — Datos generales
    ══════════════════════════════ -->
    @if (PasoActual == 1)
    {
        <div class="form-card">
            <div class="form-card-header">
                <i class="ti ti-speakerphone" aria-hidden="true"></i>
                <span>Datos de la charla</span>
            </div>

            <div class="form-grid-2">
                <div class="form-field" style="grid-column: span 2">
                    <label>Tema de la charla <span class="required">*</span></label>
                    <input type="text"
                           @bind="Modelo.Tema"
                           placeholder="Ej. Uso correcto de EPP en altura"
                           class="@(MostrarErrores && string.IsNullOrWhiteSpace(Modelo.Tema) ? "input-error" : "")" />
                    @if (MostrarErrores && string.IsNullOrWhiteSpace(Modelo.Tema))
                    {
                        <span class="field-error">El tema es requerido</span>
                    }
                </div>

                <div class="form-field">
                    <label>Obra / Proyecto <span class="required">*</span></label>
                    <select @bind="Modelo.ObraId"
                            class="@(MostrarErrores && Modelo.ObraId == 0 ? "input-error" : "")">
                        <option value="0">Seleccionar obra...</option>
                        @foreach (var obra in ObrasDisponibles)
                        {
                            <option value="@obra.Id">@obra.Nombre</option>
                        }
                    </select>

                    @if (MostrarErrores && Modelo.ObraId == 0)
                    {
                        <span class="field-error">Seleccione una obra</span>
                    }
                </div>

                <div class="form-field">
                    <label>Cuadrilla <span class="required">*</span></label>
                    <select value="@Modelo.Cuadrilla"
                            @onchange="OnCuadrillaChange">
                        <option value="">Seleccionar cuadrilla...</option>
                        @foreach (var c in CuadrillasDisponibles)
                        {
                            <option value="@c.Nombre">@c.Nombre</option>
                        }
                    </select>
                </div>

                <div class="form-field">
                    <label>Fecha <span class="required">*</span></label>
                    <input type="date" @bind="Modelo.Fecha" />
                </div>

                <div class="form-field">
                    <label>Hora de inicio</label>
                    <input type="time" @bind="Modelo.HoraInicio" />
                </div>

                <div class="form-field">
                    <label>Duración (minutos)</label>
                    <input type="number" @bind="Modelo.DuracionMinutos" min="5" max="240" />
                </div>

                <div class="form-field">
                    <label>Tipo de charla</label>
                    <select @bind="Modelo.Tipo">
                        <option value="">Seleccionar tipo...</option>
                        @foreach (var tipo in TiposCharlaDisponibles)
                        {
                            <option value="@tipo.Nombre">@tipo.Nombre</option>
                        }
                    </select>
                </div>
            </div>

            <div class="form-field">
                <label>Descripción / Puntos tratados</label>
                <textarea @bind="Modelo.Descripcion"
                          rows="3"
                          placeholder="Resuma los temas discutidos durante la charla...">
                    </textarea>
            </div>
        </div>

        <div class="form-nav">
            <div></div>
            <button class="btn-primary" @onclick="Siguiente">
                Siguiente <i class="ti ti-arrow-right" aria-hidden="true"></i>
            </button>
        </div>
    }

    <!-- ══════════════════════════════
         PASO 2 — Asistencia
    ══════════════════════════════ -->
    @if (PasoActual == 2)
    {
        <div class="form-card">
            <div class="form-card-header">
                <i class="ti ti-users" aria-hidden="true"></i>
                <span>Lista de asistencia</span>
                <span class="card-badge">
                    @Asistentes.Count(a => a.Presente)/@Asistentes.Count presentes
                </span>
            </div>

            @if (!string.IsNullOrEmpty(Modelo.Cuadrilla))
            {
                <!-- Barra de progreso de asistencia -->
                <div class="asist-progress-wrap">
                    <div class="asist-progress-bar">
                        <div class="asist-progress-fill"
                             style="width:@AsistenciaPct%;
                                            background:@(AsistenciaPct >= 90 ? "#3B6D11" :
                                                                              AsistenciaPct >= 70 ? "#854F0B" : "#A32D2D")">
                </div>
            </div>
            <span class="asist-progress-label">@AsistenciaPct% asistencia</span>
        </div>

                <!-- Acciones masivas -->
                <div class="asist-acciones">
                    <button class="btn-secondary btn-sm" @onclick="MarcarTodos">
                        <i class="ti ti-check" aria-hidden="true"></i>
                        Marcar todos presentes
                    </button>
                    <button class="btn-secondary btn-sm" @onclick="LimpiarTodos">
                        <i class="ti ti-x" aria-hidden="true"></i>
                        Limpiar selección
                    </button>
                </div>

                <!-- Lista de trabajadores -->
                <div class="trabajador-list">
            @foreach (var asistente in Asistentes)
                    {
                        <div class="trabajador-item @(asistente.Presente ? "presente" : "")">
                            <div class="asist-avatar"
                                 style="background:@asistente.AvatarBg; color:@asistente.AvatarColor">
                                @asistente.Iniciales
                            </div>
                            <div class="trabajador-info">
                                <span class="trabajador-nombre">@asistente.Nombre</span>
                                <span class="trabajador-cargo">@asistente.Cargo</span>
                            </div>
                            <label class="toggle-asist">
                                <input type="checkbox"
                                       checked="@asistente.Presente"
                                       @onchange="() => asistente.Presente = !asistente.Presente" />
                                <span class="toggle-track">
                                    <span class="toggle-thumb"></span>
                                </span>
                            </label>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="charla-detalle-empty">
                    <i class="ti ti-users" aria-hidden="true"></i>
                    <span>Seleccione una cuadrilla en el paso anterior para ver los trabajadores</span>
                </div>
            }
        </div>

        <div class="form-nav">
            <button class="btn-secondary" @onclick="Anterior">
                <i class="ti ti-arrow-left" aria-hidden="true"></i> Anterior
            </button>
            <button class="btn-primary" @onclick="Siguiente">
                Siguiente <i class="ti ti-arrow-right" aria-hidden="true"></i>
            </button>
        </div>
    }

    <!-- ══════════════════════════════
         PASO 3 — Firma del instructor
    ══════════════════════════════ -->
    @if (PasoActual == 3)
    {
        <div class="form-card">
            <div class="form-card-header">
                <i class="ti ti-writing" aria-hidden="true"></i>
                <span>Firma del instructor</span>
                @if (FirmaCapturada)
                {
                    <span class="card-badge ok">Firma lista</span>
                }
            </div>

            <!-- Resumen de la charla -->
            <div class="charla-resumen">
                <div class="resumen-item">
                    <span class="resumen-label">Tema</span>
                    <span class="resumen-val">@Modelo.Tema</span>
                </div>
                <div class="resumen-item">
                    <span class="resumen-label">Cuadrilla</span>
                    <span class="resumen-val">@Modelo.Cuadrilla</span>
                </div>
                <div class="resumen-item">
                    <span class="resumen-label">Asistencia</span>
                    <span class="resumen-val">
                        @Asistentes.Count(a => a.Presente)/@Asistentes.Count trabajadores
                    </span>
                </div>
                <div class="resumen-item">
                    <span class="resumen-label">Fecha</span>
                    <span class="resumen-val">@Modelo.Fecha.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            @* Estado del GPS *@
            @if (GpsCargando)
            {
                <div class="alert-banner" style="margin-bottom:12px;
                 background:#E6F1FB;border:0.5px solid #B5D4F4">
                    <i class="ti ti-loader-2 spin"
                       style="color:#185FA5" aria-hidden="true"></i>
                    <span style="color:#0C447C">
                        Capturando ubicación GPS...
                    </span>
                </div>
            }
            else if (GpsCargado)
            {
                <div class="alert-banner ok" style="margin-bottom:12px">
                    <i class="ti ti-map-pin" aria-hidden="true"></i>
                    <div>
                        <div style="font-weight:500">Ubicación capturada</div>
                        <div style="font-size:11px;font-family:var(--font-mono)">
                            @Modelo.Latitud.ToString("F6"),
                            @Modelo.Longitud.ToString("F6")
                            · ±@Modelo.PrecisionGps.ToString("F0")m
                        </div>
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(GpsError))
            {
                <div class="alert-banner danger" style="margin-bottom:12px">
                    <i class="ti ti-map-pin-off" aria-hidden="true"></i>
                    <div>
                        <div style="font-weight:500">Error de geolocalización</div>
                        <div style="font-size:12px;margin-top:2px">@GpsError</div>
                    </div>
                    <button class="btn-secondary btn-sm"
                            style="margin-left:auto;flex-shrink:0"
                            @onclick="CapturarGPSAutomatico">
                        <i class="ti ti-refresh" aria-hidden="true"></i>
                        Reintentar
                    </button>
                </div>
            }

            <!-- Firma del instructor -->
            <div class="firma-info">
                <div class="firma-quien">
                    <div class="avatar" style="background:#E6F1FB;color:#185FA5">RG</div>
                    <div>
                        <div class="firma-nombre">Ramón Gómez</div>
                        <div class="firma-rol">Instructor · Prevencionista SST</div>
                    </div>
                </div>
                <div class="firma-fecha">
                    <i class="ti ti-calendar" aria-hidden="true"></i>
                    @DateTime.Now.ToString("dd/MM/yyyy hh:mm tt")
                </div>
            </div>

            <div class="firma-canvas-wrap">
                <canvas id="firmaCharlaCanvas"
                        width="600" height="180"
                        class="firma-canvas @(FirmaCapturada ? "signed" : "")">
                </canvas>
                @if (!FirmaCapturada)
                {
                    <div class="firma-placeholder">
                        <i class="ti ti-pencil" aria-hidden="true"></i>
                        Firme aquí con el mouse o con el dedo
                    </div>
                }
            </div>

            <div class="firma-actions">
                <button class="btn-secondary btn-sm" @onclick="LimpiarFirma">
                    <i class="ti ti-eraser" aria-hidden="true"></i>
                    Limpiar
                </button>
                <button class="btn-primary btn-sm"
                        @onclick="CapturarFirma"
                        disabled="@FirmaCapturada">
                    <i class="ti ti-check" aria-hidden="true"></i>
                    @(FirmaCapturada ? "Firma guardada" : "Confirmar firma")
                </button>
            </div>

            @if (FirmaCapturada)
            {
                <div class="alert-banner ok">
                    <i class="ti ti-shield-check" aria-hidden="true"></i>
                    Firma capturada. El registro será sellado con hash SHA-256 al guardar.
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(ErrorGeofencing))
        {
            <div class="alert-banner danger"
                 style="margin-bottom:12px">
                <i class="ti ti-map-pin-off" aria-hidden="true"></i>
                <div>
                    <div style="font-weight:500">
                        Registro rechazado por geofencing
                    </div>
                    <div style="font-size:12px;margin-top:2px">
                        @ErrorGeofencing
                    </div>
                </div>
            </div>
        }

        <div class="form-nav">
            <button class="btn-secondary" @onclick="Anterior">
                <i class="ti ti-arrow-left" aria-hidden="true"></i> Anterior
            </button>
            <button class="btn-primary"
                    @onclick="EnviarFormulario"
                    disabled="@(!FirmaCapturada || Guardando)">
                @if (Guardando)
                {
                    <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                    <span>Registrando...</span>
                }
                else
                {
                    <i class="ti ti-send" aria-hidden="true"></i>
                    <span>Registrar charla</span>
                }
            </button>
        </div>
    }

</div>

@code {
    // ── Pasos ──────────────────────────────────────────────────
    private List<string> Pasos = new() { "Datos generales", "Asistencia", "Firma" };
    private int PasoActual = 1;
    private bool MostrarErrores = false;
    private bool Guardando = false;
    private bool FirmaCapturada = false;

    private bool GpsCargando = false;
    private bool GpsCargado = false;
    private string GpsError = "";

    private List<TipoCharlaDto> TiposCharlaDisponibles = new();

    private string ErrorGeofencing = "";

    private class ErrorDto
    {
        public string Error { get; set; } = "";
    }

    private List<CuadrillaDto> CuadrillasDisponibles = new();

    // private List<AsistenteFormItem> ListaAsistentes = new()
    // {
    //     new() { Nombre="Juan Pérez",   Cedula="001-0000001-1", Cargo="Albañil",     Presente=true },
    //     new() { Nombre="M. López",     Cedula="001-0000002-2", Cargo="Carpintero",  Presente=true },
    //     new() { Nombre="C. Ramírez",   Cedula="001-0000003-3", Cargo="Ayudante",    Presente=true },
    //     new() { Nombre="D. Martínez",  Cedula="001-0000004-4", Cargo="Electricista",Presente=false },
    //     new() { Nombre="R. Paulino",   Cedula="001-0000005-5", Cargo="Albañil",     Presente=true },
    // };

    // public class AsistenteFormItem
    // {
    //     public string Nombre { get; set; } = "";
    //     public string Cedula { get; set; } = "";
    //     public string Cargo { get; set; } = "";
    //     public bool Presente { get; set; } = true;
    // }


    // ── Modelo ─────────────────────────────────────────────────
    private CharlaFormDto Modelo = new()
    {
        Fecha = DateTime.Today,
        HoraInicio = new TimeOnly(7, 30),
        DuracionMinutos = 30
    };

    // ── Validación ─────────────────────────────────────────────
    private bool FormularioValido =>
        !string.IsNullOrWhiteSpace(Modelo.Tema) &&
        Modelo.ObraId > 0 &&
        FirmaCapturada;

    private int AsistenciaPct => Asistentes.Count == 0 ? 0 :
        (int)Math.Round(Asistentes.Count(a => a.Presente) * 100.0 / Asistentes.Count);

    private async Task CapturarGPSAutomatico()
    {
        if (GpsCargado) return; // ya capturado, no repetir
        GpsCargando = true;
        StateHasChanged();

        try
        {
            var coords = await JS.InvokeAsync<GeoCoords>(
                "SSTGeo.getPosition");
            Modelo.Latitud = coords.Latitude;
            Modelo.Longitud = coords.Longitude;
            Modelo.PrecisionGps = coords.Accuracy;
            GpsCargado = true;
            GpsError = "";
        }
        catch
        {
            GpsError = "No se pudo obtener la ubicación. " +
                       "Active el GPS e intente nuevamente.";
        }
        finally
        {
            GpsCargando = false;
            StateHasChanged();
        }
    }

    public class GeoCoords
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public double Accuracy { get; set; }
    }

    // ── Navegación ─────────────────────────────────────────────
    private async Task Siguiente()
    {
        if (PasoActual == 1)
        {
            MostrarErrores = true;
            if (string.IsNullOrWhiteSpace(Modelo.Tema) || Modelo.ObraId == 0) return;
            MostrarErrores = false;
        }
        if (PasoActual < Pasos.Count)
        {
            PasoActual++;

            // Capturar GPS automáticamente al llegar al paso de firma
            if (PasoActual == 3)
                await CapturarGPSAutomatico();
        }
    }

    private void Anterior() { if (PasoActual > 1) PasoActual--; }
    private void Cancelar() => Nav.NavigateTo("/charlas");

    // ── Asistencia ─────────────────────────────────────────────
    private async Task CargarAsistentes()
    {
        Console.WriteLine($"[DEBUG] Cargando asistentes para: '{Modelo.Cuadrilla}'");

        if (string.IsNullOrWhiteSpace(Modelo.Cuadrilla))
        {
            Asistentes = new();
            return;
        }

        try
        {
            var empleados = await Http
                .GetFromJsonAsync<List<EmpleadoListDto>>(
                    $"api/empleados?cuadrilla={Uri.EscapeDataString(Modelo.Cuadrilla)}");

            if (empleados is not null && empleados.Any())
            {
                Asistentes = empleados.Select((e, i) => new AsistenteEditable
                {
                    EmpleadoId = e.Id,
                    Iniciales = string.Concat(
                        e.Nombre.Split(' ')
                            .Take(2)
                            .Select(p => p.Length > 0
                                ? p[0].ToString() : ""))
                        .ToUpper(),
                    Nombre = e.Nombre,
                    Cargo = e.Cargo,
                    Cedula = e.Cedula ?? "",
                    Presente = true,
                    AvatarBg = BgColors[i % BgColors.Length],
                    AvatarColor = FgColors[i % FgColors.Length]
                }).ToList();
            }
            else
            {
                Asistentes = new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando asistentes: {ex.Message}");
            Asistentes = new();
        }

        StateHasChanged();
    }

    private async Task OnCuadrillaChange(ChangeEventArgs e)
    {
        Modelo.Cuadrilla = e.Value?.ToString() ?? "";
        await CargarAsistentes();
    }
    // private void CargarAsistentes()
    // {
    //     Asistentes = Modelo.Cuadrilla switch
    //     {
    //         "Cuadrilla A" => GenerarAsistentes(new[]
    //         {
    //             ("JP","Juan Pérez","Albañil"),
    //             ("ML","M. López","Carpintero"),
    //             ("CR","C. Ramírez","Ayudante"),
    //             ("DM","D. Martínez","Electricista"),
    //             ("RP","R. Paulino","Albañil"),
    //             ("LV","L. Valdez","Plomero"),
    //         }),
    //         "Cuadrilla B" => GenerarAsistentes(new[]
    //         {
    //             ("PS","P. Sánchez","Operador"),
    //             ("EM","E. Méndez","Soldador"),
    //             ("JR","J. Reyes","Ayudante"),
    //             ("AR","A. Rosario","Albañil"),
    //         }),
    //         "Cuadrilla C" => GenerarAsistentes(new[]
    //         {
    //             ("MT","M. Torres","Electricista"),
    //             ("FG","F. García","Ayudante"),
    //             ("NA","N. Arias","Albañil"),
    //             ("OC","O. Castro","Carpintero"),
    //         }),
    //         "Cuadrilla D" => GenerarAsistentes(new[]
    //         {
    //             ("BF","B. Féliz","Operador"),
    //             ("IC","I. Cabrera","Albañil"),
    //             ("SM","S. Matos","Plomero"),
    //             ("VD","V. Díaz","Ayudante"),
    //         }),
    //         _ => new()
    //     };
    // }

    private static readonly string[] BgColors =
        { "#E6F1FB","#EAF3DE","#FAEEDA","#FCEBEB" };
    private static readonly string[] FgColors =
        { "#185FA5","#3B6D11","#854F0B","#A32D2D" };

    private List<AsistenteEditable> GenerarAsistentes(
        IEnumerable<(string ini, string nom, string cargo)> datos)
    {
        return datos.Select((d, i) => new AsistenteEditable
        {
            Iniciales = d.ini,
            Nombre = d.nom,
            Cargo = d.cargo,
            Presente = true,
            AvatarBg = BgColors[i % BgColors.Length],
            AvatarColor = FgColors[i % FgColors.Length],
        }).ToList();
    }

    private void MarcarTodos() => Asistentes.ForEach(a => a.Presente = true);
    private void LimpiarTodos() => Asistentes.ForEach(a => a.Presente = false);

    // ── Firma ──────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (PasoActual == 3)
            await JS.InvokeVoidAsync("SSTFirma.init", "firmaCharlaCanvas");
    }

    private async Task CapturarFirma()
    {
        var dataUrl = await JS.InvokeAsync<string>(
            "SSTFirma.getDataUrl", "firmaCharlaCanvas");
        if (!string.IsNullOrEmpty(dataUrl) && dataUrl != "data:,")
        {
            Modelo.FirmaBase64 = dataUrl;
            FirmaCapturada = true;
        }
    }

    private async Task LimpiarFirma()
    {
        await JS.InvokeVoidAsync("SSTFirma.clear", "firmaCharlaCanvas");
        FirmaCapturada = false;
        Modelo.FirmaBase64 = "";
    }

    // ── Envío ──────────────────────────────────────────────────
    private async Task EnviarFormulario()
    {
        if (!FormularioValido) return;
        Guardando = true;
        ErrorGeofencing = "";
        StateHasChanged();

        var dto = new CrearCharlaDto
        {
            Tema = Modelo.Tema,
            Instructor = Modelo.Instructor,
            ObraId = Modelo.ObraId,
            Obra = Modelo.Obra,
            Cuadrilla = Modelo.Cuadrilla,
            FechaCharla = Modelo.Fecha,
            DuracionMinutos = Modelo.DuracionMinutos,
            Latitud = Modelo.Latitud,
            Longitud = Modelo.Longitud,
            PrecisionGps = Modelo.PrecisionGps,
            FotoBase64 = Modelo.FotoBase64,
            FirmaBase64 = Modelo.FirmaBase64,
            Asistentes = Asistentes.Select(a => new AsistenteDto
            {
                Nombre = a.Nombre,
                Cedula = a.Cedula,
                Cargo = a.Cargo,
                Presente = a.Presente
            }).ToList()
        };

        var response = await Http.PostAsJsonAsync("api/charlas", dto);

        if (response.IsSuccessStatusCode)
            Nav.NavigateTo("/charlas");
        else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            // Leer el mensaje de error del backend
            var error = await response.Content.ReadFromJsonAsync<ErrorDto>();
            ErrorGeofencing = error?.Error ?? "No se pudo guardar la charla.";
            Guardando = false;
            StateHasChanged();
        }
        else
        {
            ErrorGeofencing = "Error inesperado. Intente nuevamente.";
            Guardando = false;
            StateHasChanged();
        }
    }

    private async Task GuardarBorrador()
    {
        Guardando = true;
        StateHasChanged();
        await Task.Delay(800); // TODO: POST /api/charlas/borrador
        Guardando = false;
        StateHasChanged();
    }

    private List<ObraActivaDto> ObrasDisponibles = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var obras = await Http.GetFromJsonAsync<List<ObraActivaDto>>("api/configuracion/obras");

            if (obras is not null)
                ObrasDisponibles = obras;

            var cuadrillas = await Http.GetFromJsonAsync<List<CuadrillaDto>>("api/configuracion/cuadrillas");
            
            if (cuadrillas is not null)
                CuadrillasDisponibles = cuadrillas;
            
            var tiposCharla = await Http.GetFromJsonAsync<List<TipoCharlaDto>>("api/configuracion/tipos-charla");
            
            if (tiposCharla is not null)
                TiposCharlaDisponibles = tiposCharla;

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando configuración: {ex.Message}");
        }
    }

