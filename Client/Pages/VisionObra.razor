    private void CambiarArea()
    {
        var idx = AreasDisponibles.IndexOf(AreaActual);
        AreaActual = AreasDisponibles[(idx + 1) % AreasDisponibles.Count];
    }

    private static string GetTiempoRelativo(DateTime timestamp)
    {
        var diff = DateTime.Now - timestamp;
        if (diff.TotalMinutes < 1) return "Hace un momento";
        if (diff.TotalMinutes < 60) return $"Hace {(int)diff.TotalMinutes} min";
        return $"Hace {(int)diff.TotalHours} hora(s)";
    }

    private static string GenerarHash()
    {
        var chars = "abcdef0123456789";
        var rng = new Random();
        return new string(
            Enumerable.Range(0, 32)
                      .Select(_ => chars[rng.Next(chars.Length)])
                      .ToArray());
    }

    public async ValueTask DisposeAsync()
    {
        if (CamaraActiva)
            await JS.InvokeVoidAsync("SSTVision.detener", "visionVideo");
    }

