    // ── Estado ─────────────────────────────────────────────────
    private string AreaActual = "Área 2-A · Andamios";
    private bool CamaraActiva = false;
    private bool AlertaActiva = false;
    private string MensajeAlerta = "";
    private int FpsActual = 0;
    private int PctCasco = 92;
    private int PctChaleco = 85;
    private int PctBotas = 78;
    private bool _tieneAcceso = true;

    private CapturaFrame? UltimaCaptura =>
        Capturas.OrderByDescending(c => c.Timestamp).FirstOrDefault();

    private List<string> AreasDisponibles = new()
    {
        "Área 2-A · Andamios",
        "Área 1-B · Estructura",
        "Área 3-C · Excavación",
        "Área 4-D · Almacén"
    };

    protected override async Task OnInitializedAsync()
    {
        _tieneAcceso = await Permisos.TieneAcceso("VisionObra");
        if (!_tieneAcceso) return;

        try
        {
            var obras = await Http
                .GetFromJsonAsync<List<ObraActivaDto>>(
                    "api/configuracion/obras");
            if (obras is not null && obras.Any())
            {
                // Generar áreas basadas en obras activas
                AreasDisponibles = obras
                    .Select(o => $"{o.Nombre} · General")
                    .ToList();
                AreaActual = AreasDisponibles.First();
            }
        }
        catch { /* usar áreas por defecto */ }
        await CargarDatosHoy();
    }

    private async Task CargarDatosHoy()
{
    try
    {
        // Capturas del día
        var capturas = await Http
            .GetFromJsonAsync<List<CapturaVisionListDto>>(
                "api/vision/capturas") ?? new();

        Capturas = capturas.Select(c => new CapturaFrame
        {
            Timestamp       = c.Timestamp.ToLocalTime(),
            Area            = c.Area,
            Descripcion     = c.Descripcion,
            TieneInfraccion = c.TieneInfraccion,
            HashSha256      = c.HashSha256,
            Latitud         = c.Latitud,
            Longitud        = c.Longitud
        }).ToList();

        // Actualizar métricas con última captura
        var ultima = capturas.FirstOrDefault();
        if (ultima is not null)
        {
            PctCasco   = ultima.PctCasco;
            PctChaleco = ultima.PctChaleco;
            PctBotas   = ultima.PctBotas;
        }

        // Alertas del día
        var alertas = await Http
            .GetFromJsonAsync<List<CapturaVisionListDto>>(
                "api/vision/alertas") ?? new();

        Alertas = alertas.Select(a => new AlertaVision
        {
            Titulo    = "Sin EPP detectado",
            Detalle   = $"{a.Area} · {a.Descripcion}",
            Timestamp = a.Timestamp.ToLocalTime(),
            Critica   = true
        }).ToList();
    }
    catch (Exception ex)
    {
        Console.WriteLine($"Error cargando visión: {ex.Message}");
    }

    StateHasChanged();
}


