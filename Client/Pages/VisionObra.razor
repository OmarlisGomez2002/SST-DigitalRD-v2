    {
        try
        {
            await JS.InvokeVoidAsync("SSTVision.iniciar", "visionVideo", "visionCanvas");
            CamaraActiva = true;
            FpsActual = 24;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al iniciar cámara: {ex.Message}");
        }
    }

