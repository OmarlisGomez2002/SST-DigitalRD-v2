    private async Task CapturarFrame()
    {
        if (!CamaraActiva) return;

        var imageDataUrl = await JS.InvokeAsync<string>(
            "SSTVision.capturarFrame", "visionVideo", "visionCanvas");

        double lat = 18.473621, lng = -69.931215;
        try
        {
            var coords = await JS.InvokeAsync<GeoCoords>(
                "SSTGeo.getPosition");
            lat = coords.Latitude;
            lng = coords.Longitude;
        }
        catch { }

        var rng = new Random();
        var tieneInfraccion = rng.Next(0, 4) == 0;
        PctCasco = Math.Max(60, Math.Min(100, PctCasco + rng.Next(-5, 6)));
        PctChaleco = Math.Max(60, Math.Min(100, PctChaleco + rng.Next(-5, 6)));
        PctBotas = Math.Max(60, Math.Min(100, PctBotas + rng.Next(-5, 6)));

        // Guardar en la BD
        var dto = new CrearCapturaVisionDto
        {
            Area = AreaActual,
            Descripcion = "Procesando...",//tieneInfraccion ? "Sin casco · 1 trabajador detectado" : "Todos con EPP · cumplimiento completo",
            TieneInfraccion = false, //tieneInfraccion,
            Latitud = lat,
            Longitud = lng,
            PctCasco = PctCasco,
            PctChaleco = PctChaleco,
            PctBotas = PctBotas,
            ImageBase64 = imageDataUrl
        };

        var response = await Http.PostAsJsonAsync("api/vision/capturar", dto);

        string hash = GenerarHash();
        if (response.IsSuccessStatusCode)
        {
            var resultado = await response.Content
                .ReadFromJsonAsync<CapturaVisionListDto>();
            if (resultado is not null)
            {
                hash = resultado.HashSha256;
                PctCasco = resultado.PctCasco;
                PctChaleco = resultado.PctChaleco;
                PctBotas = resultado.PctBotas;
                tieneInfraccion = resultado.TieneInfraccion;

                // Actualizar descripción con resultado real del modelo
                dto.Descripcion = resultado.Descripcion;
                dto.TieneInfraccion = tieneInfraccion;
                //dto.HashSha256 = hash;
            }
        }

        var captura = new CapturaFrame
        {
            Timestamp = DateTime.Now,
            Area = AreaActual,
            Descripcion = dto.Descripcion,
            TieneInfraccion = tieneInfraccion,
            HashSha256 = hash,
            Latitud = lat,
            Longitud = lng,
            ImageDataUrl = imageDataUrl
        };

        Capturas.Insert(0, captura);

        if (tieneInfraccion)
        {
            AlertaActiva = true;
            MensajeAlerta = "⚠ Sin casco detectado";
            Alertas.Insert(0, new AlertaVision
            {
                Titulo = "Sin casco detectado",
                Detalle = $"1 trabajador · {AreaActual}",
                Timestamp = DateTime.Now,
                Critica = true
            });
            StateHasChanged();

            await Task.Delay(3000);
            AlertaActiva = false;
        }

        StateHasChanged();
    }

