@page "/epp/{Id:int}/editar"
@inject NavigationManager Nav

<PageTitle>Editar EPP · SST-Digital RD</PageTitle>

<div class="form-page-header">
    <button class="btn-back" @onclick="VolverAInventario">
        <i class="ti ti-arrow-left" aria-hidden="true"></i>
        Volver a inventario
    </button>
    <div class="form-page-title">
        <h1>Editar EPP — @Trabajador.Nombre</h1>
        <span class="form-page-sub">
            @Trabajador.Cargo · @Trabajador.Cuadrilla
        </span>
    </div>
    <div class="form-page-actions">
        <button class="btn-secondary" @onclick="VolverAInventario">
            Cancelar
        </button>
        <button class="btn-primary"
                @onclick="GuardarCambios"
                disabled="@Guardando">
            @if (Guardando)
            {
                <i class="ti ti-loader-2 spin" aria-hidden="true"></i>
                <span>Guardando...</span>
            }
            else
            {
                <i class="ti ti-device-floppy" aria-hidden="true"></i>
                <span>Guardar cambios</span>
            }
        </button>
    </div>
</div>

<div class="asignar-epp-layout">

    <!-- ══ IZQUIERDA — Lista de EPP editable ══ -->
    <div class="dashboard-card">
        <div class="card-header">
            <span class="card-title">
                <i class="ti ti-hardhat" aria-hidden="true"></i>
                Equipos asignados
            </span>
            <span class="card-badge">@ArticulosEPP.Count artículos</span>
        </div>

        <div class="epp-asignar-header">
            <span style="grid-column:1/3">Equipo</span>
            <span>Marca / Modelo</span>
            <span>Fecha vencimiento</span>
            <span>Estado</span>
        </div>

        <div class="epp-asignar-list">
            @foreach (var item in ArticulosEPP)
            {
                var epp = item;
                <div class="epp-asignar-row" style="grid-template-columns:36px 1fr 120px 120px 80px">
                    <div class="epp-tipo-icon"
                         style="background:@epp.IconoBg;width:32px;height:32px">
                        <i class="ti @epp.Icono"
                           style="color:@epp.IconoColor;font-size:17px"
                           aria-hidden="true"></i>
                    </div>
                    <div>
                        <div class="epp-asignar-nombre">@epp.Nombre</div>
                        <div class="text-hint">@epp.Categoria</div>
                    </div>
                    <input type="text"
                           @bind="epp.Marca"
                           placeholder="Marca" />
                    <input type="date"
                           @bind="epp.FechaVencimiento" />
                    <select @bind="epp.EstadoActual"
                            style="height:30px;font-size:12px;
                                       padding:0 6px;border:0.5px solid var(--border-mid);
                                       border-radius:var(--radius-md);
                                       font-family:inherit;
                                       background:var(--bg-surface);
                                       color:var(--text-primary)">
                        <option>Vigente</option>
                        <option>Vencido</option>
                        <option>Dañado</option>
                        <option>N/A</option>
                    </select>
                </div>
            }
        </div>

        <div class="epp-asignar-hint">
            <i class="ti ti-info-circle" aria-hidden="true"></i>
            Actualiza la marca, fecha de vencimiento y estado de cada equipo.
        </div>
    </div>

    <!-- ══ DERECHA — Resumen ══ -->
    <div style="display:flex;flex-direction:column;gap:12px">

        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-user" aria-hidden="true"></i>
                    Trabajador
                </span>
            </div>
            <div class="worker-selected-card">
                <div class="mini-avatar"
                     style="background:@Trabajador.AvatarBg;
                            color:@Trabajador.AvatarColor;
                            width:38px;height:38px;font-size:13px">
                    @Trabajador.Iniciales
                </div>
                <div class="worker-selected-info">
                    <span class="worker-selected-name">@Trabajador.Nombre</span>
                    <span class="worker-selected-role">
                        @Trabajador.Cargo · @Trabajador.Cuadrilla
                    </span>
                </div>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-header">
                <span class="card-title">
                    <i class="ti ti-receipt" aria-hidden="true"></i>
                    Resumen
                </span>
            </div>
            <div class="epp-resumen-card">
                <div class="epp-resumen-row">
                    <span class="epp-resumen-label">Total artículos</span>
                    <span class="epp-resumen-val">@ArticulosEPP.Count</span>
                </div>
                <div class="epp-resumen-row">
                    <span class="epp-resumen-label">Vigentes</span>
                    <span class="epp-resumen-val" style="color:#3B6D11">
                        @ArticulosEPP.Count(x => x.EstadoActual == "Vigente")
                    </span>
                </div>
                <div class="epp-resumen-row">
                    <span class="epp-resumen-label">Vencidos</span>
                    <span class="epp-resumen-val" style="color:#A32D2D">
                        @ArticulosEPP.Count(x => x.EstadoActual == "Vencido")
                    </span>
                </div>
                <div class="epp-resumen-row">
                    <span class="epp-resumen-label">Próx. vencimiento</span>
                    <span class="epp-resumen-val" style="color:#854F0B">
                        @ProximoVencimiento
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private bool Guardando = false;

    private TrabajadorInfo Trabajador = new();

    private void VolverAInventario() => Nav.NavigateTo("/epp");

    private async Task GuardarCambios()
    {
        Guardando = true;
        StateHasChanged();
        await Task.Delay(1000); // TODO: PUT /api/epp/{Id}
        Nav.NavigateTo("/epp");
    }

    private string ProximoVencimiento
    {
        get
        {
            var fechas = ArticulosEPP
                .Where(x => x.EstadoActual == "Vigente" &&
                            x.FechaVencimiento != default)
                .Select(x => x.FechaVencimiento)
                .ToList();
            return fechas.Any()
                ? fechas.Min().ToString("dd/MM/yyyy") : "—";
        }
    }

    protected override void OnInitialized()
    {
        // TODO: GET /api/epp/trabajador/{Id}
        Trabajador = new()
        {
            Nombre = "Juan Pérez",
            Iniciales = "JP",
            Cargo = "Albañil",
            Cuadrilla = "Cuadrilla A",
            AvatarBg = "#E6F1FB",
            AvatarColor = "#185FA5"
        };
    }

    private List<ArticuloEPPEditable> ArticulosEPP = new()
    {
        new("ti-hardhat",   "#E6F1FB","#185FA5","Casco de seguridad", "Protección craneal",  "MSA V-Gard",  new DateTime(2025,1,1),  "Vencido"),
        new("ti-shirt",     "#EAF3DE","#3B6D11","Chaleco reflectivo",  "Visibilidad",         "3M Hi-Vis",   new DateTime(2026,3,15), "Vigente"),
        new("ti-shoe",      "#FAEEDA","#854F0B","Botas de seguridad",  "Protección de pies",  "Caterpillar", new DateTime(2026,5,10), "Vigente"),
        new("ti-hand-stop", "#F1EFE8","#5F5E5A","Guantes",             "Protección de manos", "3M",          new DateTime(2025,6,5),  "Vigente"),
        new("ti-ripple",    "#FCEBEB","#A32D2D","Arnés de seguridad",  "Trabajo en altura",   "",            default,                 "N/A"),
    };

    public class TrabajadorInfo
    {
        public string Nombre { get; set; } = "";
        public string Iniciales { get; set; } = "";
        public string Cargo { get; set; } = "";
        public string Cuadrilla { get; set; } = "";
        public string AvatarBg { get; set; } = "#E6F1FB";
        public string AvatarColor { get; set; } = "#185FA5";
    }

    public class ArticuloEPPEditable
    {
        public string Icono { get; set; }
        public string IconoBg { get; set; }
        public string IconoColor { get; set; }
        public string Nombre { get; set; }
        public string Categoria { get; set; }
        public string Marca { get; set; }
        public DateTime FechaVencimiento { get; set; }
        public string EstadoActual { get; set; }

        public ArticuloEPPEditable(string icono, string bg, string color,
            string nombre, string cat, string marca,
            DateTime fecha, string estado)
        {
            Icono = icono; IconoBg = bg; IconoColor = color;
            Nombre = nombre; Categoria = cat; Marca = marca;
            FechaVencimiento = fecha; EstadoActual = estado;
        }
    }
}