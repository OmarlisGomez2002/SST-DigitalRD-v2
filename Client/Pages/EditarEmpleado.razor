    //     };
    // }

    // private async Task GuardarCambios()
    // {
    //     Guardando = true;
    //     StateHasChanged();
    //     await Task.Delay(1000); // TODO: PUT /api/empleados/{Id}
    //     Nav.NavigateTo("/empleados");
    // }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var resultado = await Http.GetFromJsonAsync<EmpleadoDetalleDto>($"api/empleados/{Id}");

            if (resultado is not null)
            {
                Modelo = new EmpleadoEditDto
                {
                    Nombre = resultado.Nombre,
                    Cedula = resultado.Cedula,
                    FechaNacimiento = resultado.FechaNacimiento,
                    Telefono = resultado.Telefono,
                    Correo = resultado.Correo,
                    Direccion = resultado.Direccion,
                    Cargo = resultado.Cargo,
                    Cuadrilla = resultado.Cuadrilla,
                    FechaIngreso = resultado.FechaIngreso,
                    TipoContrato = resultado.TipoContrato,
                    NumeroTSS = resultado.NumeroTSS,
                    Estado = resultado.Estado
                };
            }

            var cargos = await Http.GetFromJsonAsync<List<CargoEmpleadoDto>>("api/configuracion/cargos");
            
            if (cargos is not null)
                CargosDisponibles = cargos;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando empleado: {ex.Message}");
        }
    }

    private async Task GuardarCambios()
    {
        MostrarErrores = true;
        Guardando = true;
        StateHasChanged();

        var dto = new CrearEmpleadoDto
        {
            Nombre = Modelo.Nombre,
            Cedula = Modelo.Cedula,
            FechaNacimiento = Modelo.FechaNacimiento,
            Telefono = Modelo.Telefono,
            Correo = Modelo.Correo,
            Direccion = Modelo.Direccion,
            Cargo = Modelo.Cargo,
            Cuadrilla = Modelo.Cuadrilla,
            Obra = "Torre Piantini IV",
            FechaIngreso = Modelo.FechaIngreso,
            TipoContrato = Modelo.TipoContrato,
            NumeroTSS = Modelo.NumeroTSS,
            Estado = Modelo.Estado
        };

        var response = await Http
            .PutAsJsonAsync($"api/empleados/{Id}", dto);

        if (response.IsSuccessStatusCode)
            Nav.NavigateTo("/empleados");
        else
        {
            MostrarErrores = true;
            Guardando = false;
            StateHasChanged();
        }
    }

    private async Task DesactivarEmpleado()
    {
        Modelo.Estado = "Inactivo";
        await GuardarCambios();
    }

    private void Cancelar() => Nav.NavigateTo("/empleados");

    public class EmpleadoEditDto
    {
        public string Nombre { get; set; } = "";
        public string Cedula { get; set; } = "";
        public DateTime FechaNacimiento { get; set; }
        public string Telefono { get; set; } = "";
        public string Correo { get; set; } = "";
        public string Direccion { get; set; } = "";
        public string Cargo { get; set; } = "";
        public string Cuadrilla { get; set; } = "";
        public DateTime FechaIngreso { get; set; }
        public string TipoContrato { get; set; } = "";
        public string NumeroTSS { get; set; } = "";
        public string Estado { get; set; } = "";
    }
}