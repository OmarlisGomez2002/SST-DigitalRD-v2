@using SSTDigitalRD.Shared.DTOs

<div class="dashboard-card alertas-panel">
    <div class="card-header">
        <span class="card-title">Alertas activas</span>
        <a href="/incidentes" class="card-link">Ver todas</a>
    </div>

    @if (!Alertas.Any())
    {
        <div class="alertas-empty">
            <i class="ti ti-shield-check" aria-hidden="true"></i>
            <span>Sin alertas activas</span>
        </div>
    }
    else
    {
        <div class="alertas-list">
            @foreach (var alerta in Alertas)
            {
                <div class="alerta-item">
                    <div class="alerta-dot
                                 @(alerta.Tipo == "danger" ? "dot-danger" : "dot-warn")">
                    </div>
                    <div class="alerta-content">
                        <div class="alerta-titulo">@alerta.Titulo</div>
                        <div class="alerta-desc">@alerta.Descripcion</div>
                        <div class="alerta-tiempo">@alerta.Tiempo</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public List<DashboardAlertaDto> Alertas { get; set; } = new();
}
