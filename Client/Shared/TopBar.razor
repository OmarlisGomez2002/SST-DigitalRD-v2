@inject NavigationManager Nav
@inject HttpClient Http
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@* @inject SSTDigitalRD.Client.Services.PermisosService Permisos *@

<header class="topbar">
    <div class="topbar-left">
        <h1 class="page-title">@TituloFinal</h1>
        <span class="page-sub">@DateTime.Now.ToString("dddd, d 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-DO")) </span>
    </div>
    <div class="topbar-actions">
        <button class="icon-btn" title="Buscar">
            <i class="ti ti-search"></i>
        </button>
        <button class="icon-btn notif" title="Notificaciones">
            <i class="ti ti-bell"></i>
            <span class="notif-dot"></span>
        </button>
        @* @if (_puedeCrear)

        {            
            <button class="btn-primary" @onclick="NuevaInspeccion">
                <i class="ti ti-plus"></i> Nueva inspección
            </button>                } *@
    </div>
</header>

@code {
    [Parameter] public string PageTitle { get; set; } = "";

    private static readonly Dictionary<string, string> Titulos = new()
    {
        { "/",                  "Dashboard" },
        { "/inspecciones",      "Inspecciones" },
        { "/charlas",           "Charlas SST" },
        { "/epp",               "EPP / Inventario" },
        { "/incidentes",        "Incidentes" },
        { "/ia-predictiva",     "IA Predictiva" },
        { "/vision-obra",       "Visión en Obra" },
        { "/gemelo-digital",    "Gemelo Digital" },
        { "/dossier",           "Dossier MTRAB" },
        { "/empleados",         "Empleados" },
        { "/configuracion",     "Configuración" },
    };

    private string TituloFinal
    {
        get
        {
            if (!string.IsNullOrEmpty(PageTitle))
                return PageTitle;

            var ruta = new Uri(Nav.Uri).AbsolutePath
                .TrimEnd('/');

            // Buscar coincidencia exacta primero
            if (Titulos.TryGetValue(
                    string.IsNullOrEmpty(ruta) ? "/" : ruta,
                    out var titulo))
                return titulo;

            // Buscar por prefijo para rutas con parámetros
            // ej. /inspecciones/nueva, /empleados/1/editar
            var prefijo = Titulos.Keys
                .Where(k => k != "/" &&
                            ruta.StartsWith(k,
                                StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(k => k.Length)
                .FirstOrDefault();

            return prefijo is not null
                ? Titulos[prefijo] : "SST-Digital RD";
        }
    }

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender,
        LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
