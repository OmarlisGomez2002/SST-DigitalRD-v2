@using SSTDigitalRD.Shared.DTOs
@inject NavigationManager Nav

<div class="dashboard-card">
    <div class="card-header">
        <span class="card-title">Últimas inspecciones</span>
        <a href="/inspecciones" class="card-link">Ver historial →</a>
    </div>

    <table class="insp-table">
        <thead>
            <tr>
                <th>Área / Actividad</th>
                <th>Inspector</th>
                <th>Fecha</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @if (!Inspecciones.Any())
            {
                <tr>
                    <td colspan="4" class="empty-state">
                        <i class="ti ti-clipboard" aria-hidden="true"></i>
                        <span>Sin inspecciones registradas</span>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var insp in Inspecciones)
                {
                    <tr style="cursor:pointer"
                        @onclick="() => VerDetalle(insp.Id)">
                        <td style="font-weight:500">@insp.Area</td>
                        <td>@insp.Inspector</td>
                        <td>@insp.Fecha</td>
                        <td>
                            <span class="pill @GetEstadoPill(insp.Estado)">
                                @insp.Estado
                            </span>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter]
    public List<DashboardInspeccionRecienteDto> Inspecciones { get; set; } = new();

    private void VerDetalle(int id) =>
        Nav.NavigateTo($"/inspecciones/{id}");

    private static string GetEstadoPill(string estado) => estado switch
    {
        "Conforme" => "pill-ok",
        "Observación" => "pill-warn",
        "No conforme" => "pill-danger",
        _ => "pill-info"
    };
}
