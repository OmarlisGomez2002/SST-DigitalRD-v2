@using SSTDigitalRD.Shared.DTOs
@inject NavigationManager Nav

<div class="dashboard-card epp-panel">
    <div class="card-header">
        <span class="card-title">Detección EPP en obra</span>
        <a href="/vision-obra" class="card-link">Ver cámaras →</a>
    </div>

    <div class="epp-camara-badge">
        <div class="epp-camara-dot"></div>
        <span>
            YOLOv4-Tiny · En vivo —
            Cámara Área 2-A · Actualizado hace 12s
        </span>
    </div>

    <div class="epp-stats-grid">
        <div class="epp-stat">
            <div class="epp-stat-val">@PctCascos<small>%</small></div>
            <div class="epp-stat-label">Cascos</div>
            <div class="epp-bar-track">
                <div class="epp-bar-fill epp-bar-blue"
                     style="width:@PctCascos%">
                </div>
            </div>
        </div>
        <div class="epp-stat">
            <div class="epp-stat-val">@PctChalecos<small>%</small></div>
            <div class="epp-stat-label">Chalecos</div>
            <div class="epp-bar-track">
                <div class="epp-bar-fill epp-bar-green"
                     style="width:@PctChalecos%">
                </div>
            </div>
        </div>
        <div class="epp-stat">
            <div class="epp-stat-val">@PctBotas<small>%</small></div>
            <div class="epp-stat-label">Botas</div>
            <div class="epp-bar-track">
                <div class="epp-bar-fill epp-bar-amber"
                     style="width:@PctBotas%">
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int PctCascos { get; set; } = 92;
    [Parameter] public int PctChalecos { get; set; } = 85;
    [Parameter] public int PctBotas { get; set; } = 78;
}
